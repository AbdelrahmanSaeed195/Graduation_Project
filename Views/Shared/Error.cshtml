@model ErrorViewModel
@{
    ViewData["Title"] = "حدث خطأ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="app-card">
                <div class="card-body text-center p-5">
                    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:48px"></i>
                    <h2 class="mt-3 academic-heading">حدث خطأ أثناء معالجة الطلب</h2>
                    <p class="text-muted">نعتذر، حدث خطأ غير متوقع. حاول مرة أخرى أو تواصل مع مسؤول النظام.</p>

                    @if (Model?.ShowRequestId == true)
                    {
                        <div class="mt-3">
                            <small class="text-muted">معرف الطلب: <code>@Model.RequestId</code></small>
                        </div>
                    }

                    <div class="mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-academic-primary me-2"><i class="bi bi-house"></i> العودة للرئيسية</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
