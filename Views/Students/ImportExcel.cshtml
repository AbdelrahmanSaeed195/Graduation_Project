@{
    ViewData["Title"] = "استيراد من إكسيل";
}

<div class="content-body" dir="rtl">
    <div class="card academic-card shadow-sm">
        <div class="card-header bg-academic-primary text-white">
            <h5 class="mb-0"><i class="bi bi-file-earmark-excel me-2"></i> استيراد بيانات الطلاب من Excel</h5>
        </div>
        <div class="card-body bg-white">
            <div class="alert alert-info">
                <h6><i class="bi bi-info-circle me-2"></i> تعليمات هامة:</h6>
                <ul>
                    <li>
                        يجب أن يحتوي ملف Excel على العناوين التالية بالظبط في أول صف:
                        <strong>[الاسم الكامل، الرقم القومي، السنة الدراسية، التخصص]</strong>
                    </li>
                    <li>سيتم تجاهل أي رقم قومي مسجل مسبقاً تلقائياً.</li>
                </ul>
            </div>

            <form asp-action="ImportExcel" method="post" enctype="multipart/form-data" class="mt-4">
                <div class="mb-3">
                    <label class="form-label fw-bold">اختر ملف الإكسيل:</label>
                    <input type="file" name="excelfile" class="form-control academic-input" accept=".xlsx, .xls" required />
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="bi bi-cloud-arrow-up me-1"></i> بدء الاستيراد
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
                </div>
            </form>
        </div>
    </div>
</div>