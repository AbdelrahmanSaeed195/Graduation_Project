@model IEnumerable<projectweb.Models.Student>

@{
    ViewData["Title"] = "إدارة الطلاب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold academic-heading"><i class="bi bi-mortarboard-fill me-2"></i> سجل الطلاب</h1>

        <div class="d-flex gap-2">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="DistributeStudents"
                   id="btnDistribute"
                   class="btn btn-success px-4 shadow-sm">
                    <i class="bi bi-diagram-3 me-1"></i> توزيع الطلاب تلقائياً
                </a>
                <a asp-action="Create" class="btn btn-academic-primary px-4 shadow-sm">
                    <i class="bi bi-person-plus-fill me-1"></i> إضافة طالب
                </a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 10px;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 10px;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card academic-card mb-4 shadow-sm">
        <div class="card-body p-3 bg-white rounded">
            <form asp-action="Search" method="get" class="row g-3">
                <div class="col-md-9">
                    <input type="text" name="searchTerm" class="form-control academic-input" placeholder="ابحث بالاسم أو الرقم القومي .." value="@ViewBag.Search">
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-academic-primary w-100 fw-bold"><i class="bi bi-search me-1"></i> ابحث</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100"><i class="bi bi-arrow-counterclockwise me-1"></i> إعادة تعيين</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card academic-card overflow-hidden shadow-sm">
        <div class="table-responsive">
            <table class="table academic-table table-hover align-middle mb-0 text-center">
                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>الرقم القومي</th>
                        <th>السنة الدراسية</th>
                        <th>التخصص</th>
                        <th>رقم الجلوس</th>
                        <th>اللجنة الثابتة</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var s in Model)
                        {
                            <tr>
                                <td class="fw-bold text-start ps-3">@s.FullName</td>
                                <td><span style="color: var(--text-muted);">@s.NationalId</span></td>
                                <td>
                                    @{
                                        string academicLevel = s.AcademicYear switch
                                        {
                                            projectweb.Models.AcademicLevel.FirstYear => "المستوى الأول",
                                            projectweb.Models.AcademicLevel.SecondYear => "المستوى الثاني",
                                            projectweb.Models.AcademicLevel.ThirdYear => "المستوى الثالث",
                                            projectweb.Models.AcademicLevel.FourthYear => "المستوى الرابع",
                                            _ => s.AcademicYear.ToString()
                                        };
                                    }
                                    <span class="badge" style="background-color: var(--bg-light); color: var(--primary-navy); border: 1px solid var(--border-color); padding: 8px 12px;">
                                        @academicLevel
                                    </span>
                                </td>
                                <td>
                                    @{
                                        string specializationName = s.Specialization switch
                                        {
                                            projectweb.Models.StudentSpecialization.General => "عام",
                                            projectweb.Models.StudentSpecialization.Management => "إدارة",
                                            projectweb.Models.StudentSpecialization.Teaching => "تدريس",
                                            projectweb.Models.StudentSpecialization.Training => "تدريب",
                                            _ => s.Specialization.ToString()
                                        };
                                    }
                                    <span class="badge bg-light text-secondary border px-2 py-2">
                                        @specializationName
                                    </span>
                                </td>
                                <td>
                                    <span class="fw-bold" style="color: var(--accent-blue);">
                                        @(s.SeatNumber > 0 ? s.SeatNumber.ToString() : "-")
                                    </span>
                                </td>
                                <td>
                                    @if (s.Committee != null)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2">
                                            <i class="bi bi-building-check me-1"></i> لجنة @s.Committee.CommitteeNumber
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border px-3 py-2">
                                            غير مسكن
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group shadow-sm" role="group" style="border-radius: 6px; overflow: hidden;">
                                        <a asp-action="Committee" asp-route-id="@s.StudentId" class="btn btn-sm btn-dark" title="استعراض مقعد اللجنة">
                                            <i class="bi bi-building-check"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@s.StudentId" class="btn btn-sm btn-info text-white" title="التفاصيل">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                      
                                            <a asp-action="Edit" asp-route-id="@s.StudentId" class="btn btn-sm btn-warning" title="تعديل">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@s.StudentId" class="btn btn-sm btn-danger" title="حذف">
                                                <i class="bi bi-trash"></i>
                                           </a>
                                        
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="py-5" style="color: var(--text-muted);">
                                <i class="bi bi-person-x d-block mb-2 h1"></i>
                                لا توجد بيانات للطلاب تتوافق مع معايير البحث الحالية.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#btnDistribute').on('click', function (e) {
                e.preventDefault();
                var url = $(this).attr('href');

                Swal.fire({
                    title: 'توزيع الطلاب التلقائي',
                    text: "هل تريد بدء توزيع الطلاب غير المسكنين على اللجان الثابتة المتاحة وتوليد أرقام جلوسهم أبجدياً؟",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'توزيع الآن',
                    cancelButtonText: 'إلغاء',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: 'جاري العمل وموازنة السعة...',
                            text: 'يتم الآن فحص سعة اللجان وهندسة المقاعد، يرجى الانتظار.',
                            allowOutsideClick: false,
                            didOpen: () => { Swal.showLoading(); }
                        });
                        window.location.href = url;
                    }
                });
            });
        });
    </script>
}