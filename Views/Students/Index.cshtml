@model IEnumerable<projectweb.Models.Student>

@{
    ViewData["Title"] = "إدارة الطلاب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 academic-heading">
            <i class="bi bi-mortarboard-fill me-2"></i> سجل الطلاب
        </h1>

        <div class="d-flex gap-2">
            <a asp-action="DistributeStudents"
               class="btn btn-success px-4"
               onclick="return confirm('هل تريد توزيع الطلاب الآن؟');">
                <i class="bi bi-diagram-3 me-1"></i> توزيع الطلاب
            </a>

            <a asp-action="Create" class="btn btn-academic-primary px-4">
                <i class="bi bi-plus-circle me-1"></i> إضافة طالب
            </a>
        </div>
    </div>

    <!-- Table -->
    <div class="academic-card">
        <div class="table-responsive">
            <table class="table academic-table align-middle mb-0 text-center">
                <thead>
                    <tr>
                        <th>كود</th>
                        <th>الاسم</th>
                        <th>الرقم القومي</th>
                        <th>السنة</th>
                        <th>رقم الجلوس</th>
                        <th>اللجنة / الجلسة</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var s in Model)
                        {
                            <tr>
                                <td>@s.StudentId</td>
                                <td class="fw-bold">@s.FullName</td>
                                <td><span style="color: var(--text-muted);">@s.NationalId</span></td>
                                <td>
                                    <span class="badge" style="background-color: var(--bg-light); color: var(--primary-navy); border: 1px solid var(--border-color);">
                                        سنة @s.AcademicYear
                                    </span>
                                </td>
                                <td>
                                    <span class="fw-bold" style="color: var(--accent-blue);">
                                        @(s.SeatNumber > 0 ? s.SeatNumber.ToString() : "-")
                                    </span>
                                </td>
                                <td>
                                    @if (s.ExamSchedule != null && s.ExamSchedule.Committee != null)
                                    {
                                        <div>
                                            <span class="badge bg-success px-3 py-2 mb-1">
                                                لجنة @s.ExamSchedule.Committee.CommitteeNumber
                                            </span>
                                            <br />
                                            <small style="color: var(--text-muted);">
                                                جلسة: @s.ExamSchedule.ExamScheduleId
                                            </small>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-3 py-2">
                                            غير موزع
                                        </span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Committee" asp-route-id="@s.StudentId" class="btn btn-sm btn-dark" title="استعراض اللجنة">
                                        <i class="bi bi-building-check"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@s.StudentId" class="btn btn-sm btn-info text-white" title="التفاصيل">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@s.StudentId" class="btn btn-sm btn-warning" title="تعديل">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@s.StudentId" class="btn btn-sm btn-danger" title="حذف" onclick="return confirm('تأكيد الحذف؟ سيتم إعادة ترتيب أرقام الجلوس إذا كان الطالب موزعاً.');">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="py-4" style="color: var(--text-muted);">
                                لا توجد بيانات للطلاب
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>