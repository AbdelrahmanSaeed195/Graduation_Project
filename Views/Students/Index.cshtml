@model IEnumerable<projectweb.Models.Student>

@{
    ViewData["Title"] = "إدارة الطلاب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold academic-heading"><i class="bi bi-mortarboard-fill me-2"></i> سجل الطلاب</h1>

        <div class="d-flex gap-2">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="DistributeStudents"
                   id="btnDistribute"
                   class="btn btn-success px-4 shadow-sm">
                    <i class="bi bi-diagram-3 me-1"></i> توزيع الطلاب
                </a>
                <a asp-action="Create" class="btn btn-academic-primary px-4 shadow-sm">
                    <i class="bi bi-person-plus-fill me-1"></i> إضافة طالب
                </a>
            }
        </div>
    </div>

    <div class="card academic-card mb-4 shadow-sm">
        <div class="card-body p-3 bg-white rounded">
            <form asp-action="Search" method="get" class="row g-3">
                <div class="col-md-9">
                    <input type="text" name="searchTerm" class="form-control academic-input" placeholder="ابحث بالاسم أو الرقم القومي .." value="@ViewBag.Search">
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-academic-primary w-100 fw-bold"><i class="bi bi-search me-1"></i> ابحث</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100"><i class="bi bi-arrow-counterclockwise me-1"></i> إعادة تعيين</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card academic-card overflow-hidden shadow-sm">
        <div class="table-responsive">
            <table class="table academic-table table-hover align-middle mb-0 text-center">
                <thead>
                    <tr>
                        <th>كود</th>
                        <th>الاسم</th>
                        <th>الرقم القومي</th>
                        <th>السنة الدراسية</th>
                        <th>رقم الجلوس</th>
                        <th>اللجنة / الجلسة</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var s in Model)
                        {
                            <tr>
                                <td>@s.StudentId</td>
                                <td class="fw-bold">@s.FullName</td>
                                <td><span style="color: var(--text-muted);">@s.NationalId</span></td>
                                <td>
                                    @{
                                        string academicLevel = s.AcademicYear switch
                                        {
                                            "1" => "المستوى الأول",
                                            "2" => "المستوى الثاني",
                                            "3" => "المستوى الثالث",
                                            "4" => "المستوى الرابع",
                                            _ => s.AcademicYear
                                        };
                                    }
                                    <span class="badge" style="background-color: var(--bg-light); color: var(--primary-navy); border: 1px solid var(--border-color); padding: 8px 12px;">
                                        @academicLevel
                                    </span>
                                </td>
                                <td>
                                    <span class="fw-bold" style="color: var(--accent-blue);">
                                        @(s.SeatNumber > 0 ? s.SeatNumber.ToString() : "-")
                                    </span>
                                </td>
                                <td>
                                    @if (s.ExamSchedule != null && s.ExamSchedule.Committee != null && s.ExamSchedule.Exam != null)
                                    {
                                        <div>
                                            <span class="badge bg-success px-3 py-2 mb-1">
                                                لجنة @s.ExamSchedule.Committee.CommitteeNumber
                                            </span>
                                            <br />
                                            <small class="text-dark fw-bold d-block">
                                                <i class="bi bi-calendar3 me-1"></i>
                                                @s.ExamSchedule.Exam.ExamDate.ToString("yyyy-MM-dd")
                                            </small>
                                            <small class="text-muted d-block">
                                                <i class="bi bi-clock me-1"></i>
                                                @{
                                                    var startStr = DateTime.Today.Add(s.ExamSchedule.Exam.StartTime).ToString("hh:mm tt");
                                                    var endStr = DateTime.Today.Add(s.ExamSchedule.Exam.EndTime).ToString("hh:mm tt");
                                                }
                                                @startStr - @endStr
                                            </small>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-3 py-2">
                                            غير موزع
                                        </span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Committee" asp-route-id="@s.StudentId" class="btn btn-sm btn-dark" title="استعراض اللجنة">
                                        <i class="bi bi-building-check"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@s.StudentId" class="btn btn-sm btn-info text-white" title="التفاصيل">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@s.StudentId" class="btn btn-sm btn-warning" title="تعديل">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@s.StudentId" class="btn btn-sm btn-danger" title="حذف">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="py-5" style="color: var(--text-muted);">
                                <i class="bi bi-person-x d-block mb-2 h1"></i>
                                لا توجد بيانات للطلاب
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#btnDistribute').on('click', function (e) {
                e.preventDefault();
                var url = $(this).attr('href');

                Swal.fire({
                    title: 'توزيع الطلاب',
                    text: "هل تريد بدء توزيع الطلاب على اللجان وتوليد أرقام الجلوس؟",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'توزيع الآن',
                    cancelButtonText: 'إلغاء',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: 'جاري العمل...',
                            text: 'يتم الآن توزيع الطلاب، يرجى الانتظار.',
                            allowOutsideClick: false,
                            didOpen: () => { Swal.showLoading(); }
                        });
                        window.location.href = url;
                    }
                });
            });
        });
    </script>
}