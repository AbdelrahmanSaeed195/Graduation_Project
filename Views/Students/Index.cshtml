
@model IEnumerable<projectweb.Models.Student>

@{
    ViewData["Title"] = "إدارة الطلاب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold academic-heading">
            <i class="bi bi-mortarboard-fill me-2"></i> سجل الطلاب
        </h1>
        <div class="d-flex gap-2">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="DistributeStudents"
                       id="btnDistribute"
                       class="btn btn-success px-4 shadow-sm">
                    <i class="bi bi-diagram-3 me-1"></i> توزيع الطلاب تلقائياً
                </a>
                <a asp-action="ImportExcel"
                       class="btn px-4 shadow-sm"
                       style="background-color: #1565c0; color: white;">
                    <i class="bi bi-file-earmark-arrow-up me-1"></i> استيراد
                </a>
                <a asp-action="Create" class="btn btn-academic-primary px-4 shadow-sm">
                    <i class="bi bi-person-plus-fill me-1"></i> إضافة طالب
                </a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* قسم البحث *@
    <div class="card academic-card mb-4 shadow-sm">
        <div class="card-body p-3 bg-white rounded">
            <div class="row g-3">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-start-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" id="searchInput" class="form-control academic-input border-end-0"
                               placeholder="ابدأ بالكتابة للبحث بالاسم أو الرقم القومي..."
                               value="@ViewBag.Search" autocomplete="off">
                    </div>
                </div>
                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> إعادة تعيين
                    </a>
                </div>
            </div>
        </div>
    </div>

    @* الجدول *@
    <div id="tableContainer" class="card academic-card overflow-hidden shadow-sm">
        <partial name="_StudentTablePartial" model="Model" />
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // ========== AJAX Search ==========
            let timeout = null;
            $('#searchInput').on('input', function () {
                clearTimeout(timeout);
                let searchValue = $(this).val();

                timeout = setTimeout(function () {
                    $.ajax({
                        url: '@Url.Action("Index", "Students")',
                        type: 'GET',
                        data: { searchTerm: searchValue },
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        beforeSend: function () {
                            $('#tableContainer').css('opacity', '0.6');
                        },
                        success: function (data) {
                            $('#tableContainer').html(data);
                            $('#tableContainer').css('opacity', '1');
                        },
                        error: function () {
                            $('#tableContainer').css('opacity', '1');
                        }
                    });
                }, 300);
            });

            // ========== Distribute Button ==========
            $('#btnDistribute').on('click', function (e) {
                e.preventDefault();
                var url = $(this).attr('href');

                Swal.fire({
                    title: 'توزيع الطلاب التلقائي',
                    text: "هل تريد بدء توزيع الطلاب غير المسكنين على اللجان الثابتة المتاحة وتوليد أرقام جلوسهم أبجدياً؟",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'توزيع الآن',
                    cancelButtonText: 'إلغاء',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: 'جاري العمل وموازنة السعة...',
                            text: 'يتم الآن فحص سعة اللجان وهندسة المقاعد، يرجى الانتظار.',
                            allowOutsideClick: false,
                            didOpen: () => { Swal.showLoading(); }
                        });
                        window.location.href = url;
                    }
                });
            });

        });
    </script>
}