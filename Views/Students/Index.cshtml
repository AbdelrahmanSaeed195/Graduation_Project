@model IEnumerable<projectweb.Models.Student>

@{
    ViewData["Title"] = "إدارة الطلاب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold academic-heading"><i class="bi bi-mortarboard-fill me-2"></i> سجل الطلاب</h1>
        <a asp-action="Create" class="btn btn-academic-primary px-4">
            <i class="bi bi-plus-circle me-1"></i> إضافة طالب
        </a>
    </div>

    <div class="academic-card">
        <div class="table-responsive">
            <table class="table academic-table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">كود الطالب</th>
                        <th>الاسم الكامل</th>
                        <th>الرقم القومي</th>
                        <th class="text-center">السنة الدراسية</th>
                        <th class="text-center">رقم الجلوس</th>
                        <th class="text-center">اللجنة التابع لها</th>
                        <th class="text-center pe-4">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var s in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">@s.StudentId</td>
                                <td class="fw-medium" style="color: var(--text-main);">@s.FullName</td>
                                <td class="text-muted small">@s.NationalId</td>
                                <td class="text-center">
                                    <span class="badge px-3 py-2" style="background-color: var(--bg-light); color: var(--text-main); border: 1px solid var(--border-color);">
                                        المستوى @s.AcademicYear
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="fw-bold" style="color: @(s.SeatNumber > 0 ? "var(--accent-blue)" : "var(--text-muted)");">
                                        @(s.SeatNumber > 0 ? s.SeatNumber.ToString() : "-")
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (s.CommitteeId.HasValue && s.Committee != null)
                                    {
                                        <a asp-action="Committee" asp-route-id="@s.StudentId" class="badge bg-success text-decoration-none px-3 py-2">
                                            لجنة رقم @s.Committee.CommitteeNumber
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-3 py-2">غير موزع</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a asp-action="Details" asp-route-id="@s.StudentId" class="btn btn-sm btn-outline-info" title="التفاصيل">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@s.StudentId" class="btn btn-sm btn-outline-academic" title="تعديل">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@s.StudentId" class="btn btn-sm btn-outline-danger" title="حذف" onclick="return confirm('هل أنت متأكد من حذف هذا الطالب؟');">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">لا توجد بيانات مطابقة</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>