@model projectweb.Models.Student

@{
    ViewData["Title"] = "تأكيد حذف طالب";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool hasRelatives = Model.Relatives != null && Model.Relatives.Any();
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-lg-6">
        <div class="card academic-card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
            <div class="card-body p-4 bg-white text-center">

                <div class="mb-3">
                    <i class="bi bi-exclamation-octagon text-danger" style="font-size: 4.5rem;"></i>
                    <h3 class="fw-bold mt-2" style="color: #1a2c4e;">تأكيد الحذف</h3>
                </div>

                @if (hasRelatives)
                {
                    <div class="alert alert-danger border-0 mb-4 shadow-sm text-start" style="border-radius: 10px;">
                        <i class="bi bi-x-circle-fill fs-5 me-2"></i>
                        <strong>عفواً، لا يمكن حذف هذا الطالب.</strong>
                        <p class="mb-0 small opacity-90 mt-1">
                            النظام يمنع حذف الطالب لوجود بيانات أقارب مرتبطة به. يرجى حذف بيانات الأقارب أولاً لتتمكن من إزالة سجل الطالب.
                        </p>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning d-flex gap-2 align-items-center mb-4 border-0 shadow-sm text-start" style="border-radius: 10px;">
                        <i class="bi bi-exclamation-triangle-fill fs-4 text-warning"></i>
                        <div>
                            <strong class="text-dark">تنبيه هام!</strong><br />
                            <span class="text-dark small">هل أنت متأكد من أنك تريد حذف الطالب "<strong>@Model.FullName</strong>" نهائياً؟ هذا الإجراء لا يمكن التراجع عنه.</span>
                        </div>
                    </div>
                }

                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <div class="p-3 border rounded shadow-sm" style="background-color: #f8f9fa;">
                            <div class="small text-muted fw-bold mb-1">الرقم القومي</div>
                            <div class="fw-bold text-dark mt-1">@Model.NationalId</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 border rounded shadow-sm h-100" style="background-color: #f8f9fa;">
                            <div class="small text-muted fw-bold mb-1">السنة الدراسية</div>
                            <div class="fw-bold text-dark mt-1">
                                @{
                                    string arabicLevel = Model.AcademicYear switch
                                    {
                                        projectweb.Models.AcademicLevel.FirstYear => "المستوى الأول",
                                        projectweb.Models.AcademicLevel.SecondYear => "المستوى الثاني",
                                        projectweb.Models.AcademicLevel.ThirdYear => "المستوى الثالث",
                                        projectweb.Models.AcademicLevel.FourthYear => "المستوى الرابع",
                                        _ => Model.AcademicYear.ToString()
                                    };
                                }
                                @arabicLevel
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 border rounded shadow-sm h-100" style="background-color: #f8f9fa;">
                            <div class="small text-muted fw-bold mb-1">عدد الأقارب المسجلين</div>
                            <div class="fw-bold mt-1 @(hasRelatives ? "text-danger" : "text-success")">
                                <i class="bi bi-people-fill me-1"></i> @(Model.Relatives?.Count ?? 0)
                            </div>
                        </div>
                    </div>
                </div>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.StudentId" />

                    <div class="d-flex justify-content-center gap-2 mt-4 pt-3 border-top">
                        @if (hasRelatives)
                        {
                            <button type="button" class="btn btn-secondary px-5 fw-bold" style="border-radius: 8px;" disabled>
                                <i class="bi bi-lock-fill me-1"></i> الحذف غير متاح
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-danger px-5 fw-bold shadow-sm" style="border-radius: 8px;">
                                <i class="bi bi-trash me-1"></i> تأكيد الحذف
                            </button>
                        }

                        <a asp-action="Index" class="btn btn-outline-secondary px-4 shadow-sm" style="border-radius: 8px;">إلغاء وتراجع</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>