@model projectweb.ViewModel.StudentCommitteeViewModel

@{
    ViewData["Title"] = "لجنة الطالب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-lg-7">
        <div class="card academic-card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header text-white p-4 text-center" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%); border: none;">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-building-check me-2"></i> إشعار توزيع اللجنة</h4>
            </div>
            <div class="card-body p-4 bg-white">
                <div class="text-center mb-4">
                    <i class="bi bi-person-check-fill text-success" style="font-size: 4rem;"></i>
                    <h5 class="mt-2 fw-bold" style="color: #1a3a5a;">@Model.FullName</h5>
                    <p class="text-muted mb-0">
                        المستوى الدراسي:
                        @{
                            string arabicLevel = Model.AcademicYear switch
                            {
                                projectweb.Models.AcademicLevel.FirstYear => "المستوى الأول",
                                projectweb.Models.AcademicLevel.SecondYear => "المستوى الثاني",
                                projectweb.Models.AcademicLevel.ThirdYear => "المستوى الثالث",
                                projectweb.Models.AcademicLevel.FourthYear => "المستوى الرابع",
                                _ => Model.AcademicYear.ToString()
                            };
                        }
                        @arabicLevel
                    </p>
                </div>

                <div class="row g-3">
                    <div class="col-4">
                        <div class="p-3 border rounded text-center bg-light bg-opacity-50 shadow-sm">
                            <div class="small text-muted fw-bold mb-1">رقم اللجنة</div>
                            <div class="fw-bold fs-3 text-dark">@Model.CommitteeNumber</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-3 border rounded text-center bg-light bg-opacity-50 shadow-sm">
                            <div class="small text-muted fw-bold mb-1">رقم الجلوس</div>
                            <div class="fw-bold fs-3 text-primary">@Model.SeatNumber</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-3 border rounded text-center bg-light bg-opacity-50 shadow-sm">
                            <div class="small text-muted fw-bold mb-1">سعة اللجنة</div>
                            <div class="fw-bold fs-3 text-secondary">@Model.NumberOfStudent</div>
                        </div>
                    </div>
                </div>

                <div class="mt-5 pt-4 border-top text-center" style="border-color: #dee2e6 !important;">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold" style="border-radius: 8px;">العودة لقائمة الطلاب</a>
                </div>
            </div>
        </div>
    </div>
</div>