@model projectweb.Models.Student

@{
    ViewData["Title"] = "بطاقة الطالب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-lg-8">
        <div class="card academic-card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%); border: none;">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-person-vcard me-2"></i> البطاقة الأكاديمية للطالب</h4>
            </div>
            <div class="card-body p-4 bg-white">
                <div class="row g-4">
                    <div class="col-md-12">
                        <div class="p-3 border rounded bg-light bg-opacity-50">
                            <div class="small text-muted mb-1 fw-bold">الاسم الكامل</div>
                            <div class="fw-bold fs-5 text-dark">@Model.FullName</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="p-3 border rounded bg-light bg-opacity-50">
                            <div class="small text-muted mb-1 fw-bold">الرقم القومي</div>
                            <div class="fw-bold text-dark">@Model.NationalId</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="p-3 border rounded bg-light bg-opacity-50">
                            <div class="small text-muted mb-1 fw-bold">السنة الدراسية</div>
                            <div class="fw-bold text-primary">
                                @{
                                    string arabicLevel = Model.AcademicYear switch
                                    {
                                        projectweb.Models.AcademicLevel.FirstYear => "المستوى الأول",
                                        projectweb.Models.AcademicLevel.SecondYear => "المستوى الثاني",
                                        projectweb.Models.AcademicLevel.ThirdYear => "المستوى الثالث",
                                        projectweb.Models.AcademicLevel.FourthYear => "المستوى الرابع",
                                        _ => Model.AcademicYear.ToString()
                                    };
                                }
                                @arabicLevel
                            </div>
                        </div>
                    </div>

                 

                   
                    <div class="col-md-12">
                        <div class="p-3 border rounded bg-light bg-opacity-50">
                            <div class="small text-muted mb-1 fw-bold">اللجنة التابع لها طوال العام</div>
                            <div class="fw-bold text-success">
                                @if (Model.ExamLocation != null)
                                {
                                    <span><i class="bi bi-building-check me-1"></i> @Model.ExamLocation.LocationName</span>
                                }
                                else
                                {
                                    <span class="text-muted fw-normal">غير موزع على لجنة ثابتة حالياً</span>
                                }
                            </div>
                        </div>
                    </div>

                    @if (Model.Relatives != null && Model.Relatives.Any())
                    {
                        <div class="col-12 mt-3">
                            <div class="alert alert-danger border-0 shadow-sm d-flex align-items-start p-3" style="border-right: 5px solid #dc3545 !important;">
                                <i class="bi bi-exclamation-triangle-fill fs-4 me-3 text-danger"></i>
                                <div>
                                    <strong class="d-block mb-1 fs-5 text-danger">تحذير قانوني (صلات قرابة مسجلة):</strong>
                                    <p class="small mb-2 text-dark">يوجد صلات قرابة مثبتة برمجياً بين هذا الطالب وأعضاء لجان الامتحانات/الكنترول:</p>
                                    <ul class="mb-0 text-dark small fw-bold">
                                        @foreach (var rel in Model.Relatives)
                                        {
                                            <li>
                                                @(rel.Person != null ? rel.Person.FullName : "عضو غير معروف")
                                                @if (!string.IsNullOrEmpty(rel.RelationType))
                                                {
                                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 ms-2">@rel.RelationType</span>
                                                }
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="d-flex flex-wrap gap-2 mt-5 pt-4 border-top" style="border-color: #dee2e6 !important;">
                    <a asp-action="Edit" asp-route-id="@Model.StudentId" class="btn btn-academic-primary px-5 fw-bold text-white" style="background-color: #1a3a5a; border-radius: 8px;">
                        <i class="bi bi-pencil-square me-1"></i> تعديل البيانات
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.StudentId" class="btn btn-danger px-4" style="border-radius: 8px;">
                        <i class="bi bi-trash me-1"></i> حذف الطالب
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 ms-auto" style="border-radius: 8px;">العودة للقائمة الرئيسية</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-academic-primary:hover {
        background-color: #2e5a88 !important;
        transform: translateY(-1px);
    }
</style>