@model projectweb.Models.Committee

@{
    ViewData["Title"] = "تعديل لجنة";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-9">
        <div class="card academic-card">
            <div class="card-header academic-card-header text-white p-4">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-pencil-square me-2"></i> تعديل بيانات اللجنة رقم (@Model.CommitteeNumber)</h4>
            </div>
            <div class="card-body p-4 bg-white">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="CommitteeID" />
       
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3 border-0 shadow-sm"></div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="CommitteeNumber" class="form-label academic-label required">رقم اللجنة</label>
                            <input asp-for="CommitteeNumber" class="form-control academic-input" type="number" />
                            <span asp-validation-for="CommitteeNumber" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="NumberOfStudent" class="form-label academic-label required">سعة الطلاب (الاستيعاب)</label>
                            <input asp-for="NumberOfStudent" class="form-control academic-input" type="number" />
                            <span asp-validation-for="NumberOfStudent" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="BlockID" class="form-label academic-label required">موقع اللجنة (البلوك)</label>
                            <select asp-for="BlockID" asp-items="ViewBag.BlockID" class="form-select academic-input">
                                <option value="">-- اختر البلوك / القاعة --</option>
                            </select>
                            <span asp-validation-for="BlockID" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="StatusOfCommittee" class="form-label academic-label">حالة اللجنة</label>
                            <select asp-for="StatusOfCommittee" asp-items="ViewBag.StatusList" class="form-select academic-input">
                                <option value="">-- اختر الحالة --</option>
                            </select>
                            <span asp-validation-for="StatusOfCommittee" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>



                    <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top" style="border-color: var(--border-color) !important;">
                        <button type="submit" class="btn btn-academic-primary px-4 fw-bold">
                            <i class="bi bi-check2-circle me-1"></i> حفظ التعديلات
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">العودة للقائمة</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}