@model projectweb.Models.ViewModels.ExamControlSheetViewModel
@{
    Layout = null; int i = 1;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <style>
        body {
            font-family: 'Times New Roman', serif;
            padding: 15px;
            direction: rtl;
            background: white;
        }

        .outer-frame {
            border: 2px solid black;
            padding: 25px;
            min-height: 95vh;
        }

        .header-table {
            width: 100%;
            margin-bottom: 15px;
            border: none;
        }

            .header-table td {
                border: none !important;
                font-weight: bold;
                font-size: 14pt;
            }

        .main-title {
            text-align: center;
            text-decoration: underline;
            font-size: 18pt;
            font-weight: bold;
            margin: 15px 0;
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin: 20px 0;
            font-weight: bold;
            font-size: 13pt;
        }

        .line-draw {
            border-bottom: 1px dotted black;
            display: inline-block;
            min-width: 180px;
            padding: 0 5px;
        }

        .main-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

            .main-table th, .main-table td {
                border: 1px solid black;
                padding: 10px;
                text-align: center;
            }

            .main-table thead th {
                background-color: #f2f2f2;
            }

        .bottom-section {
            margin-top: 35px;
            font-weight: bold;
            line-height: 2.5;
            font-size: 12pt;
        }

        .footer-sigs {
            display: flex;
            justify-content: space-around;
            margin-top: 50px;
            text-align: center;
            font-weight: bold;
        }

        /* تنسيق رسالة التنبيه */
        .no-data-alert {
            text-align: center;
            padding: 40px;
            border: 2px dashed #999;
            margin: 20px 0;
            border-radius: 10px;
            color: #666;
        }

        @@media print {
          .no-print

        {
            display: none !important;
        }

        .outer-frame {
            border: 2px solid black;
        }

        }
    </style>
</head>
<body>
    <div class="no-print" style="text-align:center; margin-bottom:10px;">
        @if (Model.SubjectName != "................")
        {
            <button onclick="window.print()" style="padding:10px 20px; background:green; color:white; border:none; border-radius:5px; cursor:pointer;">🖨️ طباعة الكشف</button>
        }
        <button onclick="window.history.back()" style="padding:10px 20px; background:#666; color:white; border:none; border-radius:5px; cursor:pointer; margin-right:10px;">العودة للخلف</button>
    </div>

    <div class="outer-frame">
        <table class="header-table">
            <tr>
                <td style="text-align: right;">جامعة أسيوط<br>كلية علوم الرياضة<br>شئون الطلاب</td>
                <td style="text-align: left;">AU-EX-02</td>
            </tr>
        </table>

        @* الفحص: إذا لم تكن هناك بيانات امتحان (المادة منقطة) *@
        @if (Model.SubjectName == "................")
        {
            <div class="main-title">استمارة تحضير ملاحظين</div>
            <div class="no-data-alert">
                <i style="font-size: 40px; display: block; margin-bottom: 10px;">⚠️</i>
                <h3>لا توجد تكليفات أو جداول امتحانات مسجلة لهذه اللجنة حالياً</h3>
                <p>يمكنك العودة وتوزيع الملاحظين أولاً لتتمكن من طباعة الكشف كاملاً.</p>
            </div>
        }
        else
        {
            <div class="main-title">امتحانات @Model.Semester للعام الجامعي @Model.AcademicYear</div>

            <div class="info-grid">
                <div>اليوم: <span class="line-draw">@Model.ExamDay</span></div>
                <div>رئيس اللجان: <span class="line-draw">@Model.MainHead</span></div>
                <div>التاريخ: <span class="line-draw">@Model.ExamDate</span></div>
                <div>مراقب اللجان: <span class="line-draw">@Model.MainObserver</span></div>
                <div>الفرقة: <span class="line-draw">@Model.TargetYear</span></div>
                <div>المادة: <span class="line-draw">@Model.SubjectName</span></div>
                <div>الزمن: <span class="line-draw">@Model.ExamTime</span></div>
            </div>

            <table class="main-table">
                <thead>
                    <tr><th style="width:40px;">م</th><th>اسم الملاحظ</th><th style="width:100px;">عدد الكراسات</th><th>التوقيع</th><th>ملاحظات</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ObserverRows)
                    {
                        <tr><td>@(i++)</td><td style="text-align:right;">@item.ObserverName</td><td></td><td></td><td></td></tr>
                    }
                    @for (int j = i; j <= 15; j++)
                    {
                        <tr style="height:35px;"><td>@j</td><td></td><td></td><td></td><td></td></tr>
                    }
                </tbody>
            </table>
        }

        <div class="bottom-section">
            <div>احتياطي رئيس اللجان: <span class="line-draw" style="min-width:350px;">@Model.ReserveHead</span></div>
            <div>احتياطي مراقب اللجان: <span class="line-draw" style="min-width:350px;">@Model.ReserveObserver</span></div>
            <div>طبيب اللجان: <span class="line-draw" style="min-width:400px;">@Model.DoctorName</span></div>
        </div>

        <div class="footer-sigs">
            <div>شئون طلاب</div>
            <div>مراقب اللجنة<br>( @Model.MainObserver )</div>
            <div>رئيس اللجنة<br>( @Model.MainHead )</div>
        </div>
    </div>
</body>
</html>