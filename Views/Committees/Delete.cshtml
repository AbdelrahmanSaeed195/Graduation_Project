@model projectweb.Models.Committee

@{
    ViewData["Title"] = "تأكيد حذف لجنة";
    Layout = "~/Views/Shared/_Layout.cshtml";

    bool hasDependencies = (Model.Students != null && Model.Students.Any()) ||
                           (Model.CommitteesAssignments != null && Model.CommitteesAssignments.Any()) ||
                           (Model.ExamSchedules != null && Model.ExamSchedules.Any());
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-lg-6">
        <div class="card academic-card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
            <div class="card-body p-4 bg-white text-center">               
                <div class="mb-3">
                    <i class="bi bi-exclamation-octagon text-danger" style="font-size: 4.5rem;"></i>
                    <h3 class="fw-bold mt-2" style="color: #1a2c4e;">تأكيد الحذف</h3>
                </div>

                @if (hasDependencies)
                {
                    <div class="alert alert-danger border-0 mb-4 shadow-sm text-start" style="border-radius: 10px;">
                        <i class="bi bi-x-circle-fill fs-5 me-2"></i>
                        <strong>عفواً، لا يمكن حذف هذه اللجنة.</strong>
                        <p class="mb-0 small opacity-90 mt-1">
                            النظام يمنع حذف أي لجنة تحتوي على طلاب، جداول امتحانات، أو مراقبين. يرجى إزالة هذه الارتباطات أولاً.
                        </p>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning d-flex gap-2 align-items-center mb-4 border-0 shadow-sm text-start" style="border-radius: 10px; background-color: #fff8e1;">
                        <i class="bi bi-exclamation-triangle-fill fs-4 text-warning"></i>
                        <div>
                            <strong class="text-dark">تنبيه هام!</strong><br />
                            <span class="text-dark small">أنت على وشك حذف اللجنة رقم (<strong>@Model.CommitteeNumber</strong>) نهائياً من النظام. هل أنت متأكد؟</span>
                        </div>
                    </div>
                }

              
                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <div class="p-3 border rounded shadow-sm h-100" style="background-color: #f8f9fa;">
                            <div class="small text-muted fw-bold mb-1">الموقع / القاعة</div>
                            <div class="fw-bold text-dark mt-1">
                               
                                @(Model.Block != null ? $"قاعة {Model.Block.Hall?.HallName ?? Model.Block.HallId.ToString()} / بلوك {Model.Block.BlockName}" : "غير محدد")
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 border rounded shadow-sm h-100" style="background-color: #f8f9fa;">
                            <div class="small text-muted fw-bold mb-1">حالة اللجنة</div>
                            <div class="fw-bold text-dark mt-1">@Model.StatusOfCommittee</div>
                        </div>
                    </div>
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="CommitteeID" />
                    <div class="d-flex justify-content-center gap-2 mt-4 pt-3 border-top">

                        @if (hasDependencies)
                        {
                            <button type="button" class="btn btn-secondary px-4 py-2 fw-bold" style="border-radius: 8px;" disabled>
                                <i class="bi bi-lock-fill me-1"></i> الحذف غير متاح
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-danger px-4 py-2 fw-bold shadow-sm" style="border-radius: 8px; background-color: #dc3545;">
                                <i class="bi bi-trash me-1"></i> تأكيد عملية الحذف
                            </button>
                        }

                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px;">إلغاء وتراجع</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}