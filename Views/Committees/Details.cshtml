@model projectweb.Models.Committee

@{
    ViewData["Title"] = "تفاصيل اللجنة";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-lg-10">
        <div class="card academic-card mb-4">
            <div class="card-header academic-card-header text-white p-4 d-flex justify-content-between align-items-center">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-info-circle-fill me-2"></i> تفاصيل اللجنة رقم (@Model.CommitteeNumber)</h4>
                @if (Model.StatusOfCommittee == "نشطة")
                {
                    <span class="badge bg-success fs-6">نشطة</span>
                }
                else if (Model.StatusOfCommittee == "مغلقة")
                {
                    <span class="badge bg-danger fs-6">مغلقة</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark fs-6">@Model.StatusOfCommittee</span>
                }
            </div>

            <div class="card-body p-4 bg-white">
                <h5 class="fw-bold academic-heading border-bottom pb-2 mb-3" style="border-color: var(--border-color) !important;">المعلومات الأساسية</h5>
                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="data-panel h-100">
                            <div class="panel-label">الموقع (القاعة / البلوك)</div>
                            <div class="panel-value mt-1">
                                @(Model.Block != null ? $"قاعة {Model.Block.HallId} / بلوك {Model.Block.BlockID}" : "غير محدد")
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="data-panel h-100">
                            <div class="panel-label">السعة الطلابية</div>
                            <div class="panel-value mt-1" style="color: var(--accent-blue);">@Model.NumberOfStudent طالب</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="data-panel h-100">
                            <div class="panel-label">عدد الطلاب الموزعين فعلياً</div>
                            <div class="panel-value mt-1 text-success">@(Model.Students?.Count ?? 0) طالب</div>
                        </div>
                    </div>
                </div>



                <div class="row g-4 mt-2">
                    <div class="col-md-6">
                        <div class="alert border shadow-sm h-100 mb-0" style="background-color: var(--surface-white); border-color: var(--border-color) !important;">
                            <h6 class="fw-bold academic-heading mb-3"><i class="bi bi-calendar-check me-2"></i> جداول الامتحانات المرتبطة</h6>
                            @if (Model.ExamSchedules != null && Model.ExamSchedules.Any())
                            {
                                <span class="badge bg-primary px-3 py-2">يوجد @Model.ExamSchedules.Count امتحان مجدول</span>
                            }
                            else
                            {
                                <span class="text-muted small">لا يوجد امتحانات مجدولة بعد.</span>
                            }
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="alert border shadow-sm h-100 mb-0" style="background-color: var(--bg-light); border-color: var(--border-color) !important;">
                            <h6 class="fw-bold academic-heading mb-3"><i class="bi bi-person-lines-fill me-2"></i> الطاقم الرقابي المعين</h6>
                            @if (Model.CommitteesAssignments != null && Model.CommitteesAssignments.Any())
                            {
                                <ul class="list-unstyled mb-0">
                                    @foreach (var assignment in Model.CommitteesAssignments)
                                    {
                                        if (assignment.Person != null)
                                        {
                                            <li class="mb-1" style="color: var(--text-main);"><i class="bi bi-person-badge text-muted me-1"></i> @assignment.Person.FullName</li>
                                        }
                                    }
                                </ul>
                            }
                            else
                            {
                                <span class="text-muted small">لم يتم تعيين طاقم رقابي حتى الآن.</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top" style="border-color: var(--border-color) !important;">
                    <a asp-action="Edit" asp-route-id="@Model.CommitteeID" class="btn btn-academic-primary px-4 fw-bold">
                        <i class="bi bi-pencil-square me-1"></i> تعديل البيانات
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">العودة للقائمة</a>
                </div>
            </div>
        </div>
    </div>
</div>