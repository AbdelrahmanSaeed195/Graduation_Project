@model projectweb.Models.Committee

@{
    ViewData["Title"] = "تفاصيل اللجنة";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-10">
        <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
            
            <div class="card-header p-4 d-flex justify-content-between align-items-center" style="background-color: #1a3a5a;">
                <h4 class="mb-0 fw-bold text-white">
                    <i class="bi bi-person-workspace ms-2"></i> تفاصيل وعقد لجنة رقم: (@Model.CommitteeNumber)
                </h4>
                <div>
                    @if (string.IsNullOrEmpty(Model.StatusOfCommittee) || Model.StatusOfCommittee == "نشطة" || Model.StatusOfCommittee == "مكتمل")
                    {
                        <span class="badge bg-success fs-6 shadow-sm px-3 py-2" style="border-radius: 6px;">نشطة</span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6 shadow-sm px-3 py-2" style="border-radius: 6px;">@Model.StatusOfCommittee</span>
                    }
                </div>
            </div>

            <div class="card-body p-4 bg-light">
                
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="p-3 bg-white rounded shadow-sm border-start border-primary border-4 h-100 data-panel">
                            <div class="text-muted small fw-bold mb-1">الموقع التبعي الهرمي</div>
                            <div class="fw-bold text-dark mt-1" style="font-size: 1.05rem;">
                                <i class="bi bi-geo-alt-fill text-danger ms-1"></i>
                                @(Model.Block != null ? $"جراش {Model.Block.Hall?.HallName} ⬅️ صالة {Model.Block.BlockName}" : "غير محدد")
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 bg-white rounded shadow-sm border-start border-info border-4 h-100 data-panel">
                            <div class="text-muted small fw-bold mb-1">السعة الاستيعابية المخططة</div>
                            <div class="fw-bold text-info mt-1 fs-5">
                                <i class="bi bi-calculator ms-1"></i> @Model.NumberOfStudent مقعد طالب
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 bg-white rounded shadow-sm border-start border-success border-4 h-100 data-panel">
                            <div class="text-muted small fw-bold mb-1">الطلاب المسجلين فعلياً باللجنة</div>
                            <div class="fw-bold text-success mt-1 fs-5">
                                <i class="bi bi-person-check-fill ms-1"></i> @(Model.Students?.Count ?? 0) طالب حالي
                            </div>
                        </div>
                    </div>
                </div>

                <h5 class="fw-bold pb-2 mb-3 border-bottom text-secondary" style="font-size: 1.1rem;">
                    <i class="bi bi-calendar-event-fill ms-2 text-primary"></i> الفترات والجدول الزمني للامتحانات داخل اللجنة
                </h5>

                @if (Model.ExamSchedules != null && Model.ExamSchedules.Any())
                {
                    <div class="table-responsive rounded border bg-white shadow-sm">
                        <table class="table table-hover align-middle mb-0 text-center">
                            <thead class="table-light text-secondary small text-uppercase">
                                <tr>
                                    <th class="py-3">المادة الدراسية</th>
                                    <th>السنة الدراسية</th>
                                    <th>تاريخ الامتحان</th>
                                    <th>الفترة الزمنية</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var schedule in Model.ExamSchedules.OrderBy(s => s.Exam?.ExamDate))
                                {
                                    <tr>
                                        <td class="fw-bold text-dark">@schedule.Exam?.Subject?.SubjectName</td>
                                        <td>
                                            @if (schedule.Exam?.Subject != null)
                                            {
                                                var enumType = typeof(projectweb.Models.AcademicLevel);
                                                var memberInfo = enumType.GetMember(schedule.Exam.Subject.AcademicYear.ToString());
                                                var attribute = memberInfo.FirstOrDefault()?.GetCustomAttributes(typeof(System.ComponentModel.DataAnnotations.DisplayAttribute), false).FirstOrDefault() as System.ComponentModel.DataAnnotations.DisplayAttribute;
                                                
                                                <span class="badge bg-light text-primary border px-2 py-1">
                                                    @(attribute != null ? attribute.Name : schedule.Exam.Subject.AcademicYear.ToString())
                                                </span>
                                            }
                                        </td>
                                        <td class="text-muted">
                                            <i class="bi bi-calendar3 ms-1 text-secondary"></i>
                                            @(schedule.Exam?.ExamDate.ToString("yyyy/MM/dd") ?? "غير محدد")
                                        </td>
                                        <td class="fw-bold text-danger">
                                            <i class="bi bi-clock ms-1"></i>
                                            @if (schedule.Exam != null)
                                            {
                                                var start = DateTime.Today.Add(schedule.Exam.StartTime).ToString("hh:mm tt");
                                                var end = DateTime.Today.Add(schedule.Exam.EndTime).ToString("hh:mm tt");
                                                @start @:- @end
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-white border text-center text-muted p-5 mb-0" style="border-radius: 10px; background-color: #fff;">
                        <i class="bi bi-calendar-x fs-1 d-block mb-2 text-warning"></i>
                        لا توجد فترات امتحانية أو مواد مجدولة داخل هذه اللجنة حالياً.
                    </div>
                }
            </div>

            <div class="card-footer bg-white p-3 d-flex justify-content-start gap-2 border-top">
                <a asp-action="Edit" asp-route-id="@Model.CommitteeId" class="btn text-white px-4 fw-bold shadow-sm" style="background-color: #1a3a5a; border-radius: 8px;">
                    <i class="bi bi-pencil-square ms-1"></i> تعديل بيانات اللجنة
                </a>

                <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold shadow-sm" style="border-radius: 8px;">
                    <i class="bi bi-arrow-right-circle ms-1"></i> العودة للقائمة الرئيسية
                </a>
            </div>

        </div>
    </div>
</div>

<style>
    .data-panel {
        transition: transform 0.2s;
    }
    .data-panel:hover {
        transform: translateY(-3px);
    }
    .table thead th {
        font-weight: 600;
        border-top: none;
    }
</style>