@model IEnumerable<projectweb.Models.Subject>

<div class="container mt-4" dir="rtl" style="text-align: right;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #1a237e; font-weight: bold;">
            <i class="fas fa-book ml-2"></i> إدارة المواد الدراسية
        </h2>
        <a asp-action="Create" class="btn" style="background-color: #0d1b3e; color: white; border-radius: 8px; padding: 10px 20px;">
            <i class="fas fa-plus-circle"></i> إضافة مادة جديدة
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm" style="border-radius: 12px; overflow: hidden;">
        <table class="table mb-0 text-center">
            <thead style="background-color: #f8f9fa; border-bottom: 2px solid #dee2e6;">
                <tr>
                    <th class="py-3">@Html.DisplayNameFor(model => model.SubjectId)</th>
                    <th class="py-3">@Html.DisplayNameFor(model => model.SubjectName)</th>
                    <th class="py-3">الامتحانات</th>
                    <th class="py-3">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="py-5 text-muted">لا توجد مواد مسجلة في النظام حالياً.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle">@item.SubjectId</td>
                        <td class="align-middle" style="font-weight: 500;">@item.SubjectName</td>
                        <td class="align-middle">
                            <span class="badge badge-pill badge-info">@(item.Exams?.Count ?? 0) امتحان</span>
                        </td>
                        <td class="align-middle">
                            <a asp-action="Edit" asp-route-id="@item.SubjectId" class="btn btn-sm btn-outline-warning mx-1" title="تعديل">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.SubjectId" class="btn btn-sm btn-outline-info mx-1" title="تفاصيل">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.SubjectId" class="btn btn-sm btn-outline-danger mx-1" title="حذف">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>