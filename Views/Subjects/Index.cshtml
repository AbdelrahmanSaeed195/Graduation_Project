@model IEnumerable<projectweb.Models.Subject>

<div class="container mt-4" dir="rtl" style="text-align: right;">
    <!-- الهيدر: نفس ستايل إدارة الصالات -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #0d1b3e; font-weight: bold;">
            <i class="fas fa-book-open ml-2"></i> إدارة المواد الدراسية
        </h2>
        <a asp-action="Create" class="btn shadow-sm" style="background-color: #0d1b3e; color: white; border-radius: 8px; padding: 10px 20px; font-weight: 500;">
            <i class="fas fa-plus-circle ml-1"></i> إضافة مادة جديدة
        </a>
    </div>

    <!-- التنبيهات -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert" style="border-radius: 10px;">
            <i class="fas fa-check-circle ml-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <!-- الجدول داخل كارت أبيض نظيف -->
    <div class="card shadow-sm border-0" style="border-radius: 15px; overflow: hidden; background-color: white;">
        <table class="table mb-0 text-center table-hover">
            <thead style="background-color: #fcfcfc; border-bottom: 2px solid #f0f0f0;">
                <tr>
                    <th class="py-3 text-muted" style="width: 20%; font-weight: 600;">كود المادة</th>
                    <th class="py-3 text-muted" style="width: 40%; font-weight: 600;">اسم المادة</th>
                    <th class="py-3 text-muted" style="width: 20%; font-weight: 600;">السنة الدراسية</th>
                    <th class="py-3 text-muted" style="width: 20%; font-weight: 600;">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="py-5 text-muted">لا توجد مواد مسجلة في النظام حالياً.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr style="transition: all 0.3s;">
                        <td class="align-middle" style="font-weight: bold; color: #0d1b3e;">
                            @item.SubjectCode
                        </td>
                        <td class="align-middle" style="color: #333; font-weight: 500;">
                            @item.SubjectName
                        </td>
                        <td class="align-middle">
                            <span class="badge px-3 py-2" style="background-color: #f0f2f5; color: #0d1b3e; border-radius: 8px; font-size: 0.85rem; border: 1px solid #e0e0e0;">
                                @item.AcademicYear
                            </span>
                        </td>
                        <td class="align-middle">
                            <!-- أيقونات ملونة مباشرة بدون Outline لتطابق صورة الصالات -->
                            <div class="d-flex justify-content-center">
                                <a asp-action="Edit" asp-route-id="@item.SubjectId" class="mx-2" title="تعديل" style="color: #ffc107;">
                                    <i class="fas fa-edit fa-lg"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.SubjectId" class="mx-2" title="تفاصيل" style="color: #17a2b8;">
                                    <i class="fas fa-eye fa-lg"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.SubjectId" class="mx-2" title="حذف" style="color: #dc3545;">
                                    <i class="fas fa-trash-alt fa-lg"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>