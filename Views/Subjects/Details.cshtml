@model projectweb.Models.Subject
@using System.ComponentModel.DataAnnotations
@using System.Reflection

@{
    ViewData["Title"] = "تفاصيل المادة الدراسية";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var enumType = Model.AcademicYear.GetType();
    var memberInfo = enumType.GetMember(Model.AcademicYear.ToString());
    var displayAttribute = memberInfo.Length > 0 ? memberInfo[0].GetCustomAttribute<DisplayAttribute>() : null;
    string arabicLevelName = displayAttribute != null ? displayAttribute.Name : Model.AcademicYear.ToString();
}

<div class="container mt-5" dir="rtl" style="text-align: right;">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-header text-white d-flex align-items-center" style="background-color: #0d1b3e; border-radius: 12px 12px 0 0; padding: 15px 20px;">
                    <h4 class="mb-0 font-weight-bold"><i class="fas fa-info-circle ml-2"></i> تفاصيل المادة الدراسية</h4>
                </div>

                <div class="card-body p-4">
                    <div class="row mb-0">
                        <div class="col-12 mb-3">
                            <div class="p-3" style="background-color: #f8f9fa; border-right: 5px solid #0d1b3e; border-radius: 8px;">
                                <span class="text-muted d-block small mb-1">كود المادة الدراسي:</span>
                                <h5 class="mb-0 font-weight-bold" style="color: #0d1b3e;">@Model.SubjectCode</h5>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <span class="text-muted d-block small mb-1">اسم المادة:</span>
                            <p class="font-weight-500 text-dark border-bottom pb-2">@Model.SubjectName</p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <span class="text-muted d-block small mb-1">السنة الدراسية:</span>
                            <p class="pb-2 border-bottom">
                                <span class="badge px-3 py-2 fw-bold" style="background-color: #e3f2fd; color: #0d1b3e; border: 1px solid #bbdefb; border-radius: 6px; font-size: 0.95rem; display: inline-block;">
                                    <i class="fas fa-graduation-cap ml-1 text-primary"></i> @arabicLevelName
                                </span>
                            </p>
                        </div>
                    </div>

                    @if (Model.Exams != null && Model.Exams.Any())
                    {
                        <div class="mt-4 pt-3">
                            <h6 class="font-weight-bold mb-3" style="color: #0d1b3e;">
                                <i class="fas fa-calendar-alt ml-1"></i> الجداول الزمنية المرتبطة بالمادة:
                            </h6>
                            <div class="list-group">
                                @foreach (var exam in Model.Exams)
                                {
                                    <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center mb-2 border shadow-xs" style="border-radius: 8px;">
                                        <div>
                                            <span class="d-block font-weight-bold">امتحان @Model.SubjectName</span>
                                            <small class="text-muted fw-bold">المرحلة: @arabicLevelName</small>
                                        </div>
                                        <div class="text-left">
                                            <span class="badge badge-pill border px-3 py-2 fw-bold" style="background-color: #f8f9fa; color: #333; border-radius: 6px; font-size: 0.85rem;">
                                                <i class="far fa-calendar-check ml-1 text-info"></i> @exam.ExamDate.ToString("yyyy/MM/dd")
                                            </span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="card-footer bg-white d-flex justify-content-start py-3" style="border-radius: 0 0 12px 12px; border-top: 1px solid #f0f0f0;">
                    <a asp-action="Edit" asp-route-id="@Model.SubjectId" class="btn btn-warning px-4 ml-3 shadow-sm font-weight-500">
                        <i class="fas fa-edit ml-1"></i> تعديل البيانات
                    </a>
                    <a asp-action="Index" class="btn btn-light px-4 shadow-sm border font-weight-500">
                        <i class="fas fa-arrow-right ml-1"></i> العودة للقائمة
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>