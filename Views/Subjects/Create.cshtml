@model projectweb.Models.Subject

<div class="container mt-5" dir="rtl" style="text-align: right;">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <!-- الكارت الأساسي بحدود دائرية وظل خفيف -->
            <div class="card shadow-sm border-0" style="border-radius: 12px;">

                <!-- رأس الكارت بالكحلي الموحد #0d1b3e -->
                <div class="card-header text-white" style="background-color: #0d1b3e; border-radius: 12px 12px 0 0; padding: 15px 20px;">
                    <h4 class="mb-0 font-weight-bold"><i class="fas fa-plus-circle ml-2"></i> إضافة مادة دراسية جديدة</h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <!-- كود المادة -->
                        <div class="form-group mb-4">
                            <label asp-for="SubjectCode" class="text-muted font-weight-bold mb-2"></label>
                            <input asp-for="SubjectCode" class="form-control" placeholder="مثلاً: CS202"
                                   style="background-color: #f8f9fa; border: 1px solid #ddd; border-radius: 8px; padding: 10px;" />
                            <span asp-validation-for="SubjectCode" class="text-danger small"></span>
                        </div>

                        <!-- اسم المادة -->
                        <div class="form-group mb-4">
                            <label asp-for="SubjectName" class="text-muted font-weight-bold mb-2"></label>
                            <input asp-for="SubjectName" class="form-control" placeholder="أدخل اسم المادة..."
                                   style="background-color: #f8f9fa; border: 1px solid #ddd; border-radius: 8px; padding: 10px;" />
                            <span asp-validation-for="SubjectName" class="text-danger small"></span>
                        </div>

                        <!-- السنة الدراسية -->
                        <div class="form-group mb-4">
                            <label asp-for="AcademicYear" class="text-muted font-weight-bold mb-2"></label>
                            <select asp-for="AcademicYear" class="form-control"
                                    style="background-color: #f8f9fa; border: 1px solid #ddd; border-radius: 8px; height: auto; padding: 10px;">
                                <option value="">-- اختر السنة الدراسية --</option>
                                <option value="الأولى">الفرقة الأولى</option>
                                <option value="الثانية">الفرقة الثانية</option>
                                <option value="الثالثة">الفرقة الثالثة</option>
                                <option value="الرابعة">الفرقة الرابعة</option>
                            </select>
                            <span asp-validation-for="AcademicYear" class="text-danger small"></span>
                        </div>

                        <hr class="my-4" style="border-top: 1px solid #eee;" />

                        <!-- الأزرار بالتنسيق الموحد -->
                        <div class="form-group mb-0 d-flex justify-content-start">
                            <button type="submit" class="btn text-white px-5 ml-3 shadow-sm"
                                    style="background-color: #0d1b3e; border-radius: 8px; font-weight: 500;">
                                <i class="fas fa-save ml-1"></i> حفظ المادة
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4 shadow-sm border"
                               style="border-radius: 8px; font-weight: 500;">
                                رجوع
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>