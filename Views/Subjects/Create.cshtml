@model projectweb.Models.Subject

<div class="container mt-5" dir="rtl" style="text-align: right;">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header text-white" style="background-color: #0d1b3e;">
                    <h4 class="mb-0">إضافة مادة دراسية جديدة</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @* تأكد من وجود method="post" *@

                        @* غيرنا دي لـ All عشان تظهر أي خطأ يمنع الحفظ *@
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="form-group">
                            <label asp-for="SubjectName" class="control-label font-weight-bold"></label>
                            <input asp-for="SubjectName" class="form-control" placeholder="أدخل اسم المادة..." />
                            <span asp-validation-for="SubjectName" class="text-danger"></span>
                        </div>
                        <hr />
                        <div class="form-group mb-0">
                            <button type="submit" class="btn btn-primary px-4">حفظ المادة</button>
                            <a asp-action="Index" class="btn btn-secondary px-4">رجوع</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>