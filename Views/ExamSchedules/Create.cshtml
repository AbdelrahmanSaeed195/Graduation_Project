@model projectweb.Models.ExamSchedule

@{
    ViewData["Title"] = "إضافة جلسة توزيع الصالات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl">
    <div class="row justify-content-center mt-4">
        <div class="col-md-8">
            <div class="card academic-card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
                <div class="card-header py-3" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%); border-bottom: none;">
                    <h4 class="card-title mb-0 fw-bold text-white text-center">
                        <i class="bi bi-calendar-plus me-2"></i> تخصيص مبنى / صالة لامتحان
                    </h4>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4 rounded-3 d-none"></div>

                        <div class="row g-4">
                            <div class="col-md-12 mb-3">
                                <label asp-for="ExamId" class="form-label fw-bold" style="color: #4a5568;">الامتحان / المادة المحددة <span class="text-danger">*</span></label>
                                <select asp-for="ExamId" id="ExamSelect" class="form-select form-select-lg shadow-sm border-light-subtle" asp-items="ViewBag.ExamId" style="font-size: 0.95rem; border-radius: 8px;">
                                    <option value="">-- اختر الامتحان (المادة - التاريخ) --</option>
                                </select>
                                <span asp-validation-for="ExamId" class="text-danger small mt-1 d-block fw-bold"></span>
                                <div class="form-text mt-2"><i class="bi bi-info-circle me-1"></i> يتم سحب التوقيت وفحص الإشغال تلقائياً بناءً على اختيار الامتحان.</div>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label asp-for="LocationId" class="form-label fw-bold" style="color: #4a5568;">الصالات / المباني المتاحة <span class="text-danger">*</span></label>
                                <select asp-for="LocationId" id="LocationSelect" class="form-select form-select-lg shadow-sm border-light-subtle" style="font-size: 0.95rem; border-radius: 8px;">
                                    <option value="">-- اختر الامتحان أولاً لعرض الصالات المتاحة --</option>
                                </select>
                                <span asp-validation-for="LocationId" class="text-danger small mt-1 d-block fw-bold"></span>
                            </div>
                        </div>

                        <div class="border-top mt-5 pt-4">
                            <div class="d-flex justify-content-center gap-3">
                                <button type="submit" class="btn btn-lg px-5 py-2 shadow-sm text-white" style="background-color: #1a3a5a; border-radius: 8px; font-size: 1rem; font-weight: 600;">
                                    <i class="bi bi-check-circle me-2"></i> حفظ التوزيع
                                </button>
                                <a asp-action="Index" class="btn btn-lg btn-outline-secondary px-5 py-2" style="border-radius: 8px; font-size: 1rem;">
                                    إلغاء
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            $('#ExamSelect').change(function () {
                var examId = $(this).val();
                var locationSelect = $('#LocationSelect');

                locationSelect.empty();

                if (examId) {
                    locationSelect.append('<option value="">-- جاري تحميل الصالات المتاحة... --</option>');

                    $.ajax({
                        url: '@Url.Action("GetAvailableLocations", "ExamSchedules")',
                        type: 'GET',
                        dataType: 'json',
                        data: { examId: examId },
                        success: function (data) {
                            locationSelect.empty();
                            if (data && data.length > 0) {
                                locationSelect.append('<option value="">-- اختر الصالة / المبنى المختص --</option>');
                                $.each(data, function (i, item) {
                                    locationSelect.append($('<option>', {
                                        value: item.id,
                                        text: item.name
                                    }));
                                });
                            } else {
                                locationSelect.append('<option value="">-- لا توجد صالات متاحة في هذا الوقت --</option>');
                            }
                        },
                        error: function (xhr, status, error) {
                            console.error("AJAX Error: ", error);
                            locationSelect.empty();
                            locationSelect.append('<option value="">-- خطأ في تحميل البيانات --</option>');
                        }
                    });
                } else {
                    locationSelect.append('<option value="">-- اختر الامتحان أولاً لعرض الصالات المتاحة --</option>');
                }
            });
        });
    </script>
}