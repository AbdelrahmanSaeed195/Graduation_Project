@model projectweb.Models.ExamSchedule
@using System.ComponentModel.DataAnnotations
@using System.Reflection

@{
    ViewData["Title"] = "تفاصيل جلسة توزيع الجراشات";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string arabicLevelName = "غير محدد";
    if (Model.Exam?.Subject != null)
    {
        var enumType = Model.Exam.Subject.AcademicYear.GetType();
        var memberInfo = enumType.GetMember(Model.Exam.Subject.AcademicYear.ToString());
        var displayAttribute = memberInfo.Length > 0 ? memberInfo[0].GetCustomAttribute<DisplayAttribute>() : null;

        arabicLevelName = displayAttribute != null ? displayAttribute.Name : Model.Exam.Subject.AcademicYear.ToString();
    }
}

<div class="content-body" dir="rtl" style="text-align: right;">
    <div class="row justify-content-center mt-4">
        <div class="col-md-10">
            <div class="card academic-card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">

                <div class="card-header py-3" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%); border-bottom: none;">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <h4 class="card-title mb-0 fw-bold text-white">
                            <i class="bi bi-info-circle me-2"></i> بيانات تخصيص الجراش: @(Model.Exam?.Subject?.SubjectName ?? "غير محدد")
                        </h4>
                        <span class="badge bg-white text-dark fw-bold px-3 py-2" style="border-radius: 6px;">كود الجلسة #@Model.ExamScheduleId</span>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <div class="row g-4">

                        <div class="col-md-7">
                            <label class="form-label fw-bold small text-muted mb-1">اسم المادة الدراسية</label>
                            <div class="p-3 border rounded-3 bg-light-subtle fw-bold fs-5 shadow-sm" style="color: #1a3a5a; background-color: #f8f9fa;">
                                <i class="bi bi-book-half me-2 text-primary"></i>
                                @(Model.Exam?.Subject?.SubjectName ?? "غير محدد")
                            </div>
                        </div>

                        <div class="col-md-5">
                            <label class="form-label fw-bold small text-muted mb-1 text-center d-block">السنة الدراسية المستهدفة</label>
                            <div class="p-3 border rounded-3 bg-light-subtle fw-bold fs-5 text-center shadow-sm" style="color: #1a3a5a; background-color: #f8f9fa;">
                                <i class="bi bi-graduation-cap me-2 text-secondary"></i>
                                @arabicLevelName
                            </div>
                        </div>

                        <div class="col-12 mt-4">
                            <label class="form-label fw-bold small text-muted mb-1">المبنى والجراش الامتحاني المعين</label>
                            <div class="p-3 border rounded-3 bg-light-subtle shadow-sm d-flex justify-content-between align-items-center" style="background-color: #f8f9fa;">
                                <span class="fw-bold text-primary fs-5" style="color: #1a3a5a !important;">
                                    <i class="bi bi-building me-2 text-primary"></i> @(Model.ExamLocation?.LocationName ?? "غير محدد")
                                </span>
                                <span class="text-muted small fw-bold">
                                    <i class="bi bi-geo-alt text-danger me-1"></i> كافة القطاعات، الصفوف، والصالات تابعة لهذا الجراش الموحد.
                                </span>
                            </div>
                        </div>

                    </div>

                    <h5 class="fw-bold pb-2 mb-3 mt-5 border-bottom text-secondary" style="font-size: 1.1rem;">
                        <i class="bi bi-calendar-event-fill ms-2 text-primary"></i> الجدولة الامتحانية الزمنية
                    </h5>

                    <div class="table-responsive rounded border bg-white shadow-sm mb-4">
                        <table class="table table-hover align-middle mb-0 text-center">
                            <thead class="table-light">
                                <tr>
                                    <th>تاريخ الامتحان</th>
                                    <th>الفترة الزمنية</th>
                                    <th>حالة الدور</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="fw-bold text-dark">@(Model.Exam?.ExamDate.ToString("yyyy/MM/dd") ?? "—")</td>
                                    <td class="fw-bold text-danger">
                                        @if (Model.Exam != null)
                                        {
                                            var startTime = DateTime.Today.Add(Model.Exam.StartTime).ToString("hh:mm tt");
                                            var endTime = DateTime.Today.Add(Model.Exam.EndTime).ToString("hh:mm tt");
                                            @($"{startTime} - {endTime}")
                                        }
                                        else
                                        {
                                            <span>غير محدد</span>
                                        }
                                    </td>
                                    <td>
                                        @if (Model.ExamLocation?.Floor == 2)
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-1">مقر ذو دورين</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary text-white px-3 py-1">مقر ذو دور واحد</span>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-5 d-flex justify-content-center gap-3 border-top pt-4">
                        <a asp-action="Edit" asp-route-id="@Model.ExamScheduleId" class="btn btn-lg px-5 text-white shadow-sm" style="background-color: #1a3a5a; border-radius: 8px; font-size: 1rem; font-weight: 600;">
                            <i class="bi bi-pencil-square me-2"></i> تعديل الجلسة
                        </a>
                        <a asp-action="Index" class="btn btn-lg btn-outline-secondary px-4 shadow-sm" style="border-radius: 8px; font-size: 1rem;">
                            العودة للقائمة
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>