@model projectweb.Models.ExamSchedule

@{
    ViewData["Title"] = "حذف جلسة توزيع الصالات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5" dir="rtl" style="text-align: right;">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow-lg border-0 rounded-3 border-danger" style="border-top-width: 5px !important; border-radius: 12px; overflow: hidden;">
                <div class="card-header bg-danger text-white py-3 border-0 text-center">
                    <h3 class="card-title mb-0 fw-bold">
                        <i class="bi bi-exclamation-triangle me-2"></i> تأكيد حذف توزيع الصالة
                    </h3>
                </div>

                <div class="card-body p-4 p-md-5 text-center">
                    <div class="alert alert-warning border-0 rounded-3 p-4 mb-5 shadow-sm" style="border-radius: 10px;">
                        <i class="bi bi-patch-exclamation-fill text-warning fs-1 mb-3"></i>
                        <h4 class="fw-bold text-dark">هل أنت متأكد نهائياً من رغبتك في حذف هذا التوزيع؟</h4>
                        <p class="text-danger mb-0 fw-bold">
                            تحذير: سيتم إزالة ربط الصالة بالكامل بهذا الامتحان، وهذا الإجراء لا يمكن التراجع عنه.
                        </p>
                    </div>

                    <div class="card bg-light border-0 rounded-3 mb-5 text-start" style="border-radius: 8px; background-color: #f8f9fa;">
                        <div class="card-body py-3 px-4" style="text-align: right;">
                            <h5 class="fw-bold text-primary border-bottom pb-2 mb-3" style="color: #0d1b3e !important;">
                                <i class="bi bi-book-half me-1"></i> @(Model.Exam?.Subject?.SubjectName ?? "مادة غير محددة")
                                <small class="text-muted fw-bold fs-6">(@(ViewBag.ArabicAcademicYear ?? "غير محدد"))</small>
                            </h5>

                            <p class="mb-2"><strong><i class="bi bi-building me-1 text-secondary"></i> الصالة المعين:</strong> @(Model.Block?.BlockName ?? "غير محدد")</p>
                            <p class="mb-2"><strong><i class="bi bi-calendar3 me-1 text-secondary"></i> التاريخ المقرر:</strong> @(Model.Exam?.ExamDate.ToString("yyyy / MM / dd") ?? "—")</p>

                            <p class="mb-0">
                                <strong><i class="bi bi-clock me-1 text-secondary"></i> توقيت الامتحان:</strong>
                                <span dir="ltr" class="fw-bold text-dark">
                                    @if (Model.Exam != null)
                                    {
                                        var startTime = DateTime.Today.Add(Model.Exam.StartTime).ToString("hh:mm tt");
                                        var endTime = DateTime.Today.Add(Model.Exam.EndTime).ToString("hh:mm tt");
                                        @($"{startTime} - {endTime}")
                                    }
                                    else
                                    {
                                        <span>غير محدد</span>
                                    }
                                </span>
                            </p>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="ExamScheduleId" />
                        <div class="d-grid gap-3 d-md-flex justify-content-md-center">
                            <button type="submit" class="btn btn-danger btn-lg px-5 rounded-pill shadow fw-bold">
                                <i class="bi bi-trash"></i> نعم، قم بالحذف نهائياً
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5 rounded-pill fw-bold">
                                <i class="bi bi-arrow-right"></i> تراجع وإلغاء
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>