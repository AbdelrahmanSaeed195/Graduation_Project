@model projectweb.Models.ExamSchedule

@{
    ViewData["Title"] = "تعديل جلسة توزيع الجراشات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl">
    <div class="row justify-content-center mt-4">
        <div class="col-md-9">
            <div class="card academic-card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">

                <div class="card-header py-3" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%); border-bottom: none;">
                    <h4 class="card-title mb-0 fw-bold text-white text-center">
                        <i class="bi bi-pencil-square me-2"></i> تعديل بيانات تخصيص الجراشات
                    </h4>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="ExamScheduleId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4 rounded-3 @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>

                        <div class="row g-4">
                            <div class="col-12 mb-3">
                                <label asp-for="ExamId" class="form-label fw-bold small text-muted mb-1">اسم المادة / الامتحان المقرر <span class="text-danger">*</span></label>
                                <select asp-for="ExamId" id="ExamSelect" class="form-select form-select-lg shadow-sm border-light-subtle" asp-items="ViewBag.ExamId" style="border-radius: 8px; font-size: 0.95rem;">
                                </select>
                                <span asp-validation-for="ExamId" class="text-danger small mt-1 d-block fw-bold"></span>
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="LocationId" class="form-label fw-bold small text-muted mb-1">الجراش المختص <span class="text-danger">*</span></label>
                                <select asp-for="LocationId" id="LocationSelect" class="form-select form-select-lg shadow-sm border-light-subtle" asp-items="@(ViewBag.LocationId as SelectList)" style="border-radius: 8px; font-size: 0.95rem;">
                                </select>
                                <span asp-validation-for="LocationId" class="text-danger small mt-1 d-block fw-bold"></span>
                            </div>

                        </div>

                        <div class="border-top mt-5 pt-4">
                            <div class="d-flex justify-content-center gap-3">
                                <button type="submit" class="btn btn-lg px-5 py-2 shadow-sm fw-bold text-white" style="background-color: #1a3a5a; border-radius: 8px; font-size: 1rem;">
                                    <i class="bi bi-check-circle me-2"></i> حفظ التعديلات
                                </button>
                                <a asp-action="Index" class="btn btn-lg btn-outline-secondary px-4" style="border-radius: 8px; font-size: 1rem;">
                                    إلغاء والعودة
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            var currentLocationId = '@Model.LocationId';

            function handleExamChange(examId, isInitialLoad) {
                if (!examId) return;

                var locationSelect = $('#LocationSelect');

                if (!isInitialLoad) {
                    locationSelect.empty().append('<option value="">-- جاري تحميل الجراشات المتاحة --</option>');

                    $.getJSON('@Url.Action("GetAvailableLocations")', { examId: examId }, function (data) {
                        locationSelect.empty();
                        locationSelect.append('<option value="">-- اختر الجراش --</option>');
                        $.each(data, function (i, item) {
                            locationSelect.append($('<option>', { value: item.id, text: item.name }));
                        });
                    });
                } else {
                    $.getJSON('@Url.Action("GetAvailableLocations")', { examId: examId }, function (data) {
                        $.each(data, function (i, item) {
                            if (item.id != currentLocationId && locationSelect.find('option[value="' + item.id + '"]').length === 0) {
                                locationSelect.append($('<option>', { value: item.id, text: item.name }));
                            }
                        });
                    });
                }
            }

            $('#ExamSelect').change(function () {
                handleExamChange($(this).val(), false);
            });

            var initialExamId = $('#ExamSelect').val();
            if (initialExamId) {
                handleExamChange(initialExamId, true);
            }
        });
    </script>
}