@model projectweb.Models.ExamSchedule

@{
    ViewData["Title"] = "تعديل موعد امتحان";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl">
    <div class="row justify-content-center mt-4">
        <div class="col-md-10">
            <div class="card academic-card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">

                <div class="card-header py-3" style="background-color: #1a2c4e; border-bottom: none;">
                    <h4 class="card-title mb-0 fw-bold text-white text-center">
                        <i class="bi bi-pencil-square me-2"></i> تعديل بيانات الجلسة
                    </h4>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="ExamScheduleId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4 rounded-3 @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>

                        <div class="row g-4">
                            <div class="col-md-7 mb-3">
                                <label asp-for="ExamId" class="form-label fw-bold small text-muted mb-1">اسم المادة / الامتحان <span class="text-danger">*</span></label>
                                <select asp-for="ExamId" class="form-select form-select-lg shadow-sm border-light-subtle" asp-items="ViewBag.ExamId" style="border-radius: 8px; font-size: 0.95rem;">
                                </select>
                                <span asp-validation-for="ExamId" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-5 mb-3">
                                <label class="form-label fw-bold small text-muted mb-1 text-center d-block">رقم الدور / السنة الدراسية</label>
                                <div class="p-2 border rounded-3 bg-light text-center fw-bold shadow-sm" style="font-size: 1.1rem; height: calc(3.5rem + 2px); display: flex; align-items: center; justify-content: center;">
                                    @(Model.Exam?.TargetAcademicYear ?? "-")
                                </div>
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="CommitteeId" class="form-label fw-bold small text-muted mb-1">مكان اللجنة (المسؤول) <span class="text-danger">*</span></label>
                                <select asp-for="CommitteeId" class="form-select form-select-lg shadow-sm border-light-subtle" asp-items="ViewBag.CommitteeId" style="border-radius: 8px; font-size: 0.95rem;">
                                </select>
                                <span asp-validation-for="CommitteeId" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label asp-for="ScheduledDate" class="form-label fw-bold small text-muted mb-1">تاريخ اليوم المخصص <span class="text-danger">*</span></label>
                                <input asp-for="ScheduledDate" class="form-control form-control-lg shadow-sm border-light-subtle" type="date" style="border-radius: 8px; font-size: 0.95rem;" />
                                <span asp-validation-for="ScheduledDate" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="StartTime" class="form-label fw-bold small text-muted mb-1 text-center d-block">وقت البدء</label>
                                <input asp-for="StartTime" id="StartTime" class="form-control form-control-lg shadow-sm border-light-subtle text-center fw-bold" type="time" style="border-radius: 8px;" />
                                <span asp-validation-for="StartTime" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="EndTime" class="form-label fw-bold small text-muted mb-1 text-center d-block">وقت الانتهاء</label>
                                <input asp-for="EndTime" id="EndTime" class="form-control form-control-lg shadow-sm border-light-subtle text-center fw-bold" type="time" style="border-radius: 8px;" />
                                <span asp-validation-for="EndTime" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="border-top mt-5 pt-4">
                            <div class="d-flex justify-content-center gap-3">
                                <button type="submit" class="btn btn-lg px-5 py-2 shadow-sm fw-bold" style="background-color: #1a2c4e; color: white; border-radius: 8px;">
                                    <i class="bi bi-check-circle me-2"></i> حفظ التعديلات
                                </button>
                                <a asp-action="Index" class="btn btn-lg btn-outline-secondary px-4" style="border-radius: 8px;">
                                    العودة للقائمة
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            // التحقق من الوقت في طرف العميل
            $('form').submit(function (e) {
                var start = $('#StartTime').val();
                var end = $('#EndTime').val();
                if (start && end && end <= start) {
                    e.preventDefault();
                    alert('خطأ: وقت الانتهاء يجب أن يكون بعد وقت البدء');
                }
            });
        });
    </script>
}