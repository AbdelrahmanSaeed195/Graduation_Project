@model projectweb.Models.Relative
@{
    ViewData["Title"] = "تفاصيل العلاقة";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 text-end" dir="rtl">
    <div class="card mx-auto shadow-lg border-0" style="max-width: 700px; border-radius: 15px;">

        <div class="card-header border-0 p-0" style="background: linear-gradient(135deg, #1a3a5a, #2a5298); border-radius: 15px 15px 0 0;">
            <div class="text-center py-4">
                <h3 class="fw-bold text-white mb-0">
                    <i class="bi bi-file-earmark-person me-2"></i> تفاصيل العلاقة
                </h3>
            </div>
        </div>

        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-12">
                    <div class="p-3 rounded-3 border bg-white shadow-sm">
                        <label class="text-muted small d-block mb-1">
                            <i class="bi bi-person-fill me-1 text-primary"></i> الموظف
                        </label>
                        <h5 class="fw-bold mb-0" style="color: #1a3a5a;">@Model.Person?.FullName</h5>
                    </div>
                </div>

                <div class="col-12">
                    <div class="p-3 rounded-3 border bg-white shadow-sm">
                        <label class="text-muted small d-block mb-1">
                            <i class="bi bi-mortarboard-fill me-1 text-warning"></i> الطالب
                        </label>
                        <h5 class="fw-bold mb-0" style="color: #1a3a5a;">@Model.Student?.FullName</h5>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="p-3 rounded-3 border bg-white shadow-sm h-100">
                        <label class="text-muted small d-block mb-1">
                            <i class="bi bi-diagram-3-fill me-1 text-info"></i> نوع العلاقة
                        </label>
                        <span class="badge px-3 py-2" style="background-color: #e8f0fe; color: #1a3a5a; border: 1px solid #c5d3f0; font-size: 0.9rem;">
                            @Model.RelationType
                        </span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="p-3 rounded-3 border bg-white shadow-sm h-100">
                        <label class="text-muted small d-block mb-1">
                            <i class="bi bi-calendar-fill me-1 text-success"></i> السنة الأكاديمية
                        </label>
                        <p class="fw-bold mb-0 fs-6">@Model.AcademicYear</p>
                    </div>
                </div>
            </div>

            <div class="card-footer bg-light border-0 d-flex justify-content-center gap-3 py-4 mt-4"
                 style="border-radius: 0 0 15px 15px; margin: 0 -1.5rem -1.5rem;">
                <a asp-action="Edit" asp-route-id="@Model.RelativeId" class="btn btn-primary px-5 fw-bold shadow-sm">
                    <i class="bi bi-pencil-square me-1"></i> تعديل
                </a>
                <a asp-action="Delete" asp-route-id="@Model.RelativeId" class="btn btn-outline-danger px-5 fw-bold shadow-sm">
                    <i class="bi bi-trash me-1"></i> حذف
                </a>
                <a asp-action="Index" class="btn btn-outline-dark px-5 fw-bold bg-white shadow-sm">
                    <i class="bi bi-arrow-right-circle me-1"></i> عودة
                </a>
            </div>
        </div>

    </div>
</div>
