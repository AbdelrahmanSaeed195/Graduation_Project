@model projectweb.Models.Relative
@{
    ViewData["Title"] = "تعديل العلاقة";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="app-card bg-white p-4">
            <h4 class="section-title mb-3"><i class="bi bi-pencil-square"></i> تعديل العلاقة</h4>
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="RelativeId" />

                <div class="mb-3">
                    <label class="form-label required">الموظف</label>
                    <select asp-for="PersonId" class="form-select" asp-items="ViewBag.PersonsList"></select>
                    <span asp-validation-for="PersonId" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label required">الطالب</label>
                    <select asp-for="StudentId" class="form-select" asp-items="ViewBag.StudentsList"></select>
                    <span asp-validation-for="StudentId" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-7">
                        <label class="form-label required">نوع العلاقة</label>
                        <input asp-for="RelationType" class="form-control" placeholder="مثال: والد، والدة" />
                        <span asp-validation-for="RelationType" class="text-danger small mt-1 d-block"></span>
                    </div>
                    <div class="col-5">
                        <label class="form-label required">السنة</label>
                        <input asp-for="AcademicYear" class="form-control" type="number" />
                        <span asp-validation-for="AcademicYear" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-primary">تعديل</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
                    <a asp-action="Index" class="btn btn-light border">عودة</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
