@model IEnumerable<projectweb.Models.Relative>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "إدارة علاقات القرابة";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var personsList = ViewBag.PersonsList as IEnumerable<SelectListItem> ?? new List<SelectListItem>();
    var studentsList = ViewBag.StudentsList as IEnumerable<SelectListItem> ?? new List<SelectListItem>();
    var selectedPersonId = ViewBag.SelectedPerson?.ToString();
}

<div class="container-fluid" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold m-0 section-title">إدارة علاقات القرابة</h4>
    </div>

    <div class="app-card bg-white mb-3 p-3">
        <div class="card-body py-2">
            <form method="get" asp-action="Index" class="row g-2 align-items-end">
                <div class="col-md-9">
                    <label class="small fw-bold text-muted">تصفية حسب الشخص</label>
                    <select name="personId" class="form-select">
                        <option value="">عرض جميع الأشخاص</option>
                        @foreach (var p in personsList)
                        {
                            if (p.Value == selectedPersonId)
                            {
                                <option value="@p.Value" selected>@p.Text</option>
                            }
                            else
                            {
                                <option value="@p.Value">@p.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-dark btn-sm w-100">تطبيق</button>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(selectedPersonId))
    {
        <div class="app-card bg-white mb-3 p-3 border-start border-primary border-4">
            <div class="card-body py-3">
                <h6 class="fw-bold mb-3 small text-primary">إضافة علاقة قريبة</h6>
                <form asp-action="Create" method="post" class="row g-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="PersonId" value="@selectedPersonId" />
                    <div class="col-md-4">
                        <select name="StudentId" class="form-select" required>
                            <option value="">اختر الطالب</option>
                            @foreach (var s in studentsList) {
                                <option value="@s.Value">@s.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <input name="RelationType" class="form-control" placeholder="نوع العلاقة" required />
                    </div>
                    <div class="col-md-3">
                        <input name="AcademicYear" type="number" class="form-control" value="2026" required />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">حفظ</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="app-card bg-white">
        <div class="table-responsive">
            <table class="table table-clean table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-3 small">الموظف</th>
                        <th class="small">الطالب</th>
                        <th class="small">العلاقة</th>
                        <th class="small text-center">السنة</th>
                        <th class="text-center small">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any()) {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">لا توجد نتائج</td>
                        </tr>
                    }
                    @foreach (var r in Model) {
                        <tr>
                            <td class="ps-3">@r.Person?.FullName</td>
                            <td class="fw-bold">@r.Student?.FullName</td>
                            <td><span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1">@r.RelationType</span></td>
                            <td class="text-center">@r.AcademicYear</td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Details" asp-route-id="@r.RelativeId" class="btn btn-sm btn-outline-info" title="عرض"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@r.RelativeId" class="btn btn-sm btn-outline-primary" title="تعديل"><i class="bi bi-pencil-square"></i></a>
                                    <a asp-action="Delete" asp-route-id="@r.RelativeId" class="btn btn-sm btn-outline-danger" title="حذف"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>