@model IEnumerable<projectweb.Models.Report>
@using System.ComponentModel.DataAnnotations
@using System.Reflection

@{
    ViewData["Title"] = "التقارير والمحاضر الموحدة";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl" style="text-align: right;">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 10px;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold academic-heading" style="color: #1a3a5a;">
            <i class="bi bi-file-earmark-text-fill me-2 text-primary"></i> أرشيف التقارير والمحاضر
        </h1>
        <a asp-action="Create" class="btn btn-academic-primary px-4 shadow-sm fw-bold">
            <i class="bi bi-plus-circle me-1"></i> إنشاء محضر جديد
        </a>
    </div>

    <div class="card academic-card mb-4 border-0 shadow-sm" style="border-radius: 15px; background-color: white;">
        <div class="card-body p-4">
            <h6 class="fw-bold academic-heading mb-3"><i class="bi bi-funnel me-2"></i> تصفية النتائج</h6>
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label for="reportType" class="form-label small fw-bold text-muted">تصنيف المحضر</label>
                    <select name="reportType" id="reportType" class="form-select academic-input" style="border-radius: 8px;">
                        <option value="">-- عرض الكل --</option>
                        @if (ViewBag.ReportStatusList != null)
                        {
                            foreach (var statusItem in (List<SelectListItem>)ViewBag.ReportStatusList)
                            {
                                if (ViewBag.SelectedReportType?.ToString() == statusItem.Value)
                                {
                                    <option value="@statusItem.Value" selected="selected">@statusItem.Text</option>
                                }
                                else
                                {
                                    <option value="@statusItem.Value">@statusItem.Text</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-academic-primary px-4 fw-bold w-100" style="border-radius: 8px; height: calc(2.25rem + 2px);">
                        <i class="bi bi-search me-1"></i> تصفية وبحث
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card academic-card overflow-hidden border-0 shadow-sm" style="border-radius: 15px; background-color: white;">
        <div class="card-header text-white p-3 d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%); border: none;">
            <h5 class="mb-0 fw-bold text-white"><i class="bi bi-list-ul me-2"></i> سجل الوقائع المسجلة</h5>
            <span class="badge bg-white text-dark fw-bold px-3 py-2" style="border-radius: 6px;">إجمالي المحاضر: @(Model?.Count() ?? 0)</span>
        </div>
        <div class="table-responsive">
            <table class="table academic-table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="text-center">
                        <th class="text-start" style="border: none; font-weight: 700;">المادة / الامتحان</th>
                        <th style="border: none; font-weight: 700;">اللجنة / المقر</th>
                        <th style="border: none; font-weight: 700;">تاريخ الواقعة</th>
                        <th style="border: none; font-weight: 700;">نوع المحضر</th>
                        <th style="border: none; font-weight: 700;">ملخص الملاحظات</th>
                        <th class="pe-4" style="border: none; font-weight: 700;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="text-center">
                                <td class="text-start">
                                    @if (item.ExamSchedule?.Exam?.Subject != null)
                                    {
                                        <div class="fw-bold text-dark" style="color: #1a3a5a !important;">@item.ExamSchedule.Exam.Subject.SubjectName</div>
                                        <div class="text-muted extra-small" style="font-size: 0.75rem; font-weight: 600;">
                                            <i class="bi bi-calendar-event me-1 text-secondary"></i> @item.ExamSchedule.Exam.ExamDate.ToString("yyyy/MM/dd")
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">غير محدد</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge rounded-pill bg-light border shadow-sm px-3 py-2 text-navy fw-bold" style="color: #1a3a5a; border-radius: 6px;">
                                        <i class="bi bi-door-open-fill text-primary me-1"></i>
                                        @if (item.ExamLocation != null && item.LocationId > 0)
                                        {
                                            <span>@item.ExamLocation.LocationName</span>
                                        }
                                        else
                                        {
                                            <span>محضر عام</span>
                                        }
                                    </span>
                                </td>
                                <td>
                                    <div class="small fw-bold text-muted">
                                        <i class="bi bi-clock-fill me-1 text-info"></i>
                                        @item.CreatedDate.ToString("yyyy/MM/dd HH:mm")
                                    </div>
                                </td>
                                <td>
                                    @{
                                        var enumType = item.Status.GetType();
                                        var memberInfo = enumType.GetMember(item.Status.ToString());
                                        var displayAttr = memberInfo.Length > 0 ? memberInfo[0].GetCustomAttribute<DisplayAttribute>() : null;
                                        var arabicName = displayAttr?.Name ?? item.Status.ToString();

                                        var statusClass = item.Status switch
                                        {
                                            projectweb.Models.ReportStatus.Normal => "bg-success",
                                            projectweb.Models.ReportStatus.Cheating => "bg-danger",
                                            projectweb.Models.ReportStatus.Disturbance => "bg-warning text-dark",
                                            projectweb.Models.ReportStatus.Emergency => "bg-danger",
                                            projectweb.Models.ReportStatus.AbsenceIssue => "bg-secondary",
                                            _ => "bg-info"
                                        };
                                    }
                                    <span class="badge @statusClass px-3 py-2 shadow-sm fw-bold" style="min-width: 100px; border-radius: 8px;">
                                        @arabicName
                                    </span>
                                </td>
                                <td>
                                    <div class="text-truncate text-muted small fw-bold" style="max-width: 150px; display: inline-block;" title="@item.Notes">
                                        @(string.IsNullOrEmpty(item.Notes) ? "— لا يوجد ملاحظات —" : item.Notes)
                                    </div>
                                </td>
                                <td class="pe-4">
                                    <div class="btn-group shadow-sm" role="group" style="border-radius: 8px; overflow: hidden;">
                                        <a asp-action="Details" asp-route-id="@item.ReportId" class="btn btn-sm btn-white text-info border" title="عرض التفاصيل">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.ReportId" class="btn btn-sm btn-white text-primary border" title="تعديل">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.ReportId" class="btn btn-sm btn-white text-danger border" title="حذف">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="opacity-50 py-4">
                                    <i class="bi bi-folder-x fs-1 d-block mb-3 text-muted"></i>
                                    <h5 class="fw-bold text-secondary">لا توجد محاضر مسجلة تطابق البحث حالياً</h5>
                                    <p class="small text-muted mb-0">بإمكانك إضافة أول محضر من خلال زر "إنشاء محضر جديد" بالأعلى.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .academic-table thead th {
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        font-weight: 700;
        background-color: #f8f9fa;
        color: #4a5568;
        border-bottom: 2px solid #edf2f7;
    }

    .btn-white {
        background-color: #fff;
        transition: all 0.2s;
    }

        .btn-white:hover {
            background-color: #f8f9fa;
            transform: translateY(-1px);
        }

    .table-hover tbody tr:hover {
        background-color: rgba(46, 90, 136, 0.03);
    }

    .btn-academic-primary {
        background-color: #1a3a5a;
        color: white;
        border-radius: 8px;
        transition: all 0.3s;
    }

        .btn-academic-primary:hover {
            background-color: #2e5a88;
            color: white;
            transform: translateY(-2px);
        }

    .academic-input:focus {
        border-color: #1a3a5a;
        box-shadow: 0 0 0 0.25rem rgba(26, 58, 90, 0.1);
    }
</style>