@model IEnumerable<projectweb.Models.Report>
@using System.ComponentModel.DataAnnotations
@using System.Reflection

@{
    ViewData["Title"] = "التقارير والمحاضر";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 10px;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold academic-heading">
            <i class="bi bi-file-earmark-text-fill me-2 text-primary"></i> أرشيف التقارير والمحاضر
        </h1>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-academic-primary px-4 shadow-sm fw-bold">
                <i class="bi bi-plus-circle me-1"></i> إنشاء محضر جديد
            </a>
        }
    </div>

    @* قسم التصفية المحدث *@
    <div class="card academic-card mb-4 border-0 shadow-sm" style="border-radius: 15px;">
        <div class="card-body p-4">
            <h6 class="fw-bold academic-heading mb-3"><i class="bi bi-funnel me-2"></i> تصفية النتائج</h6>
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label for="reportType" class="form-label small fw-bold text-muted">تصنيف المحضر</label>
                    <select name="reportType" id="reportType" class="form-select academic-input" asp-items="ViewBag.ReportStatusList">
                        <option value="">-- عرض الكل --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-academic-primary px-4 fw-bold w-100">
                        <i class="bi bi-search me-1"></i> تصفية
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* جدول البيانات *@
    <div class="card academic-card overflow-hidden border-0 shadow-sm" style="border-radius: 15px;">
        <div class="card-header academic-card-header text-white p-3 d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%);">
            <h5 class="mb-0 fw-bold text-white"><i class="bi bi-list-ul me-2"></i> سجل الوقائع المسجلة</h5>
            <span class="badge bg-white bg-opacity-25 shadow-sm">إجمالي المحاضر: @Model.Count()</span>
        </div>
        <div class="table-responsive">
            <table class="table academic-table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="text-center">
                        <th class="ps-4 text-start" style="width: 100px;">كود</th>
                        <th class="text-start">المادة / الامتحان</th>
                        <th>اللجنة</th>
                        <th>تاريخ الواقعة</th>
                        <th>نوع المحضر</th>
                        <th>ملخص الملاحظات</th>
                        <th class="pe-4">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="text-center">
                                <td class="ps-4 text-start fw-bold text-primary">#@item.ReportID</td>
                                <td class="text-start">
                                    @if (item.ExamSchedule?.Exam?.Subject != null)
                                    {
                                        <div class="fw-bold text-dark">@item.ExamSchedule.Exam.Subject.SubjectName</div>
                                        <div class="text-muted extra-small" style="font-size: 0.75rem;">
                                            <i class="bi bi-calendar-event me-1"></i> @item.ExamSchedule.Exam.ExamDate.ToString("yyyy/MM/dd")
                                        </div>
                                    }
                                </td>
                                <td>
                                    <span class="badge rounded-pill bg-light text-dark border shadow-sm px-3">
                                        @(item.ExamSchedule?.Committee?.CommitteeNumber ?? 0)
                                    </span>
                                </td>
                                <td>
                                    <div class="small fw-bold text-muted">
                                        <i class="bi bi-clock-fill me-1 text-info"></i>
                                        @item.CreatedDate.ToString("yyyy/MM/dd HH:mm")
                                    </div>
                                </td>
                                <td>
                                    @{
                                        // استخراج الاسم العربي من الـ Display Attribute المعرف في الموديل
                                        var enumType = item.Status.GetType();
                                        var memberInfo = enumType.GetMember(item.Status.ToString());
                                        var displayAttr = memberInfo[0].GetCustomAttribute<DisplayAttribute>();
                                        var arabicName = displayAttr?.Name ?? item.Status.ToString();

                                        var statusClass = item.Status switch
                                        {
                                            projectweb.Models.ReportStatus.Normal => "bg-success",
                                            projectweb.Models.ReportStatus.Cheating => "bg-danger",
                                            projectweb.Models.ReportStatus.Disturbance => "bg-warning text-dark",
                                            projectweb.Models.ReportStatus.Emergency => "bg-danger",
                                            projectweb.Models.ReportStatus.AbsenceIssue => "bg-secondary",
                                            _ => "bg-info"
                                        };
                                    }
                                    <span class="badge @statusClass px-3 py-2 shadow-sm" style="min-width: 100px; border-radius: 8px;">
                                        @arabicName
                                    </span>
                                </td>
                                <td>
                                    <div class="text-truncate text-muted small" style="max-width: 150px;" title="@item.Notes">
                                        @(string.IsNullOrEmpty(item.Notes) ? "— لا يوجد ملاحظات —" : item.Notes)
                                    </div>
                                </td>
                                <td class="pe-4">
                                    <div class="btn-group shadow-sm" role="group" style="border-radius: 8px; overflow: hidden;">
                                        <a asp-action="Details" asp-route-id="@item.ReportID" class="btn btn-sm btn-white text-info border" title="عرض التفاصيل">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.ReportID" class="btn btn-sm btn-white text-primary border" title="تعديل">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.ReportID" class="btn btn-sm btn-white text-danger border" title="حذف">
                                                <i class="bi bi-trash-fill"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <div class="opacity-50">
                                    <i class="bi bi-folder-x fs-1 d-block mb-3 text-muted"></i>
                                    <h5 class="fw-bold text-muted">لا توجد محاضر مسجلة حالياً</h5>
                                    <p class="small text-muted">بإمكانك إضافة أول محضر من خلال زر "إنشاء محضر جديد" بالأعلى.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .academic-table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 700;
        background-color: #f8f9fa;
        color: #4a5568;
        border-bottom: 2px solid #edf2f7;
    }

    .btn-white {
        background-color: #fff;
        transition: all 0.2s;
    }

        .btn-white:hover {
            background-color: #f8f9fa;
            transform: translateY(-1px);
        }

    .table-hover tbody tr:hover {
        background-color: rgba(46, 90, 136, 0.03);
    }

    .btn-academic-primary {
        background-color: #1a3a5a;
        color: white;
        border-radius: 8px;
        transition: all 0.3s;
    }

        .btn-academic-primary:hover {
            background-color: #2e5a88;
            color: white;
            transform: translateY(-2px);
        }

    .academic-input:focus {
        border-color: #1a3a5a;
        box-shadow: 0 0 0 0.25rem rgba(26, 58, 90, 0.1);
    }
</style>