@model projectweb.Models.Report
@using System.ComponentModel.DataAnnotations
@using System.Reflection

@{
    ViewData["Title"] = "تأكيد حذف محضر";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-5" dir="rtl">
    <div class="col-xl-7 col-lg-8">
        <div class="card academic-card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header bg-danger text-white p-4 border-0 text-center">
                <i class="bi bi-exclamation-octagon-fill fs-1 d-block mb-2"></i>
                <h4 class="mb-0 fw-bold">تأكيد عملية الحذف النهائية</h4>
                <p class="mb-0 small opacity-75">يرجى مراجعة بيانات المحضر رقم (#@Model.ReportId) قبل التأكيد</p>
            </div>

            <div class="card-body p-4 p-md-5 bg-white">

                @if (Model.ReportPersons != null && Model.ReportPersons.Any())
                {
                    <div class="alert alert-danger border-0 mb-4 shadow-sm d-flex align-items-start p-3" style="border-right: 5px solid #dc3545 !important;">
                        <i class="bi bi-shield-lock-fill fs-4 me-3"></i>
                        <div>
                            <strong class="d-block mb-1 fs-5">إجراء محظور قانونياً!</strong>
                            <p class="small mb-0 lh-base">
                                هذا المحضر محمي لوجود <strong>(@Model.ReportPersons.Count)</strong> طرف مسجل عليه (طلاب/موظفون).
                                لحماية الأرشيف الأكاديمي، لا يمكن حذف المحاضر التي تحتوي على أطراف معنية. يرجى مراجعة الإدارة المختصة.
                            </p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning border-0 mb-4 shadow-sm d-flex align-items-start p-3" style="border-right: 5px solid #ffc107 !important;">
                        <i class="bi bi-question-circle-fill fs-4 me-3 text-warning"></i>
                        <div>
                            <strong class="d-block mb-1 text-dark fs-5">هل أنت متأكد من الحذف؟</strong>
                            <p class="small text-muted mb-0 lh-base">
                                سيتم مسح كافة البيانات المرتبطة بهذا المحضر نهائياً من النظام. هذا الإجراء <strong>لا يمكن الرجوع عنه</strong>.
                            </p>
                        </div>
                    </div>
                }

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="rounded p-3 border bg-light h-100 shadow-sm text-center">
                            <div class="small text-muted mb-1 fw-bold">المادة / الامتحان</div>
                            <div class="fw-bold text-navy">
                                <i class="bi bi-journal-text me-1 text-primary"></i>
                                @(Model.ExamSchedule?.Exam?.Subject?.SubjectName ?? "غير محدد")
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="rounded p-3 border bg-light text-center h-100 shadow-sm">
                            <div class="small text-muted mb-1 fw-bold">رقم اللجنة</div>
                            <div class="fw-bold fs-5 text-dark">
                                @(Model.Committee != null ? "لجنة " + Model.Committee.CommitteeNumber : "غير محدد")
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="rounded p-3 border bg-light text-center h-100 shadow-sm">
                            <div class="small text-muted mb-1 fw-bold">حالة المحضر</div>
                            <div class="mt-1">
                                @{
                                    var enumType = Model.Status.GetType();
                                    var memberInfo = enumType.GetMember(Model.Status.ToString());
                                    var displayAttr = memberInfo.Length > 0 ? memberInfo[0].GetCustomAttribute<DisplayAttribute>() : null;
                                    var arabicStatusName = displayAttr?.Name ?? Model.Status.ToString();
                                    var badgeClass = Model.Status == projectweb.Models.ReportStatus.Normal ? "bg-success" : "bg-danger";
                                }
                                <span class="badge @badgeClass shadow-sm px-3 py-2">
                                    @arabicStatusName
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="p-3 border rounded mb-4 bg-light bg-opacity-50">
                    <div class="small text-muted fw-bold mb-1">تاريخ تحرير المحضر:</div>
                    <div class="small fw-bold text-dark text-start" dir="ltr">
                        @Model.CreatedDate.ToString("yyyy/MM/dd - hh:mm tt") <i class="bi bi-calendar-check ms-1"></i>
                    </div>
                </div>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReportId" />

                    <div class="d-flex justify-content-center gap-3 mt-4 pt-3 border-top">
                        @if (Model.ReportPersons == null || !Model.ReportPersons.Any())
                        {
                            <button type="submit" class="btn btn-danger px-5 py-2 fw-bold shadow-sm">
                                <i class="bi bi-trash3-fill me-2"></i> تأكيد الحذف النهائي
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-secondary px-5 py-2 fw-bold shadow-sm opacity-75" disabled>
                                <i class="bi bi-lock-fill me-2"></i> الحذف معطل
                            </button>
                        }

                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 border-0">
                            <i class="bi bi-arrow-right me-1"></i> تراجع والعودة للقائمة
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="text-center mt-3 text-muted small">
            <i class="bi bi-info-circle me-1"></i> تنبيه: كافة عمليات الحذف يتم توثيقها في سجلات رقابة النظام لأغراض التدقيق.
        </div>
    </div>
</div>

<style>
    .text-navy {
        color: #1a3a5a;
    }

    .academic-card {
        transition: all 0.3s ease;
    }

    .badge {
        border-radius: 8px;
        font-weight: 600;
    }

    .btn-danger {
        background-color: #dc3545;
        border: none;
        border-radius: 8px;
        transition: 0.3s;
    }

        .btn-danger:hover {
            background-color: #bb2d3b;
            transform: scale(1.02);
        }
</style>