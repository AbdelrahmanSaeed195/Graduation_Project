@model projectweb.Models.Report

@{
    ViewData["Title"] = "إنشاء محضر جديد";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-9">
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm mb-4 border-0" style="border-radius: 10px;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> برجاء مراجعة الأخطاء التالية قبل الحفظ.
            </div>
        }

        <div class="card academic-card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header academic-card-header text-white p-4" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%); border: none;">
                <div class="d-flex align-items-center">
                    <div class="bg-white bg-opacity-25 rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                        <i class="bi bi-file-earmark-plus-fill text-white fs-4"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold text-white">إنشاء محضر جديد</h4>
                        <p class="mb-0 small text-white-50">توثيق وقائع اللجان والامتحانات</p>
                    </div>
                </div>
            </div>

            <div class="card-body p-4 p-md-5" style="background-color: #ffffff;">
                <form asp-action="Create" method="post" id="reportForm">
                    @Html.AntiForgeryToken()

                    <div class="row g-4">
                        @* 1. اختيار المادة *@
                        <div class="col-md-6">
                            <label class="form-label academic-label required fw-bold mb-2">اختر المادة / الامتحان</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-book"></i></span>
                                <select id="examSelect" class="form-select academic-input border-start-0"
                                        asp-items="@(ViewData["ExamID"] as SelectList)">
                                    <option value="">-- اختر المادة --</option>
                                </select>
                            </div>
                        </div>

                        @* 2. اختيار اللجنة *@
                        <div class="col-md-6">
                            <label asp-for="ScheduleID" class="form-label academic-label required fw-bold mb-2">اللجنة المختصة</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-door-open"></i></span>
                                <select asp-for="ScheduleID" id="committeeSelect" class="form-select academic-input border-start-0" disabled>
                                    <option value="">-- اختر المادة أولاً --</option>
                                </select>
                            </div>
                            <span asp-validation-for="ScheduleID" class="text-danger small fw-bold"></span>
                        </div>

                        @* 3. نوع المحضر *@
                        <div class="col-md-12">
                            <label asp-for="Status" class="form-label academic-label required fw-bold mb-2">نوع / حالة المحضر</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-info-square"></i></span>
                                <select asp-for="Status" class="form-select academic-input border-start-0"
                                        asp-items="ViewBag.StatusList">
                                    <option value="">-- اختر نوع المحضر --</option>
                                </select>
                            </div>
                        </div>

                        @* 4. اختيار الطالب المعني *@
                        <div class="col-md-6 party-section" style="display:none;">
                            <label class="form-label academic-label fw-bold mb-2">الطالب المعني (إن وجد)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-person-badge"></i></span>
                                <select name="SelectedStudentId" id="studentSelect" class="form-select academic-input border-start-0">
                                    <option value="">-- اختر الطالب --</option>
                                </select>
                            </div>
                        </div>

                        @* 5. الموظفون (الملاحظون) *@
                        <div class="col-md-6 party-section" style="display:none;">
                            <label class="form-label academic-label required fw-bold mb-2">المكلفون الذين رصدوا الواقعة</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-people"></i></span>
                                <select name="SelectedStaffIds" id="staffSelect" class="form-select academic-input border-start-0" multiple style="height: 120px;">
                                </select>
                            </div>
                            <small class="text-muted" style="font-size: 0.75rem;">استخدم Ctrl لاختيار أكثر من موظف</small>
                        </div>

                        @* 6. الملاحظات *@
                        <div class="col-12 mt-4">
                            <label asp-for="Notes" class="form-label academic-label fw-bold mb-2">تفاصيل ووقائع المحضر</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 align-items-start pt-3 text-muted">
                                    <i class="bi bi-pencil-square"></i>
                                </span>
                                <textarea asp-for="Notes" class="form-control academic-input border-start-0" rows="5"
                                          placeholder="أدخل وصفاً تفصيلياً لما حدث داخل اللجنة..."></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-5 pt-4 border-top">
                        <button type="submit" class="btn btn-academic-primary px-5 fw-bold shadow-sm py-2">
                            <i class="bi bi-check-circle me-1"></i> حفظ المحضر
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 border-0">
                            <i class="bi bi-x-circle me-1"></i> إلغاء والعودة
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            // 1. جلب اللجان عند تغيير المادة
            $('#examSelect').change(function () {
                var examId = $(this).val();
                var committeeSelect = $('#committeeSelect');
                $('.party-section').hide();
                committeeSelect.empty().append('<option value="">-- جاري التحميل... --</option>');

                if (examId) {
                    $.getJSON('@Url.Action("GetCommitteesByExam")', { examId: examId }, function (data) {
                        committeeSelect.empty().append('<option value="">-- اختر اللجنة --</option>');
                        committeeSelect.prop('disabled', false);
                        $.each(data, function (i, item) {
                            committeeSelect.append($('<option>', { value: item.id, text: item.name }));
                        });
                    });
                } else {
                    committeeSelect.empty().append('<option value="">-- اختر المادة أولاً --</option>').prop('disabled', true);
                }
            });

            // 2. جلب الطلاب والموظفين عند تغيير اللجنة
            $('#committeeSelect').change(function () {
                var scheduleId = $(this).val();
                if (scheduleId) {
                    $.getJSON('@Url.Action("GetCommitteeParties")', { scheduleId: scheduleId }, function (data) {
                        // تعبئة الطلاب
                        var studentSelect = $('#studentSelect');
                        studentSelect.empty().append('<option value="">-- اختر الطالب --</option>');
                        $.each(data.students, function (i, s) {
                            studentSelect.append($('<option>', { value: s.id, text: s.name }));
                        });

                        // تعبئة الموظفين
                        var staffSelect = $('#staffSelect');
                        staffSelect.empty();
                        $.each(data.staff, function (i, s) {
                            staffSelect.append($('<option>', { value: s.id, text: s.name }));
                        });

                        $('.party-section').fadeIn();
                    });
                }
            });
        });
    </script>

    <style>
        .academic-input:focus {
            border-color: #1a3a5a !important;
            box-shadow: 0 0 0 0.25rem rgba(26, 58, 90, 0.1) !important;
        }

        .input-group-text {
            border-radius: 0 8px 8px 0 !important;
            border-color: #dee2e6;
            background-color: #f8f9fa;
        }

        .academic-input {
            border-radius: 8px 0 0 8px !important;
            border-color: #dee2e6;
        }

        .academic-label.required::after {
            content: " *";
            color: red;
        }

        .btn-academic-primary {
            background-color: #1a3a5a;
            color: white;
            border-radius: 8px;
            transition: 0.3s;
        }

            .btn-academic-primary:hover {
                background-color: #2e5a88;
                transform: translateY(-2px);
            }
    </style>
}