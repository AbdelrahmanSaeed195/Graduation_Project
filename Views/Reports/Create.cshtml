@model projectweb.Models.Report

@{
    ViewData["Title"] = "إنشاء محضر جديد";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-8">
        <div class="card academic-card shadow-sm border-0">
            <div class="card-header academic-card-header text-white p-4">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-plus-square-fill me-2"></i> إنشاء محضر جديد</h4>
            </div>
            <div class="card-body p-4" style="background-color: var(--surface-white);">

                <div class="alert alert-info border-0 shadow-sm d-flex align-items-center mb-4">
                    <i class="bi bi-info-circle-fill fs-3 me-3 text-primary"></i>
                    <div>
                        <strong class="d-block mb-1">توضيح:</strong>
                        <ul class="mb-0 ps-3 small opacity-90">
                            <li>بعد إنشاء المحضر، يمكنك إضافة الموقعين والتوقيعات من صفحة التفاصيل.</li>
                            <li>تاريخ تحرير المحضر يتم تعيينه تلقائياً وقت الحفظ.</li>
                        </ul>
                    </div>
                </div>

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="ScheduleID" class="form-label academic-label required">جلسة الامتحان</label>
                            <select asp-for="ScheduleID" class="form-select academic-input"
                                    asp-items="@(ViewData["ScheduleID"] as SelectList)">
                                <option value="">-- اختر جلسة الامتحان --</option>
                            </select>
                            <span asp-validation-for="ScheduleID" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label academic-label required">نوع / حالة المحضر</label>
                            <select asp-for="Status" class="form-select academic-input"
                                    asp-items="Html.GetEnumSelectList<projectweb.Models.ReportStatus>()">
                                <option value="">-- اختر نوع المحضر --</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Notes" class="form-label academic-label">ملاحظات وتفاصيل</label>
                            <textarea asp-for="Notes" class="form-control academic-input" rows="4"
                                      placeholder="أدخل أي ملاحظات أو تفاصيل إضافية حول المحضر..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top" style="border-color: var(--border-color) !important;">
                        <button type="submit" class="btn btn-academic-primary px-4 fw-bold shadow-sm">
                            <i class="bi bi-check-circle me-1"></i> حفظ وإنشاء المحضر
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">إلغاء والعودة</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
