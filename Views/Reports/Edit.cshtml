@model projectweb.Models.Report
@using System.ComponentModel.DataAnnotations
@using System.Reflection

@{
    ViewData["Title"] = "تعديل بيانات المحضر";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl" style="text-align: right;">
    <div class="col-xl-9">
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm mb-4 border-0" style="border-radius: 10px;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> برجاء مراجعة الأخطاء التالية قبل الحفظ.
            </div>
        }

        <div class="card academic-card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%); border: none;">
                <div class="d-flex align-items-center">
                    <div class="bg-white bg-opacity-25 rounded-circle p-2 ms-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                        <i class="bi bi-pencil-square text-white fs-4"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold text-white">تعديل المحضر رقم (#@Model.ReportId)</h4>
                        <p class="mb-0 small text-white-50 mt-1">تحديث البيانات المسجلة بتاريخ @Model.CreatedDate.ToString("yyyy/MM/dd")</p>
                    </div>
                </div>
            </div>

            <div class="card-body p-4 p-md-5" style="background-color: #ffffff;">
                <form asp-action="Edit" method="post" id="editReportForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReportId" />
                    <input type="hidden" asp-for="CreatedDate" />

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label academic-label required fw-bold mb-2">المادة / الامتحان</label>
                            <div class="input-group" style="flex-direction: row-reverse;">
                                <select id="examSelect" class="form-select academic-input border-end-0"
                                        asp-items="@(ViewData["ExamID"] as SelectList)" style="border-radius: 0 8px 8px 0 !important;">
                                    <option value="">-- اختر المادة --</option>
                                </select>
                                <span class="input-group-text bg-light text-muted" style="border-radius: 8px 0 0 8px !important;"><i class="bi bi-book"></i></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ScheduleId" class="form-label academic-label required fw-bold mb-2">اللجنة المختصة</label>
                            <div class="input-group" style="flex-direction: row-reverse;">
                                <select asp-for="ScheduleId" id="committeeSelect" class="form-select academic-input border-end-0" style="border-radius: 0 8px 8px 0 !important;">
                                    <option value="">-- اختر اللجنة --</option>
                                </select>
                                <span class="input-group-text bg-light text-muted" style="border-radius: 8px 0 0 8px !important;"><i class="bi bi-door-open"></i></span>
                            </div>
                            <span asp-validation-for="ScheduleId" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Status" class="form-label academic-label required fw-bold mb-2">نوع / حالة المحضر</label>
                            <div class="input-group" style="flex-direction: row-reverse;">
                                <select asp-for="Status" class="form-select academic-input border-end-0"
                                        asp-items="ViewBag.StatusList" style="border-radius: 0 8px 8px 0 !important;">
                                    <option value="">-- اختر نوع المحضر --</option>
                                </select>
                                <span class="input-group-text bg-light text-muted" style="border-radius: 8px 0 0 8px !important;"><i class="bi bi-info-square"></i></span>
                            </div>
                            <span asp-validation-for="Status" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6 party-section">
                            <label class="form-label academic-label fw-bold mb-2">الطالب المعني (إن وجد)</label>
                            <div class="input-group" style="flex-direction: row-reverse;">
                                <select name="SelectedStudentId" id="studentSelect" class="form-select academic-input border-end-0" style="border-radius: 0 8px 8px 0 !important;">
                                    <option value="">-- اختر الطالب --</option>
                                </select>
                                <span class="input-group-text bg-light text-muted" style="border-radius: 8px 0 0 8px !important;"><i class="bi bi-person-badge"></i></span>
                            </div>
                        </div>

                        <div class="col-md-6 party-section">
                            <label class="form-label academic-label required fw-bold mb-2">المكلفون الذين رصدوا الواقعة</label>
                            <div class="input-group" style="flex-direction: row-reverse;">
                                <select name="SelectedStaffIds" id="staffSelect" class="form-select academic-input border-end-0" multiple style="height: 120px; border-radius: 0 8px 8px 0 !important;">
                                </select>
                                <span class="input-group-text bg-light text-muted align-items-start pt-3" style="border-radius: 8px 0 0 8px !important;"><i class="bi bi-people"></i></span>
                            </div>
                            <small class="text-muted d-block mt-1 fw-bold" style="font-size: 0.75rem;"><i class="bi bi-info-circle"></i> يمكنك استخدام Ctrl لاختيار أكثر من موظف</small>
                        </div>

                        <div class="col-12 mt-4">
                            <label asp-for="Notes" class="form-label academic-label fw-bold mb-2">تفاصيل ووقائع المحضر</label>
                            <div class="input-group" style="flex-direction: row-reverse;">
                                <textarea asp-for="Notes" class="form-control academic-input border-end-0" rows="6"
                                          placeholder="تعديل وصف الواقعة..." style="border-radius: 0 8px 8px 0 !important;"></textarea>
                                <span class="input-group-text bg-light align-items-start pt-3 text-muted" style="border-radius: 8px 0 0 8px !important;">
                                    <i class="bi bi-pencil-square"></i>
                                </span>
                            </div>
                            <span asp-validation-for="Notes" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-5 pt-4 border-top justify-content-start">
                        <button type="submit" class="btn btn-academic-primary px-5 fw-bold shadow-sm py-2">
                            <i class="bi bi-save me-1"></i> حفظ التغييرات
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 border-0" style="border-radius: 8px;">
                            <i class="bi bi-arrow-right me-1"></i> العودة للقائمة
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            var initialExamId = $('#examSelect').val();
            var initialScheduleId = '@(ViewBag.SelectedScheduleId ?? Model.ScheduleId)';
            var currentStaffIds = @Html.Raw(Json.Serialize(ViewBag.CurrentStaffIds)) || [];
            var selectedStudentId = '@(ViewBag.SelectedStudentId ?? "")';

            if (initialExamId) {
                loadCommittees(initialExamId, initialScheduleId);
            }

            $('#examSelect').change(function () {
                loadCommittees($(this).val(), null);
            });

            $('#committeeSelect').change(function () {
                loadParties($(this).val());
            });

            function loadCommittees(examId, selectedId) {
                var committeeSelect = $('#committeeSelect');
                committeeSelect.empty().append('<option value="">-- جاري التحميل... --</option>');

                if (examId) {
                    $.getJSON('@Url.Action("GetCommitteesByExam")', { examId: examId }, function (data) {
                        committeeSelect.empty().append('<option value="">-- اختر اللجنة --</option>');
                        $.each(data, function (index, item) {
                            var option = $('<option>', { value: item.id, text: item.name });
                            if (item.id == selectedId) {
                                option.attr('selected', 'selected');
                            }
                            committeeSelect.append(option);
                        });

                        var currentId = selectedId || committeeSelect.val();
                        if (currentId) {
                            loadParties(currentId);
                        } else {
                            $('.party-section').hide();
                        }
                    });
                } else {
                    committeeSelect.empty().append('<option value="">-- اختر اللجنة --</option>');
                    $('.party-section').hide();
                }
            }

            function loadParties(scheduleId) {
                if(!scheduleId) {
                    $('.party-section').hide();
                    return;
                }

                $.getJSON('@Url.Action("GetCommitteeParties")', { scheduleId: scheduleId }, function (data) {
                    var studentSelect = $('#studentSelect');
                    studentSelect.empty().append('<option value="">-- اختر الطالب --</option>');
                    $.each(data.students, function (i, s) {
                        var option = $('<option>', { value: s.id, text: s.name });
                        if (s.id == selectedStudentId) {
                            option.attr('selected', 'selected');
                        }
                        studentSelect.append(option);
                    });

                    var staffSelect = $('#staffSelect');
                    staffSelect.empty();
                    $.each(data.staff, function (i, s) {
                        var option = $('<option>', { value: s.id, text: s.name });
                        // تأمين عملية الفحص داخل مصفوفة الموظفين بدقة
                        if (currentStaffIds && currentStaffIds.map(String).indexOf(String(s.id)) !== -1) {
                            option.attr('selected', 'selected');
                        }
                        staffSelect.append(option);
                    });

                    $('.party-section').show();
                });
            }
        });
    </script>

    <style>
        .academic-input:focus {
            border-color: #1a3a5a !important;
            box-shadow: 0 0 0 0.25rem rgba(26, 58, 90, 0.1) !important;
        }

        .academic-label.required::after {
            content: " *";
            color: red;
        }

        .btn-academic-primary {
            background-color: #1a3a5a;
            color: white;
            border-radius: 8px;
            transition: 0.3s;
        }

            .btn-academic-primary:hover {
                background-color: #2e5a88;
                transform: translateY(-2px);
            }
    </style>
}