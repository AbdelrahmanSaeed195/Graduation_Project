@model projectweb.Models.Report

@{
    ViewData["Title"] = "تعديل بيانات المحضر";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-8">
        <div class="card academic-card">
            <div class="card-header academic-card-header text-white p-4">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-pencil-square me-2"></i> تعديل بيانات المحضر رقم (#@Model.ReportID)</h4>
            </div>
            <div class="card-body p-4" style="background-color: var(--surface-white);">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="ReportID" />
                    <input type="hidden" asp-for="CreatedDate" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="ScheduleID" class="form-label academic-label required">جلسة الامتحان</label>
                            <select asp-for="ScheduleID" asp-items="@(ViewData["ScheduleID"] as SelectList)" class="form-select academic-input">
                                <option value="">-- اختر جلسة الامتحان --</option>
                            </select>
                            <span asp-validation-for="ScheduleID" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label academic-label required">نوع / حالة المحضر</label>
                            <select asp-for="Status" class="form-select academic-input" asp-items="Html.GetEnumSelectList<ReportStatus>()">
                                <option value="">-- اختر نوع المحضر --</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Notes" class="form-label academic-label">ملاحظات وتفاصيل</label>
                            <textarea asp-for="Notes" class="form-control academic-input" rows="4" placeholder="أدخل أي ملاحظات أو تفاصيل إضافية حول المحضر..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top" style="border-color: var(--border-color) !important;">
                        <button type="submit" class="btn btn-academic-primary px-4 fw-bold">
                            <i class="bi bi-check-circle me-1"></i> حفظ التعديلات
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">العودة للقائمة</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}