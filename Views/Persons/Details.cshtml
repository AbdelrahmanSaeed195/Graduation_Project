
@model projectweb.Models.Person
@{
    ViewData["Title"] = "تفاصيل الموظف";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-9">
        <div class="card academic-card shadow-sm">
            <div class="card-header academic-card-header text-white p-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-white"><i class="bi bi-person-vcard-fill me-2"></i> بيانات الملف الشخصي</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-bordered mb-0">
                    <tbody>
                        <tr>
                            <th class="bg-light" style="width: 25%;">الاسم الكامل</th>
                            <td colspan="3" class="fw-bold" style="color: var(--text-main);">@Model.FullName</td>
                        </tr>
                        <tr>
                            <th class="bg-light" style="width: 25%;">الرقم القومي</th>
                            <td style="width: 25%;">@Model.NationalId</td>
                            <th class="bg-light" style="width: 25%;">رقم المحمول</th>
                            <td style="width: 25%;"><span style="color: var(--accent-blue);" class="fw-medium">@Model.Phone</span></td>
                        </tr>
                        <tr>
                            <th class="bg-light" style="width: 25%;">البريد الإلكتروني</th>
                            <td style="width: 25%;">@(Model.Email ?? "غير متوفر")</td>
                            <th class="bg-light" style="width: 25%;">المسمى الوظيفي / الدور</th>
                            <td style="width: 25%;"><span class="badge" style="background-color: var(--bg-light); color: var(--primary-navy); border: 1px solid var(--border-color);">@Html.DisplayFor(m => m.JobRole)</span></td>
                        </tr>
                    </tbody>
                </table>
                <div class="card-footer bg-light p-3 d-flex justify-content-end gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.PersonId" class="btn btn-academic-primary px-4 fw-bold">
                        <i class="bi bi-pencil-square me-1"></i> تعديل البيانات
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.PersonId" class="btn btn-outline-danger px-4">
                        <i class="bi bi-trash ms-2"></i> حذف
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">الرجوع للقائمة</a>
                </div>
            </div>
        </div>
    </div>
</div>
