@model IEnumerable<projectweb.Models.Person>
@using projectweb.Models
@using System.ComponentModel.DataAnnotations
@using System.Reflection

@{
    ViewData["Title"] = "إدارة الموظفين";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h1 class="h3 mb-0 fw-bold academic-heading">
            <i class="bi bi-people-fill me-2"></i> إدارة الأشخاص والموظفين
        </h1>

        <div class="d-flex gap-2">
            <button type="button" class="btn btn-primary shadow-sm text-white" style="background-color: #2e5a88; border: none;" data-bs-toggle="modal" data-bs-target="#assignmentsSummaryModal">
                <i class="bi bi-bar-chart-line-fill me-1"></i> إحصائيات التكليفات
            </button>

            <a asp-action="Create" class="btn btn-academic-primary shadow-sm">
                <i class="bi bi-person-plus-fill me-1"></i> إضافة شخص
            </a>

            <a asp-action="ImportExcel" class="btn btn-outline-success shadow-sm">
                <i class="bi bi-file-earmark-excel-fill me-1"></i> استيراد
            </a>
        </div>
    </div>

    <div class="card academic-card mb-4 shadow-sm border-0">
        <div class="card-body p-3 bg-white rounded">
            <div class="row g-2 align-items-center">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-start-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" id="searchInput" class="form-control academic-input border-end-0"
                               placeholder="ابدأ بالكتابة للبحث بالاسم، الرقم القومي، أو رقم الهاتف..."
                               value="@ViewBag.Search" autocomplete="off">
                    </div>
                </div>
                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">إعادة تعيين</a>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div id="tableContainer" class="card academic-card overflow-hidden shadow-sm border-0">
        <partial name="_PersonTablePartial" model="Model" />
    </div>
</div>