@model IEnumerable<projectweb.Models.Person>

@{
    ViewData["Title"] = "إدارة الموظفين";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl">
    @* الرأس (Header) *@
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h1 class="h3 mb-0 fw-bold academic-heading">
            <i class="bi bi-people-fill me-2"></i> إدارة الأشخاص والموظفين
        </h1>
       
        <div class="d-flex gap-2">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-academic-primary shadow-sm">
                    <i class="bi bi-person-plus-fill me-1"></i> إضافة شخص
                </a>

                <a asp-action="ImportExcel" class="btn btn-outline-success shadow-sm">
                    <i class="bi bi-file-earmark-excel-fill me-1"></i> استيراد
                </a> 

                <a asp-action="ExportToExcel" class="btn btn-outline-primary shadow-sm">
                    <i class="bi bi-file-earmark-arrow-down-fill me-1"></i> تصدير
                </a>
            }
        </div>
    </div>

    @* قسم البحث اللحظي *@
    <div class="card academic-card mb-4 shadow-sm border-0">
        <div class="card-body p-3 bg-white rounded">
            <div class="row g-2 align-items-center">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-start-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        @* تم إضافة id="searchInput" لإمساكه في الجافا سكريبت *@
                        <input type="text" id="searchInput" class="form-control academic-input border-end-0" 
                               placeholder="ابدأ بالكتابة للبحث بالاسم، الرقم القومي، أو رقم الهاتف..." 
                               value="@ViewBag.Search" autocomplete="off">
                    </div>
                </div>
                <div class="col-md-2">
                    @* زر إعادة التعيين يقوم بتصفير البحث *@
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">إعادة تعيين</a>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* حاوية الجدول التي سيتم تحديثها بالـ AJAX *@
    <div id="tableContainer" class="card academic-card overflow-hidden shadow-sm border-0">
        <partial name="_PersonTablePartial" model="Model" />
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            let timeout = null;

            // الاستماع لكل حرف يتم كتابته في مربع البحث
            $('#searchInput').on('input', function () {
                clearTimeout(timeout);
                let searchValue = $(this).val();

                // خاصية الـ Debounce: ننتظر 300 مللي ثانية حتى ينتهي المستخدم من الكتابة
                timeout = setTimeout(function () {
                    $.ajax({
                        url: '@Url.Action("Index", "Persons")',
                        type: 'GET',
                        data: { search: searchValue },
                        beforeSend: function () {
                            // تعتيم الجدول قليلاً لإعطاء إيحاء بالتحميل
                            $('#tableContainer').css('opacity', '0.6');
                        },
                        success: function (data) {
                            // استبدال محتوى حاوية الجدول بالبيانات المفلترة القادمة من السيرفر
                            $('#tableContainer').html(data);
                            $('#tableContainer').css('opacity', '1');
                        },
                        error: function () {
                            console.error("حدث خطأ أثناء محاولة جلب البيانات.");
                            $('#tableContainer').css('opacity', '1');
                        }
                    });
                }, 300); 
            });
        });
    </script>

    <style>
        /* تحسينات بسيطة للمظهر */
        .academic-input:focus {
            border-color: #1a3a5a;
            box-shadow: 0 0 0 0.25rem rgba(26, 58, 90, 0.1);
        }
        .btn-academic-primary {
            background-color: #1a3a5a;
            color: white;
            transition: all 0.3s;
            border: none;
        }
        .btn-academic-primary:hover {
            background-color: #2e5a88;
            color: white;
            transform: translateY(-1px);
        }
        #tableContainer {
            transition: opacity 0.2s ease-in-out;
        }
    </style>
}