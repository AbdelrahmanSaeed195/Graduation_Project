@model IEnumerable<projectweb.Models.Person>
@{
    ViewData["Title"] = "إدارة الموظفين";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold academic-heading"><i class="bi bi-people-fill me-2"></i> إدارة الأشخاص والموظفين</h1>
        <a asp-action="Create" class="btn btn-academic-primary px-4 shadow-sm">
            <i class="bi bi-person-plus-fill me-1"></i> إضافة شخص
        </a>
    </div>

    <div class="card academic-card mb-4 shadow-sm">
        <div class="card-body p-3 bg-white rounded">
            <form method="get" class="row g-3">
                <div class="col-md-9">
                    <input type="text" name="search" class="form-control academic-input" placeholder="ابحث بالاسم أو الرقم القومي .." value="@ViewBag.Search">
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-academic-primary w-100 fw-bold"><i class="bi bi-search me-1"></i> ابحث</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100"><i class="bi bi-arrow-counterclockwise me-1"></i> إعادة تعيين</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card academic-card overflow-hidden shadow-sm">
        <div class="table-responsive">
            <table class="table academic-table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">الاسم الكامل</th>
                        <th>الرقم القومي</th>
                        <th>رقم المحمول</th>
                        <th>الدور/الوظيفة</th>
                        <th class="text-center">الحالة</th>
                        <th class="text-center pe-4">العمليات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var p in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold" style="color: var(--text-main);">@p.FullName</td>
                                <td>@p.NationalId</td>
                                <td><span style="color: var(--accent-blue);" class="fw-medium">@p.Phone</span></td>
                                <td>
                                    <span class="badge px-3 py-2" style="background-color: var(--bg-light); color: var(--primary-navy); border: 1px solid var(--border-color);">
                                        @Html.DisplayFor(modelItem => p.JobRole)
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(p.IsActiveForAssignment ? "bg-success" : "bg-danger") px-3 py-2">
                                        @(p.IsActiveForAssignment ? "نشط" : "متوقف")
                                    </span>
                                </td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Details" asp-route-id="@p.PersonId" class="btn btn-sm btn-outline-info" title="عرض التفاصيل">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@p.PersonId" class="btn btn-sm btn-outline-academic" title="تعديل">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@p.PersonId" class="btn btn-sm btn-outline-danger" title="حذف">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">لا يوجد أشخاص مسجلين.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
