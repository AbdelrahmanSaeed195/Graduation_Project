@model projectweb.Models.Person
@{
    ViewData["Title"] = "حذف موظف";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-8">
        <div class="card academic-card shadow-sm" style="border-color: #dc3545;">
            <div class="card-header bg-danger text-white p-4 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-white"><i class="bi bi-exclamation-triangle-fill me-2"></i> تأكيد الحذف</h5>
            </div>
            <div class="card-body p-4 bg-white">
                <div class="alert alert-danger border-0 mb-4 d-flex align-items-center" style="background-color: #fff5f5; color: #c53030;">
                    <i class="bi bi-exclamation-triangle-fill ms-3 fs-4"></i>
                    <div>
                        <h6 class="fw-bold mb-1">هل أنت متأكد من رغبتك في حذف هذا السجل؟</h6>
                        <p class="mb-0 small">لا يمكن التراجع عن هذا الإجراء بمجرد تنفيذه.</p>
                    </div>
                </div>

                <table class="table table-bordered mb-4">
                    <tbody>
                        <tr>
                            <th class="bg-light" style="width: 25%;">الاسم الكامل</th>
                            <td colspan="3" class="fw-bold" style="color: var(--text-main);">@Model.FullName</td>
                        </tr>
                        <tr>
                            <th class="bg-light" style="width: 25%;">الرقم القومي</th>
                            <td style="width: 25%;">@Model.NationalId</td>
                            <th class="bg-light" style="width: 25%;">رقم المحمول</th>
                            <td style="width: 25%;"><span style="color: var(--accent-blue);" class="fw-medium">@Model.Phone</span></td>
                        </tr>
                        <tr>
                            <th class="bg-light" style="width: 25%;">الدور الوظيفي</th>
                            <td colspan="3"><span class="badge" style="background-color: var(--bg-light); color: var(--primary-navy); border: 1px solid var(--border-color);">@Html.DisplayFor(m => m.JobRole)</span></td>
                        </tr>
                    </tbody>
                </table>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="PersonId" />
                    <div class="d-flex justify-content-end gap-2 border-top pt-3">
                        <button type="submit" class="btn btn-danger px-4 fw-bold shadow-sm">
                            <i class="bi bi-trash me-1"></i> تأكيد الحذف النهائي
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>