@model projectweb.Models.Person
@{
    ViewData["Title"] = "حذف موظف";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool canDelete = ViewBag.CanDelete != false;
}

<div class="container mt-5 text-end" dir="rtl">
    <div class="card mx-auto shadow-lg border-0" style="max-width: 800px; border-radius: 15px;">

        <div class="card-header border-0 p-0"
             style="background: linear-gradient(135deg, @(canDelete ? "#7f1d1d, #dc3545" : "#78350f, #d97706")); border-radius: 15px 15px 0 0;">
            <div class="text-center py-4">
                <h3 class="fw-bold text-white mb-0">
                    <i class="bi @(canDelete ? "bi-trash-fill" : "bi-exclamation-triangle-fill") me-2"></i>
                    @(canDelete ? "تأكيد حذف الموظف" : "لا يمكن حذف السجل")
                </h3>
            </div>
        </div>

        <div class="card-body p-4">

            @if (!canDelete)
            {
                <div class="alert alert-warning d-flex align-items-center gap-3 mb-4">
                    <i class="bi bi-exclamation-octagon-fill fs-4 text-warning"></i>
                    <div>
                        <h6 class="fw-bold mb-1">عفواً، لا يمكن إتمام عملية الحذف حالياً!</h6>
                        <p class="mb-0 small">@ViewBag.Message</p>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-danger d-flex align-items-center gap-3 mb-4">
                    <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                    <div>
                        <h6 class="fw-bold mb-1">هل أنت متأكد من رغبتك في حذف هذا السجل؟</h6>
                        <p class="mb-0 small">لا يمكن التراجع عن هذا الإجراء بمجرد تنفيذه.</p>
                    </div>
                </div>
            }

            <div class="row g-3 mb-4">
                <div class="col-12">
                    <div class="p-3 rounded-3 border bg-white shadow-sm">
                        <label class="text-muted small d-block mb-1">
                            <i class="bi bi-person-fill me-1 text-primary"></i> الاسم الكامل
                        </label>
                        <h5 class="fw-bold mb-0" style="color: #1a3a5a;">@Model.FullName</h5>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="p-3 rounded-3 border bg-white shadow-sm h-100">
                        <label class="text-muted small d-block mb-1">
                            <i class="bi bi-card-text me-1 text-success"></i> الرقم القومي
                        </label>
                        <p class="fw-bold mb-0" style="font-family: 'Courier New', monospace;">@Model.NationalId</p>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="p-3 rounded-3 border bg-white shadow-sm h-100">
                        <label class="text-muted small d-block mb-1">
                            <i class="bi bi-telephone-fill me-1 text-info"></i> رقم المحمول
                        </label>
                        <p class="fw-bold mb-0" style="color: #2a5298;">
                            @(string.IsNullOrEmpty(Model.Phone) ? "غير مسجل" : Model.Phone)
                        </p>
                    </div>
                </div>

                <div class="col-12">
                    <div class="p-3 rounded-3 border bg-white shadow-sm">
                        <label class="text-muted small d-block mb-1">
                            <i class="bi bi-briefcase-fill me-1 text-warning"></i> المسمى الوظيفي
                        </label>
                        <span class="badge px-3 py-2" style="background-color: #e8f0fe; color: #1a3a5a; border: 1px solid #c5d3f0; font-size: 0.9rem;">
                            @Html.DisplayFor(m => m.JobRole)
                        </span>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="PersonId" />
                <div class="card-footer bg-light border-0 d-flex justify-content-center gap-3 py-4"
                     style="border-radius: 0 0 15px 15px; margin: 0 -1.5rem -1.5rem;">
                    @if (canDelete)
                    {
                        <button type="submit" class="btn btn-danger px-5 fw-bold shadow-sm">
                            <i class="bi bi-trash me-1"></i> تأكيد الحذف النهائي
                        </button>
                    }
                    <a asp-action="Index" class="btn btn-outline-dark px-5 fw-bold bg-white shadow-sm">
                        <i class="bi bi-arrow-right-circle me-1"></i>
                        @(canDelete ? "إلغاء" : "العودة للقائمة")
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>
