@model projectweb.Models.Person
@{
    ViewData["Title"] = "إضافة موظف جديد";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 text-end" dir="rtl">
    <div class="card mx-auto shadow-lg border-0" style="max-width: 800px; border-radius: 15px;">

        <div class="card-header border-0 p-0" style="background: linear-gradient(135deg, #1a3a5a, #2a5298); border-radius: 15px 15px 0 0;">
            <div class="text-center py-4">
                <h3 class="fw-bold text-white mb-0">
                    <i class="bi bi-person-plus-fill me-2"></i> إضافة موظف جديد
                </h3>
            </div>
        </div>

        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <input type="hidden" asp-for="RoleId" value="1" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label fw-bold text-muted small">
                            <i class="bi bi-person-fill me-1 text-primary"></i> الاسم الكامل
                        </label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="NationalId" class="form-label fw-bold text-muted small">
                            <i class="bi bi-card-text me-1 text-success"></i> الرقم القومي
                        </label>
                        <input asp-for="NationalId" class="form-control" maxlength="14" />
                        <span asp-validation-for="NationalId" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label fw-bold text-muted small">
                            <i class="bi bi-telephone-fill me-1 text-info"></i> رقم المحمول
                        </label>
                        <input asp-for="Phone" class="form-control" maxlength="11" />
                        <span asp-validation-for="Phone" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="JobRole" class="form-label fw-bold text-muted small">
                            <i class="bi bi-briefcase-fill me-1 text-warning"></i> الدور أو الوظيفة
                        </label>
                        <select asp-for="JobRole" asp-items="Html.GetEnumSelectList<projectweb.Models.JobTitle>()" class="form-select">
                            <option value="">-- اختر الوظيفة --</option>
                        </select>
                        <span asp-validation-for="JobRole" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="card-footer bg-light border-0 d-flex justify-content-center gap-3 py-4 mt-4"
                     style="border-radius: 0 0 15px 15px; margin: 0 -1.5rem -1.5rem;">
                    <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm">
                        <i class="bi bi-check-circle me-1"></i> حفظ البيانات
                    </button>
                    <a asp-action="Index" class="btn btn-outline-dark px-5 fw-bold bg-white shadow-sm">
                        <i class="bi bi-arrow-right-circle me-1"></i> إلغاء
                    </a>
                </div>
            </form>
        </div>

    </div>
</div>
