
@model projectweb.Models.Person
@{
    ViewData["Title"] = "إضافة شخص جديد";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-8">
        <div class="card academic-card">
            <div class="card-header academic-card-header text-white p-4">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-person-plus-fill me-2"></i> إضافة شخص جديد</h4>
            </div>
            <div class="card-body p-4 bg-white">
                <form asp-action="Create" method="post">
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label academic-label required">الاسم الكامل</label>
                            <input asp-for="FullName" class="form-control academic-input" />
                            <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NationalId" class="form-label academic-label required">الرقم القومي</label>
                            <input asp-for="NationalId" class="form-control academic-input" maxlength="14" />
                            <span asp-validation-for="NationalId" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label academic-label required">رقم المحمول</label>
                            <input asp-for="Phone" class="form-control academic-input" maxlength="11" />
                            <span asp-validation-for="Phone" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label academic-label required">البريد الإلكتروني</label>
                            <input asp-for="Email" class="form-control academic-input" />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="JobRole" class="form-label academic-label required">الدور أو الوظيفة</label>
                            <select asp-for="JobRole" asp-items="Html.GetEnumSelectList<projectweb.Models.JobTitle>()" class="form-select academic-input"></select>
                            <span asp-validation-for="JobRole" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <input type="hidden" asp-for="RoleID" value="1" />
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top" style="border-color: var(--border-color) !important;">
                        <button type="submit" class="btn btn-academic-primary px-4 fw-bold">
                            <i class="bi bi-check-circle me-1"></i> حفظ البيانات
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
