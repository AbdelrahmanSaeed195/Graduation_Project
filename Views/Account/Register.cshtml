@model projectweb.ViewModel.RegisterViewModel

@{
    ViewData["Title"] = "إنشاء حساب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-shell d-flex justify-content-center align-items-center min-vh-100" style="background-color: #f4f7f6;">
    <div class="card academic-card shadow-lg border-0" style="max-width: 500px; width: 100%; border-radius: 15px; overflow: hidden;">

        <div class="card-header text-white text-center py-4" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%);">
            <h4 class="mb-1 fw-bold text-white">إنشاء حساب جديد</h4>
            <p class="mb-0 small opacity-75">نظام إدارة لجان الامتحانات</p>
        </div>

        <div class="card-body p-4 p-md-5" style="background-color: #ffffff;">
            <form asp-action="Register" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-4 text-center fw-bold"></div>

                <div class="row g-4">
                    <div class="col-12">
                        <label asp-for="FullName" class="form-label fw-bold small text-secondary">الاسم الكامل</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-muted"></i></span>
                            <input asp-for="FullName" class="form-control border-start-0 academic-input" placeholder="أدخل اسمك الثلاثي" style="background-color: #fcfcfc;" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger" style="font-size: 0.75rem;"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="PhoneNumber" class="form-label fw-bold small text-secondary">رقم الهاتف</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-phone text-muted"></i></span>
                            <input asp-for="PhoneNumber" class="form-control border-start-0 academic-input" placeholder="01XXXXXXXXX" style="background-color: #fcfcfc;" />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger" style="font-size: 0.75rem;"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Email" class="form-label fw-bold small text-secondary">البريد الإلكتروني</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                            <input asp-for="Email" class="form-control border-start-0 academic-input" placeholder="name@example.com" style="background-color: #fcfcfc;" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger" style="font-size: 0.75rem;"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Password" class="form-label fw-bold small text-secondary">كلمة المرور</label>
                        <div class="input-group shadow-sm-hover">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                            <input asp-for="Password" type="password" class="form-control border-start-0 border-end-0 academic-input" id="Password" placeholder="كلمة المرور" style="background-color: #fcfcfc;" />
                            <button type="button" class="btn btn-light border border-start-0 text-muted" onclick="togglePass('Password', 'eyeIcon1')">
                                <i id="eyeIcon1" class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger" style="font-size: 0.75rem;"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="ConfirmPassword" class="form-label fw-bold small text-secondary">تأكيد كلمة المرور</label>
                        <div class="input-group shadow-sm-hover">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-check text-muted"></i></span>
                            <input asp-for="ConfirmPassword" type="password" class="form-control border-start-0 border-end-0 academic-input" id="ConfirmPassword" placeholder="تأكيد كلمة المرور" style="background-color: #fcfcfc;" />
                            <button type="button" class="btn btn-light border border-start-0 text-muted" onclick="togglePass('ConfirmPassword', 'eyeIcon2')">
                                <i id="eyeIcon2" class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size: 0.75rem;"></span>
                    </div>
                </div>

                <div class="d-grid mt-5">
                    <button type="submit" class="btn btn-primary py-2 fw-bold shadow" style="background-color: #1a3a5a; border: none; border-radius: 8px;">
                        <i class="bi bi-person-plus me-2"></i> إنشاء حساب جديد
                    </button>
                </div>

                <div class="text-center mt-4">
                    <p class="small text-muted">
                        لديك حساب بالفعل؟ <a asp-action="Login" class="fw-bold text-decoration-none" style="color: #2e5a88;">تسجيل الدخول</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .academic-input:focus {
        border-color: #2e5a88;
        box-shadow: none;
        background-color: #fff !important;
    }

    .input-group-text {
        border-radius: 8px 0 0 8px !important;
    }

    .academic-input {
        border-radius: 0 8px 8px 0 !important;
    }

    .btn-light {
        border-radius: 0 8px 8px 0 !important;
        border-color: #dee2e6;
    }

    [dir="rtl"] .input-group-text {
        border-radius: 0 8px 8px 0 !important;
        border-left: 0;
    }

    [dir="rtl"] .academic-input {
        border-radius: 8px 0 0 8px !important;
    }

    [dir="rtl"] .btn-light {
        border-radius: 8px 0 0 8px !important;
        border-right: 0;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePass(inputId, iconId) {
            var input = document.getElementById(inputId);
            var icon = document.getElementById(iconId);

            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
    </script>
}