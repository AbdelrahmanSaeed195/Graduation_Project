@model projectweb.ViewModel.LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-shell d-flex justify-content-center align-items-center min-vh-100" style="background-color: #f4f7f6;">

    <div class="card academic-card shadow-lg border-0" style="max-width: 460px; width: 100%; border-radius: 15px; overflow: hidden;">

        <div class="card-header text-white text-center py-4" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%);">
            <h4 class="mb-1 fw-bold text-white">تسجيل الدخول</h4>
            <p class="mb-0 small opacity-75">منصة إدارة لجان الامتحانات الجامعية</p>
        </div>

        <div class="card-body p-4 p-md-5">

            <form asp-action="Login" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center fw-bold"></div>

                <!-- Email -->
                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold small text-secondary">البريد الإلكتروني</label>
                    <input asp-for="Email" class="form-control academic-input" placeholder="example@email.com" type="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <!-- Password -->
                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-bold small text-secondary">كلمة المرور</label>

                    <div class="input-group">
                        <button type="button" class="btn btn-light border" onclick="togglePass()">
                            <i id="eyeIcon" class="bi bi-eye"></i>
                        </button>

                        <input asp-for="Password" type="password" class="form-control academic-input" id="passInput" placeholder="أدخل كلمة المرور" />

                        <span class="input-group-text bg-light">
                            <i class="bi bi-lock text-muted"></i>
                        </span>
                    </div>

                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <!-- Remember Me -->
                <div class="form-check mb-3">
                    <input asp-for="IsPrisist" class="form-check-input" />
                    <label asp-for="IsPrisist" class="form-check-label small text-muted">
                        تذكرني
                    </label>
                </div>

                <!-- Login Button -->
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary fw-bold py-2" style="background:#1a3a5a; border:none;">
                        دخول
                    </button>
                </div>

                <!-- Forgot Password -->
                <div class="text-center mt-3">
                    <a asp-action="ForgotPassword" asp-controller="Account"
                       class="small text-decoration-none fw-bold"
                       style="color:#2e5a88;">
                        نسيت كلمة المرور؟
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>

<style>
    .academic-input:focus {
        border-color: #2e5a88;
        box-shadow: none;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePass() {
            var input = document.getElementById('passInput');
            var icon = document.getElementById('eyeIcon');

            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
    </script>
}