@{
    ViewData["Title"] = "لوحة التحكم الرئيسية";
}

<div class="container py-5" dir="rtl">
   
    <div class="text-center mb-5">
        <h2 class="fw-bold text-navy">بوابة الإدارة المركزية</h2>
        <p class="text-muted">نظام إدارة لجان الامتحانات وتوزيع المراقبين</p>
        <div class="d-flex justify-content-center">
            <hr class="section-divider" style="width: 100px; height: 3px; background-color: var(--primary-navy); opacity: 1; border: none; border-radius: 5px;">
        </div>
    </div>

    <!-- القسم الأول: إدارة شؤون الأفراد -->
    <h4 class="mb-3 fw-bold text-navy border-bottom pb-2">
       إدارة شؤون الأفراد
    </h4>
    <div class="row g-4 mb-5">
        <!-- الموظفين -->
        <div class="col-md-6 col-lg-4">
            <div class="card dash-card text-center p-4 h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary mx-auto mb-3"><i class="bi bi-person-badge-fill fs-1"></i></div>
                    <h5 class="card-title fw-bold text-navy">إدارة الموظفين</h5>
                    <p class="text-muted small mb-4 flex-grow-1">تسجيل بيانات أعضاء هيئة التدريس والمراقبين وتحديد تخصصاتهم.</p>
                    <a asp-controller="Persons" asp-action="Index" class="btn btn-academic-primary btn-enter mt-auto">دخول النظام</a>
                </div>
            </div>
        </div>
        <!-- الطلاب -->
        <div class="col-md-6 col-lg-4">
            <div class="card dash-card text-center p-4 h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="icon-box bg-success bg-opacity-10 text-success mx-auto mb-3"><i class="bi bi-mortarboard-fill fs-1"></i></div>
                    <h5 class="card-title fw-bold text-navy">إدارة الطلاب</h5>
                    <p class="text-muted small mb-4 flex-grow-1">إضافة وتعديل بيانات الطلاب، أرقام الجلوس، والمستويات الدراسية.</p>
                    <a asp-controller="Students" asp-action="Index" class="btn btn-academic-primary btn-enter mt-auto">دخول النظام</a>
                </div>
            </div>
        </div>
        <!-- الأقارب -->
        <div class="col-md-6 col-lg-4">
            <div class="card dash-card text-center p-4 h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="icon-box bg-warning bg-opacity-10 text-warning mx-auto mb-3"><i class="bi bi-diagram-2-fill fs-1"></i></div>
                    <h5 class="card-title fw-bold text-navy">صلات القرابة</h5>
                    <p class="text-muted small mb-4 flex-grow-1">إدارة قواعد منع المراقبة بناءً على صلات القرابة بين الموظف والطالب.</p>
                    <a asp-controller="Relatives" asp-action="Index" class="btn btn-academic-primary btn-enter mt-auto">دخول النظام</a>
                </div>
            </div>
        </div>
    </div>

    <!-- القسم الثاني: إعداد الامتحان -->
    <h4 class="mb-3 fw-bold text-navy border-bottom pb-2">
      إعداد الامتحان
    </h4>
    <div class="row g-4 mb-5">
        <!-- القاعات -->
        <div class="col-md-6 col-lg-4">
            <div class="card dash-card text-center p-4 h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="icon-box bg-info bg-opacity-10 text-info mx-auto mb-3"><i class="bi bi-building-fill fs-1"></i></div>
                    <h5 class="card-title fw-bold text-navy">إدارة القاعات</h5>
                    <p class="text-muted small mb-4 flex-grow-1">تعريف القاعات والمدرجات، تحديد السعة الاستيعابية لكل قاعة.</p>
                    <a asp-controller="Halls" asp-action="Index" class="btn btn-academic-primary btn-enter mt-auto">دخول النظام</a>
                </div>
            </div>
        </div>
        <!-- الأقسام / المجموعات -->
        <div class="col-md-6 col-lg-4">
            <div class="card dash-card text-center p-4 h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="icon-box bg-secondary bg-opacity-10 text-secondary mx-auto mb-3"><i class="bi bi-collection-fill fs-1"></i></div>
                    <h5 class="card-title fw-bold text-navy">إدارة الأقسام (Blocks)</h5>
                    <p class="text-muted small mb-4 flex-grow-1">تقسيم اللجان إلى مجموعات لتسهيل عملية التوزيع الجغرافي.</p>
                    <a asp-controller="Blocks" asp-action="Index" class="btn btn-academic-primary btn-enter mt-auto">دخول النظام</a>
                </div>
            </div>
        </div>
        <!-- اللجان -->
        <div class="col-md-6 col-lg-4">
            <div class="card dash-card text-center p-4 h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="icon-box bg-danger bg-opacity-10 text-danger mx-auto mb-3"><i class="bi bi-clipboard-check-fill fs-1"></i></div>
                    <h5 class="card-title fw-bold text-navy">إدارة اللجان</h5>
                    <p class="text-muted small mb-4 flex-grow-1">إنشاء لجان الامتحانات وربطها بالقاعات وتوزيع الطلاب عليها.</p>
                    <a asp-controller="Committees" asp-action="Index" class="btn btn-academic-primary btn-enter mt-auto">دخول النظام</a>
                </div>
            </div>
        </div>
        <!-- الامتحانات -->
        <div class="col-md-6 col-lg-4">
            <div class="card dash-card text-center p-4 h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="icon-box bg-dark bg-opacity-10 text-dark mx-auto mb-3"><i class="bi bi-journal-text fs-1"></i></div>
                    <h5 class="card-title fw-bold text-navy">إدارة الامتحانات</h5>
                    <p class="text-muted small mb-4 flex-grow-1">تحديد الفترات الزمنية للامتحانات العامة وإعداداتها الرئيسية.</p>
                    <a asp-controller="Exams" asp-action="Index" class="btn btn-academic-primary btn-enter mt-auto">دخول النظام</a>
                </div>
            </div>
        </div>
        <!-- المواد الدراسية (جديد) -->
        <div class="col-md-6 col-lg-4">
            <div class="card dash-card text-center p-4 h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="icon-box mx-auto mb-3" style="background-color: rgba(111, 66, 193, 0.1); color: #6f42c1;"><i class="bi bi-book-half fs-1"></i></div>
                    <h5 class="card-title fw-bold text-navy">المواد الدراسية</h5>
                    <p class="text-muted small mb-4 flex-grow-1">تسجيل المقررات الدراسية وتخصيصها للأقسام والمستويات المختلفة.</p>
                    <a asp-controller="Subjects" asp-action="Index" class="btn btn-academic-primary btn-enter mt-auto">دخول النظام</a>
                </div>
            </div>
        </div>
        <!-- مواعيد الامتحانات (جديد) -->
        <div class="col-md-6 col-lg-4">
            <div class="card dash-card text-center p-4 h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="icon-box mx-auto mb-3" style="background-color: rgba(32, 201, 151, 0.1); color: #20c997;">
                        <i class="bi bi-calendar-event-fill fs-1"></i>
                    </div>
                    <h5 class="card-title fw-bold text-navy">جدولة جلسات الامتحانات</h5>
                    <p class="text-muted small mb-4 flex-grow-1">تنظيم مواعيد الامتحانات وتسكينها داخل اللجان والقاعات المخصصة.</p>
                    <a asp-controller="ExamSchedules" asp-action="Index" class="btn btn-academic-primary btn-enter mt-auto">دخول النظام</a>
                </div>
            </div>
        </div>
    </div>

    <!-- القسم الثالث: التوزيعات والتقارير -->
    <h4 class="mb-3 fw-bold text-navy border-bottom pb-2">
        العمليات والنتائج
    </h4>
    <div class="row g-4">
        <!-- التوزيع الذكي -->
        <div class="col-md-6 col-lg-6">
            <div class="card dash-card text-center p-4 h-100 shadow-sm border-0" style="background: linear-gradient(145deg, var(--surface-white), #f0f4f8);">
                <div class="card-body d-flex flex-column">
                    <div class="icon-box mx-auto mb-3" style="background-color: var(--primary-navy); color: var(--surface-white);"><i class="bi bi-cpu-fill fs-1"></i></div>
                    <h5 class="card-title fw-bold text-navy">التوزيعات (التوزيع الذكي)</h5>
                    <p class="text-muted small mb-4 flex-grow-1">خوارزمية التوزيع التلقائي للمراقبين على اللجان مع مراعاة موانع القرابة والقواعد المنظمة.</p>
                    <a asp-controller="CommitteesAssignments" asp-action="Index" class="btn btn-outline-academic btn-enter fw-bold border-2 mt-auto">بدء التوزيع</a>
                </div>
            </div>
        </div>
        <!-- التقارير -->
        <div class="col-md-6 col-lg-6">
            <div class="card dash-card text-center p-4 h-100 shadow-sm border-0" style="background: linear-gradient(145deg, var(--surface-white), #f9f9f9);">
                <div class="card-body d-flex flex-column">
                    <div class="icon-box mx-auto mb-3" style="background-color: var(--bg-light); color: var(--primary-navy); border: 2px solid var(--primary-navy);"><i class="bi bi-bar-chart-fill fs-1"></i></div>
                    <h5 class="card-title fw-bold text-navy">مركز التقارير</h5>
                    <p class="text-muted small mb-4 flex-grow-1">توليد كشوفات الندب، كشوف حضور الطلاب، وجداول المراقبة النهائية للطباعة والتصدير.</p>
                    <a asp-controller="Reports" asp-action="Index" class="btn btn-outline-academic btn-enter border-2 mt-auto">عرض التقارير</a>
                </div>
            </div>
        </div>
    </div>
</div>