@model projectweb.Models.ExamLocation
@using System.ComponentModel.DataAnnotations
@using System.Reflection
@using projectweb.Models

@{
    ViewData["Title"] = "تعديل بيانات المكان";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dependency-field {
        display: none;
    }
</style>

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-9">
        <div class="card academic-card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
            <div class="card-header text-white p-4" style="background-color: #1a2c4e;">
                <h4 class="mb-0 fw-bold">
                    <i class="bi bi-pencil-square me-2"></i> تعديل بيانات الكيان: @Model.LocationName
                </h4>
            </div>

            <div class="card-body p-4 bg-white">

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="LocationId" />
                    <input type="hidden" asp-for="Type" id="locationTypeHidden" />

                    <div class="row g-4 mb-4">

                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted">نوع الكيان</label>
                            <input class="form-control bg-light fw-bold text-center"
                                   value="@ViewBag.TypeDisplayName"
                                   readonly />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="LocationName" class="form-label fw-bold">
                                اسم / رقم المكان <span class="text-danger">*</span>
                            </label>
                            <input asp-for="LocationName"
                                   class="form-control shadow-sm"
                                   style="border-radius: 8px;" />
                            <span asp-validation-for="LocationName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 dependency-field parent-location-container">
                            <label asp-for="ParentLocationId" class="form-label fw-bold">
                                المكان الرئيسي التابع له
                            </label>
                            <select asp-for="ParentLocationId"
                                    id="parentLocationSelect"
                                    class="form-select shadow-sm"
                                    style="border-radius: 8px;">
                                <option value="" disabled>-- اختر الأب التراتبي --</option>
                            </select>
                            <span asp-validation-for="ParentLocationId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-3 dependency-field hall-fields">
                            <label asp-for="Floor" class="form-label fw-bold">رقم الدور</label>
                            <input asp-for="Floor"
                                   type="number"
                                   class="form-control text-center shadow-sm"
                                   style="border-radius: 8px;" />
                        </div>

                        <div class="col-md-6 dependency-field capacity-fields">
                            <label asp-for="MaxSubLocations"
                                   id="maxSubLabel"
                                   class="form-label fw-bold">
                                الحد الأقصى للتفريعات
                            </label>
                            <input asp-for="MaxSubLocations"
                                   type="number"
                                   class="form-control text-center shadow-sm"
                                   style="border-radius: 8px;" />
                        </div>

                        <div class="col-md-3 dependency-field committee-fields">
                            <label asp-for="StudentCapacity" class="form-label fw-bold">سعة الطلاب</label>
                            <input asp-for="StudentCapacity"
                                   type="number"
                                   class="form-control text-center shadow-sm"
                                   style="border-radius: 8px;" />
                        </div>

                        <div class="col-md-3">
                            <label asp-for="Status" class="form-label fw-bold">الحالة الإدارية</label>
                            <select asp-for="Status"
                                    asp-items="ViewBag.StatusList"
                                    class="form-select shadow-sm"
                                    style="border-radius: 8px;">
                                <option value="">-- اختر الحالة --</option>
                            </select>
                        </div>

                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top">
                        <button type="submit"
                                class="btn text-white px-5 fw-bold"
                                style="background-color: #1a2c4e; border-radius: 8px;">
                            <i class="bi bi-save me-1"></i> تحديث وحفظ البيانات
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-arrow-right me-1"></i> رجوع
                        </a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            // استلام متغيرات قاعدة البيانات الشجرية بالكامل برمجياً
            var allLocations = @Html.Raw(ViewBag.AllLocationsJson ?? "[]");
            var currentType = @((int)Model.Type);
            var currentParentId = '@Model.ParentLocationId';

            var locationSelect = $('#LocationSelect');
            var parentSelect = $('#ParentLocationId');

            // دالة الفحص المركب لتعديل الحقول والمسميات ديناميكياً حسب تدرج الكيان المحدث
            function adjustFieldsByLocationType(typeId) {
                $('.dependency-field').hide();

                if (typeId === 1) { // 1. حالة الجراش (Hall)
                    $('.hall-fields').show();
                    $('.capacity-fields').show();
                    $('#maxSubLabel').text('أقصى عدد صفوف داخل الجراش');
                }
                else if (typeId === 2) { // 2. حالة الصف (Row)
                    $('.parent-location-container').show();
                    $('.capacity-fields').show();
                    $('#maxSubLabel').text('أقصى عدد صالات داخل الصف');

                    // شحن آباء الجراشات (Type == 1)
                    var halls = allLocations.filter(function(l) { return l.Type === 1; });
                    fillParentDropdown(halls, "جراش");
                }
                else if (typeId === 3) { // 3. حالة الصالة (Block)
                    $('.parent-location-container').show();
                    $('.capacity-fields').show();
                    $('#maxSubLabel').text('أقصى عدد لجان داخل الصالة');

                    // شحن آباء الصفوف (Type == 2)
                    var rows = allLocations.filter(function(l) { return l.Type === 2; });
                    fillParentDropdown(rows, "صف");
                }
                else if (typeId === 4) { // 4. حالة اللجنة (Committee)
                    $('.parent-location-container').show();
                    $('.committee-fields').show();

                    // شحن آباء الصالات (Type == 3)
                    var blocks = allLocations.filter(function(l) { return l.Type === 3; });
                    fillParentDropdown(blocks, "صالة");
                }
            }

            function fillParentDropdown(items, typeLabel) {
                var selectElement = $('#parentLocationSelect');
                selectElement.empty().append('<option value="" disabled>-- اختر الأب التراتبي --</option>');

                items.forEach(function (l) {
                    // منع إسناد المكان لنفسه حماية للشجرة من التكرار اللانهائي
                    if(l.LocationId != '@Model.LocationId') {
                        var isSelected = (l.LocationId == currentParentId) ? "selected" : "";
                        selectElement.append(
                            `<option value="${l.LocationId}" ${isSelected}>${typeLabel}: ${l.LocationName}</option>`
                        );
                    }
                });
            }

            // تشغيل تهيئة الحقول الفورية بمجرد تحميل الصفحة للتعديل
            adjustFieldsByLocationType(currentType);
        });
    </script>
}