@model projectweb.Models.ExamLocation

@{
    ViewData["Title"] = "لوحة تفاصيل المكان";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var examSchedules = ViewBag.ExamSchedules as IEnumerable<projectweb.Models.ExamSchedule>;
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-11">
        <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header p-4 d-flex justify-content-between align-items-center" style="background-color: #1a3a5a;">
                <h4 class="mb-0 fw-bold text-white">
                    <i class="bi bi-info-square ms-2"></i> بطاقة معلومات الكيان: @Model.LocationName
                </h4>
                <span class="badge bg-white text-dark fw-bold px-3 py-2">المعرف: #@Model.LocationId</span>
            </div>

            <div class="card-body p-4 bg-light">
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="p-3 bg-white rounded shadow-sm border-start border-primary border-4 h-100">
                            <div class="small text-muted mb-1">التبعية والمسار</div>
                            <div class="fw-bold text-dark fs-6">
                                @(Model.ParentLocation != null ? $"{Model.ParentLocation.LocationName} ⬅️ {Model.LocationName}" : "جذر رئيسي")
                            </div>
                        </div>
                    </div>

                    @if (Model.Floor > 0)
                    {
                        <div class="col-md-4">
                            <div class="p-3 bg-white rounded shadow-sm border-start border-info border-4 h-100">
                                <div class="small text-muted mb-1">الموقع الفعلي</div>
                                <div class="fw-bold text-dark fs-5">الدور: @Model.Floor</div>
                            </div>
                        </div>
                    }

                    <div class="col-md-4">
                        <div class="p-3 bg-white rounded shadow-sm border-start border-warning border-4 h-100">
                            <div class="small text-muted mb-1">السعة التشغيلية</div>
                            <div class="fw-bold text-dark fs-6">
                                @(Model.Type == LocationType.Committee ? $"{Model.StudentCapacity} مقعد طالب" : $"{Model.MaxSubLocations} وحدة فرعية")
                            </div>
                        </div>
                    </div>
                </div>

                <h5 class="fw-bold pb-2 mb-3 border-bottom text-secondary" style="font-size: 1.1rem;">
                    <i class="bi bi-calendar-event-fill ms-2 text-primary"></i> الجدولة الامتحانية
                </h5>

                @if (examSchedules != null && examSchedules.Any())
                {
                    <div class="table-responsive rounded border bg-white shadow-sm mb-4">
                        <table class="table table-hover align-middle mb-0 text-center">
                            <thead class="table-light">
                                <tr>
                                    <th>المادة الدراسية</th>
                                    <th>تاريخ الامتحان</th>
                                    <th>الفترة الزمنية</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var schedule in examSchedules)
                                {
                                    <tr>
                                        <td class="fw-bold text-dark">@schedule.Exam?.Subject?.SubjectName</td>
                                        <td>@schedule.Exam?.ExamDate.ToString("yyyy/MM/dd")</td>
                                        <td class="fw-bold text-danger">@schedule.Exam?.StartTime.ToString(@"hh\:mm") - @schedule.Exam?.EndTime.ToString(@"hh\:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-white border text-center text-muted p-4 mb-0" style="border-radius: 10px;">
                        <i class="bi bi-calendar-x fs-2 d-block mb-2 text-warning"></i>
                        لا توجد بيانات مجدولة حالياً لهذا المكان.
                    </div>
                }
            </div>

            <div class="card-footer bg-white p-3 d-flex justify-content-start gap-2 border-top">
                <a asp-action="Edit" asp-route-id="@Model.LocationId" class="btn text-white px-4 fw-bold shadow-sm" style="background-color: #1a3a5a;">
                    <i class="bi bi-pencil-square ms-1"></i> تعديل البيانات
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold shadow-sm">العودة للقائمة</a>
            </div>
        </div>
    </div>
</div>