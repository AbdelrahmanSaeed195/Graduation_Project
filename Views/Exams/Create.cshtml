@model projectweb.Models.Exam

@{
    ViewData["Title"] = "إضافة امتحان جديد";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-8">
        <div class="card academic-card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
            <div class="card-header academic-card-header text-white p-4" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%); border: none;">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-plus-square-fill me-2"></i> إضافة امتحان جديد</h4>
            </div>
            <div class="card-body p-4" style="background-color: #ffffff;">

                <div id="timeError" class="alert alert-danger border-0 shadow-sm mb-4" style="display:none; border-radius: 10px;">
                    <i class="bi bi-exclamation-triangle-fill me-2 text-danger"></i>
                    <span id="timeErrorMessage" class="fw-bold"></span>
                </div>

                <form asp-action="Create" method="post" id="examForm">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3 border-0 shadow-sm" style="border-radius: 8px;"></div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="SubjectID" class="form-label fw-bold" style="color: #4a5568;">المادة الدراسية <span class="text-danger">*</span></label>
                            <select asp-for="SubjectID" id="SubjectSelect" asp-items="@(ViewBag.SubjectID)" class="form-select border-light-subtle shadow-sm academic-input" style="border-radius: 8px;">
                                <option value="">-- اختر المادة --</option>
                            </select>
                            <span asp-validation-for="SubjectID" class="text-danger small mt-1 d-block fw-bold"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">السنة الدراسية <span class="text-muted small">(تُجلب تلقائياً)</span></label>
                            <input type="text"
                                   id="AcademicYearField"
                                   class="form-control bg-light shadow-sm fw-bold text-navy"
                                   readonly
                                   style="border-radius: 8px;"
                                   placeholder="بانتظار اختيار المادة..."
                                   value="@Model?.AcademicYear" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ExamDate" class="form-label fw-bold" style="color: #4a5568;">تاريخ الامتحان <span class="text-danger">*</span></label>
                            <input asp-for="ExamDate" id="ExamDate" class="form-control border-light-subtle shadow-sm academic-input" type="date" style="border-radius: 8px;" />
                            <span asp-validation-for="ExamDate" class="text-danger small mt-1 d-block fw-bold"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="StartTime" class="form-label fw-bold" style="color: #4a5568;">وقت البدء <span class="text-danger">*</span></label>
                            <input asp-for="StartTime" id="StartTime" class="form-control border-light-subtle shadow-sm text-center fw-bold academic-input" type="time" style="border-radius: 8px;" />
                            <span asp-validation-for="StartTime" class="text-danger small mt-1 d-block fw-bold"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="EndTime" class="form-label fw-bold" style="color: #4a5568;">وقت الانتهاء <span class="text-danger">*</span></label>
                            <input asp-for="EndTime" id="EndTime" class="form-control border-light-subtle shadow-sm text-center fw-bold academic-input" type="time" style="border-radius: 8px;" />
                            <span asp-validation-for="EndTime" class="text-danger small mt-1 d-block fw-bold"></span>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top">
                        <button type="submit" id="submitBtn" class="btn btn-academic-primary px-5 fw-bold shadow-sm py-2">
                            <i class="bi bi-check-circle me-1"></i> حفظ الامتحان
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 shadow-sm py-2 border-0">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            $('#SubjectSelect').on('change', function () {
                var subjectId = $(this).val();
                var $yearField = $('#AcademicYearField');

                if (subjectId) {
                    $.ajax({
                        url: '@Url.Action("GetSubjectYear", "Exams")',
                        type: 'GET',
                        data: { subjectId: subjectId },
                        success: function (data) {
                            if (data && data.academicYear) {
                                $yearField.val(data.academicYear);
                            } else {
                                $yearField.val('غير محددة');
                            }
                        },
                        error: function() {
                            $yearField.val('خطأ في الاتصال');
                        }
                    });
                } else {
                    $yearField.val('');
                }
            });

            function checkConstraints() {
                var date = $('#ExamDate').val();
                var start = $('#StartTime').val();
                var end = $('#EndTime').val();
                var errorDiv = $('#timeError');
                var errorMessage = $('#timeErrorMessage');
                var submitBtn = $('#submitBtn');

                if (date && start && end) {
                    var startTime = new Date("1970-01-01T" + start);
                    var endTime = new Date("1970-01-01T" + end);
                    var diffMinutes = (endTime - startTime) / (1000 * 60);

                    if (diffMinutes <= 0) {
                        errorMessage.text("خطأ: يجب أن يكون وقت انتهاء الامتحان بعد وقت البدء.");
                        errorDiv.show();
                        submitBtn.prop('disabled', true);
                        return;
                    }

                    if (diffMinutes > 180) {
                        errorMessage.text("عفواً، لا يمكن أن تتجاوز مدة الامتحان 3 ساعات.");
                        errorDiv.show();
                        submitBtn.prop('disabled', true);
                        return;
                    }

                    $.get('@Url.Action("CheckConstraints", "Exams")', { date: date, start: start, end: end }, function (data) {
                        if (data.isOverlapping) {
                            errorMessage.text("تنبيه: يوجد امتحان آخر مسجل في نفس هذا الموعد والتاريخ.");
                            errorDiv.show();
                            submitBtn.prop('disabled', true);
                        } else {
                            errorDiv.hide();
                            submitBtn.prop('disabled', false);
                        }
                    });
                }
            }

            $('#ExamDate, #StartTime, #EndTime').on('change', checkConstraints);

            // منع الإرسال إذا كانت البيانات غير منطقية
            $('#examForm').on('submit', function (e) {
                var start = $('#StartTime').val();
                var end = $('#EndTime').val();
                if (start && end) {
                    var st = new Date("1970-01-01T" + start);
                    var et = new Date("1970-01-01T" + end);
                    var duration = (et - st) / (1000 * 60);
                    if (duration > 180 || duration <= 0) {
                        e.preventDefault();
                        alert("يرجى تصحيح الوقت قبل الحفظ.");
                    }
                }
            });
        });
    </script>

    <style>
        .text-navy {
            color: #1a3a5a;
        }

        .academic-input:focus {
            border-color: #1a3a5a;
            box-shadow: 0 0 0 0.25rem rgba(26, 58, 90, 0.1);
        }

        .btn-academic-primary {
            background-color: #1a3a5a;
            color: white;
            border-radius: 8px;
            transition: all 0.3s;
        }

            .btn-academic-primary:hover {
                background-color: #2e5a88;
                transform: translateY(-2px);
            }

            .btn-academic-primary:disabled {
                background-color: #6c757d;
                cursor: not-allowed;
                transform: none;
            }
    </style>
}