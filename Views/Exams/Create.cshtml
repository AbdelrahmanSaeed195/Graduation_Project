@model projectweb.Models.Exam

@{
    ViewData["Title"] = "إضافة امتحان جديد";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-8">
        <div class="card academic-card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
            <div class="card-header academic-card-header text-white p-4" style="background-color: #1a2c4e;">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-plus-square-fill me-2"></i> إضافة امتحان جديد</h4>
            </div>
            <div class="card-body p-4" style="background-color: #ffffff;">

                <!-- رسالة تنبيه لخطأ الوقت أو التداخل تظهر وتختفي ديناميكياً -->
                <div id="timeError" class="alert alert-danger border-0 shadow-sm mb-4" style="display:none;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <span id="timeErrorMessage"></span>
                </div>

                <form asp-action="Create" method="post" id="examForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="SubjectID" class="form-label fw-bold" style="color: #4a5568;">المادة الدراسية <span class="text-danger">*</span></label>
                            <select asp-for="SubjectID" id="SubjectSelect" asp-items="@(ViewBag.SubjectID)" class="form-select border-light-subtle shadow-sm" style="border-radius: 8px;">
                                <option value="">-- اختر المادة --</option>
                            </select>
                            <span asp-validation-for="SubjectID" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TargetAcademicYear" class="form-label fw-bold" style="color: #4a5568;">السنة الدراسية <span class="text-muted small">(تُجلب تلقائياً)</span></label>
                            <input asp-for="TargetAcademicYear" id="AcademicYearField" class="form-control bg-light shadow-sm" readonly style="border-radius: 8px;" placeholder="سيتم تحديد السنة بناءً على المادة" />
                            <span asp-validation-for="TargetAcademicYear" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-12">
                            <hr />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ExamDate" class="form-label fw-bold" style="color: #4a5568;">تاريخ الامتحان <span class="text-danger">*</span></label>
                            <input asp-for="ExamDate" id="ExamDate" class="form-control border-light-subtle shadow-sm" type="date" style="border-radius: 8px;" />
                            <span asp-validation-for="ExamDate" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="StartTime" class="form-label fw-bold" style="color: #4a5568;">وقت البدء <span class="text-danger">*</span></label>
                            <input asp-for="StartTime" id="StartTime" class="form-control border-light-subtle shadow-sm text-center" type="time" style="border-radius: 8px;" />
                            <span asp-validation-for="StartTime" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="EndTime" class="form-label fw-bold" style="color: #4a5568;">وقت الانتهاء <span class="text-danger">*</span></label>
                            <input asp-for="EndTime" id="EndTime" class="form-control border-light-subtle shadow-sm text-center" type="time" style="border-radius: 8px;" />
                            <span asp-validation-for="EndTime" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top">
                        <button type="submit" id="submitBtn" class="btn btn-academic-primary px-5 fw-bold shadow-sm" style="background-color: #1a2c4e; color: white; border-radius: 8px;">
                            <i class="bi bi-check-circle me-1"></i> حفظ الامتحان
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 shadow-sm" style="border-radius: 8px;">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            // 1. جلب السنة الدراسية تلقائياً
            $('#SubjectSelect').change(function () {
                var subjectId = $(this).val();
                if (subjectId) {
                    $.ajax({
                        url: '/Exams/GetSubjectDetails',
                        type: 'GET',
                        data: { id: subjectId },
                        success: function (data) {
                            if (data) {
                                $('#AcademicYearField').val(data.academicYear);
                            }
                        }
                    });
                } else {
                    $('#AcademicYearField').val('');
                }
            });

            // 2. دالة للتحقق من تداخل المواعيد عبر Ajax
            function checkOverlap() {
                var date = $('#ExamDate').val();
                var start = $('#StartTime').val();
                var end = $('#EndTime').val();
                var errorDiv = $('#timeError');
                var errorMessage = $('#timeErrorMessage');
                var submitBtn = $('#submitBtn');

                if (date && start && end) {
                    // التحقق أولاً من أن وقت النهاية بعد وقت البدء
                    if (end <= start) {
                        errorMessage.text("خطأ: يجب أن يكون وقت انتهاء الامتحان بعد وقت البدء.");
                        errorDiv.fadeIn();
                        submitBtn.attr('disabled', 'disabled');
                        return;
                    }

                    // التحقق من التداخل في قاعدة البيانات
                    $.get('/Exams/CheckTimeOverlap', { date: date, start: start, end: end }, function (data) {
                        if (data.overlap) {
                            errorMessage.text("تنبيه: يوجد امتحان آخر مسجل في نفس هذا الموعد والتاريخ.");
                            errorDiv.fadeIn();
                            submitBtn.attr('disabled', 'disabled');
                        } else {
                            errorDiv.fadeOut();
                            submitBtn.removeAttr('disabled');
                        }
                    });
                }
            }

            // تشغيل الفحص عند تغيير التاريخ أو الأوقات
            $('#ExamDate, #StartTime, #EndTime').change(function () {
                checkOverlap();
            });

            // 3. التحقق النهائي عند الإرسال (Back-up validation)
            $('#examForm').submit(function (e) {
                var start = $('#StartTime').val();
                var end = $('#EndTime').val();
                if (start && end && end <= start) {
                    e.preventDefault();
                    $('#timeErrorMessage').text("خطأ في المواعيد: يجب أن يكون وقت انتهاء الامتحان لاحقاً لوقت البدء.");
                    $('#timeError').fadeIn();
                    $('html, body').animate({ scrollTop: 0 }, 'slow');
                }
            });
        });
    </script>
}