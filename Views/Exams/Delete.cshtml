@model projectweb.Models.Exam

@{
    ViewData["Title"] = "تأكيد حذف امتحان";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-6">
        <div class="card academic-card shadow-sm">
            <div class="card-body p-4 bg-white">
                <div class="text-center mb-4">
                    <i class="bi bi-exclamation-octagon text-danger" style="font-size: 4rem;"></i>
                    <h3 class="academic-heading fw-bold mt-2">تأكيد الحذف</h3>
                </div>

                @if (Model.ExamSchedules != null && Model.ExamSchedules.Any())
                {
                    <div class="alert alert-danger border-0 mb-4 shadow-sm">
                        <i class="bi bi-x-circle-fill fs-5 me-2"></i>
                        <strong>عفواً، لا يمكن حذف هذا الامتحان.</strong>
                        <p class="mb-0 small opacity-90 mt-1">
                            النظام يمنع حذف أي امتحان يحتوي على جداول توزيع مسجلة. يرجى حذف الجداول المرتبطة أولاً.
                        </p>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning border-0 d-flex gap-2 align-items-center mb-4 shadow-sm">
                        <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                        <div>
                            <strong>تأكيد عملية الحذف!</strong><br />
                            <span class="small">أنت على وشك حذف امتحان مادة "<strong>@(Model.Subject?.SubjectName ?? "غير محدد")</strong>" بتاريخ <strong>@Model.ExamDate.ToString("yyyy/MM/dd")</strong> نهائياً. هل أنت متأكد؟</span>
                        </div>
                    </div>
                }

                <div class="row g-3 mb-4 text-center">
                    <div class="col-4">
                        <div class="rounded p-3 border" style="background-color: var(--bg-light); border-color: var(--border-color) !important;">
                            <div class="small academic-label mb-1">المادة</div>
                            <div class="fw-bold mt-1" style="color: var(--text-main);">@(Model.Subject?.SubjectName ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="rounded p-3 border" style="background-color: var(--bg-light); border-color: var(--border-color) !important;">
                            <div class="small academic-label mb-1">السنة الدراسية</div>
                            <div class="fw-bold mt-1" style="color: var(--text-main);">@Model.TargetAcademicYear</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="rounded p-3 border" style="background-color: var(--bg-light); border-color: var(--border-color) !important;">
                            <div class="small academic-label mb-1">جداول التوزيع</div>
                            <div class="fw-bold mt-1 @(Model.ExamSchedules != null && Model.ExamSchedules.Any() ? "text-danger" : "text-success")">
                                @(Model.ExamSchedules?.Count ?? 0) جدول
                            </div>
                        </div>
                    </div>
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="ExamId" />
                    <div class="d-flex justify-content-center gap-2 mt-4 pt-3 border-top" style="border-color: var(--border-color) !important;">
                        @if (Model.ExamSchedules == null || !Model.ExamSchedules.Any())
                        {
                            <button type="submit" class="btn btn-danger px-4 fw-bold">
                                <i class="bi bi-trash me-1"></i> تأكيد الحذف
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-secondary px-4 fw-bold" disabled>
                                <i class="bi bi-lock-fill me-1"></i> الحذف غير متاح
                            </button>
                        }
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">تراجع والعودة</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>