@model projectweb.Models.Exam

@{
    ViewData["Title"] = "تأكيد حذف امتحان";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-5" dir="rtl">
    <div class="col-xl-6">
        <div class="card academic-card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
            <div class="card-body p-4 bg-white">
                <div class="text-center mb-4">
                    <i class="bi bi-exclamation-octagon text-danger" style="font-size: 4rem;"></i>
                    <h3 class="fw-bold mt-2" style="color: #1a2c4e;">تأكيد حذف الامتحان</h3>
                </div>

                @* فحص إذا كان الامتحان مرتبط بجداول توزيع (لجان) *@
                @if (Model.ExamSchedules != null && Model.ExamSchedules.Any())
                {
                    <div class="alert alert-danger border-0 mb-4 shadow-sm" style="border-radius: 10px;">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-x-circle-fill fs-4 me-2"></i>
                            <strong class="ms-2">عفواً، لا يمكن حذف هذا الامتحان حالياً.</strong>
                        </div>
                        <p class="mb-0 small opacity-90 mt-2 ms-4">
                            هذا الامتحان مرتبط بـ <strong>(@Model.ExamSchedules.Count)</strong> لجنة توزيع.
                            يرجى حذف جداول توزيع اللجان المرتبطة بهذا الامتحان أولاً قبل محاولة حذفه.
                        </p>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning border-0 mb-4 shadow-sm" style="border-radius: 10px;">
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-exclamation-triangle-fill fs-4 text-warning"></i>
                            <div>
                                <strong class="text-dark">تحذير عملية حذف!</strong><br />
                                <span class="small text-muted">
                                    أنت على وشك حذف سجل امتحان مادة "<strong>@(Model.Subject?.SubjectName ?? "غير محدد")</strong>".
                                    هذا الإجراء سيقوم بمسح كافة بيانات الامتحان نهائياً من النظام.
                                </span>
                            </div>
                        </div>
                    </div>
                }

                @* تفاصيل الامتحان المراد حذفه *@
                <div class="row g-3 mb-4 text-center">
                    <div class="col-4">
                        <div class="rounded p-3 border shadow-sm" style="background-color: #f8f9fa;">
                            <div class="small text-muted mb-1">المادة</div>
                            <div class="fw-bold text-dark">@(Model.Subject?.SubjectName ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="rounded p-3 border shadow-sm" style="background-color: #f8f9fa;">
                            <div class="small text-muted mb-1">التاريخ</div>
                            <div class="fw-bold text-dark">@Model.ExamDate.ToString("yyyy/MM/dd")</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="rounded p-3 border shadow-sm" style="background-color: #f8f9fa;">
                            <div class="small text-muted mb-1">اللجان المرتبطة</div>
                            <div class="fw-bold @(Model.ExamSchedules != null && Model.ExamSchedules.Any() ? "text-danger" : "text-success")">
                                @(Model.ExamSchedules?.Count ?? 0) سجل
                            </div>
                        </div>
                    </div>
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="ExamId" />

                    <div class="d-flex justify-content-center gap-3 mt-4 pt-3 border-top">
                        @* زر الحذف يظهر فقط إذا لم تكن هناك جداول مرتبطة *@
                        @if (Model.ExamSchedules == null || !Model.ExamSchedules.Any())
                        {
                            <button type="submit" class="btn btn-danger px-5 fw-bold shadow-sm" style="border-radius: 8px;">
                                <i class="bi bi-trash me-1"></i> نعم، احذف السجل
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-secondary px-4 fw-bold shadow-sm" style="border-radius: 8px;" disabled>
                                <i class="bi bi-lock-fill me-1"></i> الحذف معطل
                            </button>
                        }

                        <a asp-action="Index" class="btn btn-outline-secondary px-4 shadow-sm" style="border-radius: 8px;">
                            إلغاء وتراجع
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>