@model projectweb.Models.Exam

@{
    ViewData["Title"] = "تأكيد حذف امتحان";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-5" dir="rtl">
    <div class="col-xl-7 col-lg-8">
        <div class="card academic-card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
            @* رأس البطاقة الملون للتحذير *@
            <div class="card-header bg-danger text-white p-4 border-0 text-center">
                <i class="bi bi-exclamation-octagon-fill fs-1"></i>
                <h3 class="fw-bold mt-2 text-white">تأكيد حذف سجل الامتحان</h3>
            </div>

            <div class="card-body p-4 p-md-5 bg-white">

                @* الحالة الأولى: الامتحان مرتبط بتوزيعات (منع الحذف برمجياً) *@
                @if (Model.ExamSchedules != null && Model.ExamSchedules.Any())
                {
                    <div class="alert alert-danger border-0 mb-4 shadow-sm p-4" style="border-radius: 12px; border-right: 6px solid #dc3545 !important;">
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-shield-lock-fill fs-3 me-2"></i>
                            <strong class="fs-5 ms-2">إجراء محظور</strong>
                        </div>
                        <p class="mb-0 lh-lg text-dark">
                            لا يمكن حذف هذا الامتحان لوجود <strong>(@Model.ExamSchedules.Count)</strong> مقر موزع (ExamSchedule) مرتبط به.
                            حذف الامتحان سيؤدي إلى كسر روابط الجداول والتقارير المرتبطة.
                            <br>
                            <span class="badge bg-danger mt-2">الإجراء المطلوب:</span> يجب مسح التوزيعات المرتبطة بهذا الامتحان أولاً.
                        </p>
                    </div>
                }
                @* الحالة الثانية: السجل نظيف وقابل للحذف *@
                else
                {
                    <div class="alert alert-warning border-0 mb-4 shadow-sm p-4" style="border-radius: 12px; border-right: 6px solid #ffc107 !important;">
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-exclamation-triangle-fill fs-3 text-warning me-2"></i>
                            <strong class="text-dark fs-5 ms-2">تحذير نهائي</strong>
                        </div>
                        <p class="mb-0 text-muted lh-lg">
                            أنت على وشك حذف سجل امتحان مادة <strong>"@(Model.Subject?.SubjectName ?? "غير محدد")"</strong>.
                            هذا الإجراء <strong>قطعي ولا يمكن التراجع عنه</strong> بعد التنفيذ.
                        </p>
                    </div>
                }

                @* ملخص البيانات *@
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="rounded p-3 border shadow-sm text-center bg-light h-100">
                            <div class="small text-muted mb-1 fw-bold">المادة الدراسية</div>
                            <div class="fw-bold text-navy">@(Model.Subject?.SubjectName ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="rounded p-3 border shadow-sm text-center bg-light h-100">
                            <div class="small text-muted mb-1 fw-bold">تاريخ الامتحان</div>
                            <div class="fw-bold text-dark">@Model.ExamDate.ToString("yyyy/MM/dd")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="rounded p-3 border shadow-sm text-center bg-light h-100">
                            <div class="small text-muted mb-1 fw-bold">الارتباطات الحالية</div>
                            <div class="fw-bold @(Model.ExamSchedules != null && Model.ExamSchedules.Any() ? "text-danger" : "text-success")">
                                <i class="bi bi-layers-half me-1"></i>
                                @(Model.ExamSchedules?.Count ?? 0) مقر موزع
                            </div>
                        </div>
                    </div>
                </div>

                @* أزرار التحكم *@
                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ExamId" />

                    <div class="d-flex justify-content-center gap-3 mt-4 pt-3 border-top">
                        @if (Model.ExamSchedules == null || !Model.ExamSchedules.Any())
                        {
                            <button type="submit" class="btn btn-danger px-5 py-2 fw-bold shadow-sm" style="border-radius: 8px;">
                                <i class="bi bi-trash3-fill me-2"></i> تأكيد الحذف النهائي
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-secondary px-5 py-2 fw-bold shadow-sm opacity-75" style="border-radius: 8px;" disabled>
                                <i class="bi bi-lock-fill me-2"></i> الحذف معطل
                            </button>
                        }

                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 border-0 fw-bold">
                            تراجع والعودة للقائمة
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <p class="text-center mt-3 text-muted small">
            <i class="bi bi-info-circle me-1"></i> ملاحظة: كافة عمليات الحذف يتم تسجيلها في سجل مراقبة النظام لأغراض التدقيق.
        </p>
    </div>
</div>

<style>
    .text-navy {
        color: #1a3a5a;
    }

    .academic-card {
        transition: all 0.3s ease;
    }

    .bg-light {
        background-color: #f8f9fa !important;
    }

    .btn-danger:hover {
        background-color: #bb2d3b;
        transform: scale(1.02);
    }
</style>