@model IEnumerable<projectweb.Models.Exam>

@{
    ViewData["Title"] = "إدارة الامتحانات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 10px;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 10px;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold academic-heading">
            <i class="bi bi-journal-bookmark-fill me-2 text-primary"></i> جداول الامتحانات واللجان
        </h1>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-academic-primary px-4 shadow-sm fw-bold">
                <i class="bi bi-plus-circle me-1"></i> إضافة امتحان جديد
            </a>
        }
    </div>

    <div class="card academic-card shadow-sm border-0 overflow-hidden" style="border-radius: 15px;">
        <div class="table-responsive">
            <table class="table academic-table table-hover align-middle mb-0 text-center">
                <thead class="text-white" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%);">
                    <tr>
                        <th class="py-3 ps-4" style="width: 80px;">كود</th>
                        <th>المادة الدراسية</th>
                        <th>تاريخ الامتحان</th>
                        <th>الفترة الزمنية</th>
                        <th>السنة الدراسية</th>
                        <th>حالة توزيع اللجان</th>
                        <th class="pe-4" style="width: 150px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted small">#@item.ExamId</td>

                                <td class="fw-bold text-navy">
                                    <div class="d-flex align-items-center justify-content-center">
                                        <i class="bi bi-book-half me-2 opacity-50"></i>
                                        @(item.Subject?.SubjectName ?? "مادة غير محددة")
                                    </div>
                                </td>

                                <td>
                                    <span class="badge bg-light text-dark border px-3 py-2 fw-normal" style="border-radius: 8px;">
                                        <i class="bi bi-calendar3 me-1 text-primary"></i>
                                        @item.ExamDate.ToString("yyyy/MM/dd")
                                    </span>
                                </td>

                                <td>
                                    <div class="small fw-bold">
                                        @{
                                            var start = DateTime.Today.Add(item.StartTime).ToString("hh:mm tt");
                                            var end = DateTime.Today.Add(item.EndTime).ToString("hh:mm tt");
                                            var duration = (item.EndTime - item.StartTime).TotalHours;
                                        }
                                        <div class="text-dark"><i class="bi bi-clock me-1 text-info"></i> <span dir="ltr">@start - @end</span></div>
                                        <div class="text-muted extra-small" style="font-size: 0.7rem;">(المدة: @duration.ToString("0.#") ساعة)</div>
                                    </div>
                                </td>

                                <td>
                                    <span class="badge px-3 py-2" style="background-color: #e3f2fd; color: #1a3a5a; border: 1px solid #bbdefb; border-radius: 6px;">
                                        @item.TargetAcademicYear
                                    </span>
                                </td>

                                <td>
                                    @if (item.ExamSchedules != null && item.ExamSchedules.Any())
                                    {
                                        <div class="d-flex flex-column align-items-center">
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 mb-1" style="border-radius: 20px;">
                                                <i class="bi bi-check-circle-fill me-1"></i> تم توزيع @item.ExamSchedules.Count لجنة
                                            </span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border px-3 py-2" style="border-radius: 20px;">
                                            <i class="bi bi-slash-circle me-1"></i> غير موزع
                                        </span>
                                    }
                                </td>

                                <td class="pe-4">
                                    <div class="btn-group shadow-sm" role="group" style="border-radius: 8px; overflow: hidden;">
                                        <a asp-action="Details" asp-route-id="@item.ExamId" class="btn btn-sm btn-white text-info border" title="عرض التفاصيل">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.ExamId" class="btn btn-sm btn-white text-primary border" title="تعديل">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.ExamId" class="btn btn-sm btn-white text-danger border" title="حذف">
                                                <i class="bi bi-trash-fill"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <div class="opacity-50">
                                    <i class="bi bi-calendar-x fs-1 d-block mb-3"></i>
                                    <h5 class="fw-bold">لا توجد امتحانات مسجلة حالياً</h5>
                                    <p class="small text-muted">ابدأ بإضافة أول امتحان من خلال الزر بالأعلى.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .text-navy {
        color: #1a3a5a;
    }

    .btn-white {
        background-color: #ffffff;
    }

        .btn-white:hover {
            background-color: #f8f9fa;
        }

    .extra-small {
        font-size: 0.75rem;
    }

    .academic-table thead th {
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(46, 90, 136, 0.04);
        transition: background-color 0.2s ease;
    }

    .badge {
        font-weight: 500;
    }
</style>