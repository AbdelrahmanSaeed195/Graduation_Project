@model IEnumerable<projectweb.Models.Exam>

@{
    ViewData["Title"] = "إدارة الامتحانات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-body" dir="rtl">

    @* رسائل التنبيه *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold academic-heading">
            <i class="bi bi-journal-bookmark-fill me-2"></i> إدارة الامتحانات
        </h1>
        <a asp-action="Create" class="btn px-4 shadow-sm text-white" style="background-color: #1a2c4e; border-radius: 8px;">
            <i class="bi bi-plus-circle me-1"></i> إضافة امتحان جديد
        </a>
    </div>

    <div class="card academic-card shadow-sm overflow-hidden border-0" style="border-radius: 15px;">
        <div class="table-responsive">
            <table class="table academic-table table-hover align-middle mb-0 text-center">
                <thead style="background-color: #212529; color: white;">
                    <tr>
                        <th class="py-3">كود الامتحان</th>
                        <th>المادة الدراسية</th>
                        <th>تاريخ الامتحان</th>
                        <th>وقت الامتحان</th>
                        <th>السنة الدراسية</th>
                        <th>جداول التوزيع</th>
                        <th class="pe-4">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-muted">#@item.ExamId</td>

                                <td class="fw-bold" style="color: #1a2c4e;">
                                    @if (item.Subject != null)
                                    {
                                        <i class="bi bi-book me-1" style="color: #00a8ff;"></i>
                                        @item.Subject.SubjectName
                                    }
                                    else
                                    {
                                        <span class="text-muted">غير محدد</span>
                                    }
                                </td>

                                <td>
                                    <span class="badge bg-light border px-3 py-2 text-dark" style="border-radius: 8px;">
                                        <i class="bi bi-calendar-event me-1 text-primary"></i>
                                        @(item.ExamDate != DateTime.MinValue ? item.ExamDate.ToString("yyyy/MM/dd") : "لم يحدد")
                                    </span>
                                </td>

                                <td>
                                    <span class="badge px-3 py-2 bg-light border text-dark" style="border-radius: 8px;">
                                        <i class="bi bi-clock me-1 text-info"></i>
                                        @{
                                            var startDisplay = DateTime.Today.Add(item.StartTime).ToString("hh:mm tt");
                                            var endDisplay = DateTime.Today.Add(item.EndTime).ToString("hh:mm tt");
                                        }
                                        @startDisplay - @endDisplay
                                    </span>
                                </td>

                               
                                <td>
                                    <span class="badge px-4 py-2 fw-bold"
                                          style="background-color: #00d2ff; color: #1a2c4e; border-radius: 10px; min-width: 100px;">
                                        @item.TargetAcademicYear
                                    </span>
                                </td>

                                <td>
                                    @if (item.ExamSchedules != null && item.ExamSchedules.Any())
                                    {
                                        <a asp-controller="ExamSchedules" asp-action="Index" asp-route-examId="@item.ExamId"
                                           class="btn btn-sm btn-success px-3 shadow-sm" style="border-radius: 6px;">
                                            <i class="bi bi-diagram-3 me-1"></i> @item.ExamSchedules.Count لجنة
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-3 py-2" style="border-radius: 6px;">
                                            <i class="bi bi-slash-circle me-1"></i> 0 لجنة
                                        </span>
                                    }
                                </td>

                                <td class="pe-4">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.ExamId" class="btn btn-sm btn-outline-dark" style="border-radius: 6px;" title="تعديل">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.ExamId" class="btn btn-sm btn-outline-info" style="border-radius: 6px;" title="تفاصيل">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.ExamId" class="btn btn-sm btn-outline-danger" style="border-radius: 6px;" title="حذف">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>