@model projectweb.Models.Exam

@{
    ViewData["Title"] = "تفاصيل الامتحان";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-10">
        <div class="card academic-card mb-4 shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
            <div class="card-header academic-card-header text-white p-4 d-flex justify-content-between align-items-center" style="background-color: #1a2c4e;">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-info-circle-fill me-2"></i> بيانات الامتحان التفصيلية</h4>
                <span class="badge bg-light fs-6 text-dark" style="border-radius: 8px;">كود الامتحان #@Model.ExamId</span>
            </div>
            <div class="card-body p-4 bg-white">

                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="bg-light rounded p-3 border shadow-sm">
                            <div class="small text-muted mb-1 fw-bold">المادة الدراسية</div>
                            <div class="fw-bold fs-5 text-dark">
                                @if (Model.Subject != null)
                                {
                                    <i class="bi bi-book me-1 text-primary"></i>
                                    @Model.Subject.SubjectName
                                }
                                else
                                {
                                    <span class="text-muted">غير محدد</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-light rounded p-3 border shadow-sm">
                            <div class="small text-muted mb-1 fw-bold">تاريخ الامتحان</div>
                            <div class="fw-bold fs-5 text-dark">
                                <i class="bi bi-calendar-event me-1 text-primary"></i> @Model.ExamDate.ToString("yyyy/MM/dd")
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-light rounded p-3 border shadow-sm">
                            <div class="small text-muted mb-1 fw-bold">السنة الدراسية</div>
                            <div class="fw-bold fs-5 text-dark">
                                <span class="badge bg-info text-dark px-3 py-2 fs-6" style="border-radius: 8px;">@Model.TargetAcademicYear</span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="bg-light rounded p-3 border shadow-sm text-center">
                            <div class="small text-muted mb-1 fw-bold">وقت البدء</div>
                            <div class="fw-bold fs-4 text-dark">
                                @{
                                    var startTime = DateTime.Today.Add(Model.StartTime);
                                }
                                <i class="bi bi-clock me-1 text-info"></i> @startTime.ToString("hh:mm tt")
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="bg-light rounded p-3 border shadow-sm text-center">
                            <div class="small text-muted mb-1 fw-bold">وقت الانتهاء</div>
                            <div class="fw-bold fs-4 text-dark">
                                @{
                                    var endTime = DateTime.Today.Add(Model.EndTime);
                                }
                                <i class="bi bi-clock-fill me-1 text-info"></i> @endTime.ToString("hh:mm tt")
                            </div>
                        </div>
                    </div>
                </div>

                <h5 class="fw-bold border-bottom pb-2 mb-3 mt-5" style="color: #1a2c4e;">
                    <i class="bi bi-table me-2"></i> لجان التوزيع المسجلة لهذا الامتحان
                </h5>

                @if (Model.ExamSchedules != null && Model.ExamSchedules.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle border">
                            <thead class="table-dark">
                                <tr class="text-center">
                                    <th>كود الجلسة</th>
                                    <th>اللجنة</th>
                                    <th>الإجراء</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.ExamSchedules)
                                {
                                    <tr class="text-center">
                                        <td class="fw-bold text-muted">#@s.ExamScheduleId</td>
                                        <td class="fw-bold text-primary">
                                            @(s.Committee != null ? $"لجنة {s.Committee.CommitteeNumber}" : "غير محدد")
                                        </td>
                                        <td>
                                            <a asp-controller="ExamSchedules" asp-action="Details" asp-route-id="@s.ExamScheduleId" class="btn btn-sm btn-outline-primary shadow-sm" style="border-radius: 6px;">
                                                <i class="bi bi-eye"></i> عرض اللجنة
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary border-0 text-center shadow-sm" style="background-color: #f8f9fa;">
                        <i class="bi bi-info-circle me-1"></i> لا توجد لجان موزعة لهذا الامتحان بعد.
                        يمكنك إضافة توزيع جديد من قائمة "توزيع اللجان".
                    </div>
                }

                <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top">
                    <a asp-action="Edit" asp-route-id="@Model.ExamId" class="btn btn-academic-primary px-5 fw-bold shadow-sm" style="background-color: #1a2c4e; color: white; border-radius: 8px;">
                        <i class="bi bi-pencil-square me-1"></i> تعديل بيانات الامتحان
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 shadow-sm" style="border-radius: 8px;">العودة للقائمة</a>
                </div>
            </div>
        </div>
    </div>
</div>