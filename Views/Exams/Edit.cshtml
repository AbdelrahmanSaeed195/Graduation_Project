@model projectweb.Models.Exam

@{
    ViewData["Title"] = "تعديل بيانات الامتحان";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-8">
        <div class="card academic-card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
            <div class="card-header academic-card-header text-white p-4" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%); border: none;">
                <h4 class="mb-0 fw-bold text-white">
                    <i class="bi bi-pencil-square me-2"></i> تعديل بيانات الامتحان رقم (#@Model.ExamId)
                </h4>
            </div>

            <div class="card-body p-4 bg-white">
                <form asp-action="Edit" method="post" id="editExamForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ExamId" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3 border-0 shadow-sm" style="border-radius: 8px;"></div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="SubjectID" class="form-label fw-bold text-secondary">المادة الدراسية <span class="text-danger">*</span></label>
                            <select asp-for="SubjectID" id="SubjectDropdown" asp-items="@(ViewBag.SubjectID)" class="form-select border-light-subtle shadow-sm academic-input" style="border-radius: 8px;">
                                <option value="">-- اختر المادة --</option>
                            </select>
                            <span asp-validation-for="SubjectID" class="text-danger small mt-1 d-block fw-bold"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold text-secondary">السنة الدراسية المستهدفة (تلقائي)</label>
                            <input id="AcademicYearDisplay"
                                   class="form-control bg-light shadow-sm border-0 fw-bold text-navy"
                                   readonly
                                   style="border-radius: 8px;"
                                   placeholder="سيتم تحديدها آلياً..."
                                   @* 🌟 تم التعديل هنا ليقرأ اللفظ العربي المترجم فور تحميل الصفحة *@
                                   value="@ViewBag.InitialAcademicYear" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ExamDate" class="form-label fw-bold text-secondary">تاريخ الامتحان <span class="text-danger">*</span></label>
                            <input asp-for="ExamDate" class="form-control border-light-subtle shadow-sm academic-input" type="date" style="border-radius: 8px;" />
                            <span asp-validation-for="ExamDate" class="text-danger small mt-1 d-block fw-bold"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="StartTime" class="form-label fw-bold text-secondary">وقت البدء <span class="text-danger">*</span></label>
                            <input asp-for="StartTime" id="StartTime" class="form-control border-light-subtle shadow-sm text-center fw-bold academic-input" type="time" style="border-radius: 8px;" />
                            <span asp-validation-for="StartTime" class="text-danger small mt-1 d-block fw-bold"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="EndTime" class="form-label fw-bold text-secondary">وقت الانتهاء <span class="text-danger">*</span></label>
                            <input asp-for="EndTime" id="EndTime" class="form-control border-light-subtle shadow-sm text-center fw-bold academic-input" type="time" style="border-radius: 8px;" />
                            <span asp-validation-for="EndTime" class="text-danger small mt-1 d-block fw-bold"></span>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-2 pt-4 border-top">
                        <button type="submit" class="btn btn-academic-primary px-5 fw-bold shadow-sm py-2">
                            <i class="bi bi-save me-1"></i> حفظ التعديلات
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 shadow-sm py-2 border-0" style="border-radius: 8px;">
                            <i class="bi bi-arrow-right me-1"></i> تراجع
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            // 🌟 تحديث جلب السنة الدراسية لتقرأ النص العربي المترجم الصريح عند تغيير المادة
            $('#SubjectDropdown').change(function () {
                var subjectId = $(this).val();
                if (subjectId) {
                    $.getJSON('@Url.Action("GetSubjectYear")', { subjectId: subjectId }, function (data) {
                        $('#AcademicYearDisplay').val(data.academicYear);
                    });
                } else {
                    $('#AcademicYearDisplay').val('');
                }
            });

            $('#editExamForm').submit(function (e) {
                var start = $('#StartTime').val();
                var end = $('#EndTime').val();

                if (start && end) {
                    var startTime = new Date("1970-01-01 " + start);
                    var endTime = new Date("1970-01-01 " + end);

                    var diffMinutes = (endTime - startTime) / (1000 * 60);

                    if (diffMinutes <= 0) {
                        e.preventDefault();
                        alert("خطأ: يجب أن يكون وقت الانتهاء بعد وقت البدء.");
                        $('#EndTime').addClass('is-invalid');
                        return false;
                    }

                    if (diffMinutes > 180) {
                        e.preventDefault();
                        alert("خطأ: لا يمكن أن تتجاوز مدة الامتحان 3 ساعات (180 دقيقة). المدة المدخلة حالياً هي: " + (diffMinutes / 60).toFixed(1) + " ساعة.");
                        $('#EndTime').addClass('is-invalid');
                        return false;
                    }
                }
            });

            $('#EndTime, #StartTime').on('change', function() {
                $(this).removeClass('is-invalid');
            });
        });
    </script>

    <style>
        .text-navy {
            color: #1a3a5a;
        }

        .academic-input:focus {
            border-color: #1a3a5a;
            box-shadow: 0 0 0 0.25rem rgba(26, 58, 90, 0.1);
        }

        .btn-academic-primary {
            background-color: #1a3a5a;
            color: white;
            border-radius: 8px;
            transition: all 0.3s;
        }

            .btn-academic-primary:hover {
                background-color: #2e5a88;
                color: white;
                transform: translateY(-2px);
            }
    </style>
}