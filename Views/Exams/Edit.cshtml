@model projectweb.Models.Exam

@{
    ViewData["Title"] = "تعديل بيانات الامتحان";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-8">
        <div class="card academic-card">
            <div class="card-header academic-card-header text-white p-4">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-pencil-square me-2"></i> تعديل بيانات الامتحان رقم (#@Model.ExamId)</h4>
            </div>
            <div class="card-body p-4 bg-white">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="ExamId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="SubjectID" class="form-label academic-label required">المادة الدراسية</label>
                            <select asp-for="SubjectID" asp-items="@(ViewData["SubjectID"] as SelectList)" class="form-select academic-input">
                                <option value="">-- اختر المادة --</option>
                            </select>
                            <span asp-validation-for="SubjectID" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ExamDate" class="form-label academic-label required">تاريخ الامتحان</label>
                            <input asp-for="ExamDate" class="form-control academic-input" type="date" />
                            <span asp-validation-for="ExamDate" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="StartTime" class="form-label academic-label required">وقت البدء</label>
                            <input asp-for="StartTime" class="form-control academic-input" type="time" />
                            <span asp-validation-for="StartTime" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="EndTime" class="form-label academic-label required">وقت الانتهاء</label>
                            <input asp-for="EndTime" class="form-control academic-input" type="time" />
                            <span asp-validation-for="EndTime" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="TargetAcademicYear" class="form-label academic-label required">السنة الدراسية المستهدفة</label>
                            <select asp-for="TargetAcademicYear" class="form-select academic-input">
                                <option value="">-- اختر السنة الدراسية --</option>
                                <option value="1">المستوى الأول</option>
                                <option value="2">المستوى الثاني</option>
                                <option value="3">المستوى الثالث</option>
                                <option value="4">المستوى الرابع</option>
                            </select>
                            <span asp-validation-for="TargetAcademicYear" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top" style="border-color: var(--border-color) !important;">
                        <button type="submit" class="btn btn-academic-primary px-4 fw-bold">
                            <i class="bi bi-check-circle me-1"></i> حفظ التعديلات
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">العودة للقائمة</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}