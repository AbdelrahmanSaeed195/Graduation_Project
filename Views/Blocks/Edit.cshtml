@model projectweb.Models.Block

@{
    ViewData["Title"] = "تعديل بيانات البلوك";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-8">
        <div class="card academic-card shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">

         
            <div class="card-header text-white p-4" style="background-color: #1a2c4e;">
                <h4 class="mb-0 fw-bold">
                    <i class="bi bi-pencil-square me-2"></i>
                    تعديل بيانات البلوك (#@Model.BlockID)
                </h4>
            </div>

            <div class="card-body p-4 bg-white">

              
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger border-0 shadow-sm mb-4 d-flex align-items-center" style="border-radius: 10px;">
                        <i class="bi bi-exclamation-octagon-fill fs-4 me-3"></i>
                        <div>
                            <ul class="mb-0 list-unstyled fw-bold">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            </ul>
                        </div>
                    </div>
                }

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="BlockID" />

                    <div class="row g-4 mb-4">

                      
                        <div class="col-md-4">
                            <label asp-for="HallId" class="form-label fw-bold" style="color: #4a5568;">الصالة / القاعة التابع لها <span class="text-danger">*</span></label>
                            <select asp-for="HallId" asp-items="ViewBag.HallId" class="form-select border-light-subtle shadow-sm" style="border-radius: 8px;">
                                <option value="">-- اختر الصالة --</option>
                            </select>
                            <span asp-validation-for="HallId" class="text-danger small mt-1 d-block"></span>
                        </div>

                        @* اسم البلوك *@
                        <div class="col-md-4">
                            <label asp-for="BlockName" class="form-label fw-bold" style="color: #4a5568;">اسم البلوك <span class="text-danger">*</span></label>
                            <input asp-for="BlockName" class="form-control border-light-subtle shadow-sm" style="border-radius: 8px;" />
                            <span asp-validation-for="BlockName" class="text-danger small mt-1 d-block fw-bold"></span>
                        </div>

                        @* عدد اللجان *@
                        <div class="col-md-4">
                            <label asp-for="MaxCommittees" class="form-label fw-bold" style="color: #4a5568;">أقصى عدد لجان مسموح <span class="text-danger">*</span></label>
                            <input asp-for="MaxCommittees" type="number" min="1" max="50" class="form-control border-light-subtle shadow-sm text-center" style="border-radius: 8px;" />
                            <span asp-validation-for="MaxCommittees" class="text-danger small mt-1 d-block"></span>
                        </div>

                    </div>

                    @* أزرار التحكم *@
                    <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top">
                        <button type="submit" class="btn px-5 fw-bold shadow-sm text-white" style="background-color: #1a2c4e; border-radius: 8px;">
                            <i class="bi bi-check-circle me-1"></i> حفظ التعديلات
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 shadow-sm" style="border-radius: 8px;">إلغاء والعودة للقائمة</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}