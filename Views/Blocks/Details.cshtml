@model projectweb.Models.Block

@{
    ViewData["Title"] = "تفاصيل البلوك";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-10">
        <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">

            <div class="card-header p-4 d-flex justify-content-between align-items-center" style="background-color: #1a3a5a;">
                <h4 class="mb-0 fw-bold text-white">
                    <i class="bi bi-box-seam me-2"></i> بيانات البلوك / الجزء: @Model.BlockName
                </h4>
                <span class="badge bg-white text-dark fw-bold px-3 py-2" style="font-size: 0.85rem; border-radius: 8px;">
                    كود البلوك: #@Model.BlockId
                </span>
            </div>

            <div class="card-body p-4 bg-light">

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="p-3 bg-white rounded shadow-sm border-start border-primary border-4 h-100">
                            <div class="small text-muted mb-1">اسم البلوك (الجزء)</div>
                            <div class="fw-bold text-dark fs-5">@Model.BlockName</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 bg-white rounded shadow-sm border-start border-success border-4 h-100">
                            <div class="small text-muted mb-1">الصالة / القاعة التابع لها</div>
                            <div class="fw-bold text-success fs-5 text-truncate">
                                @(Model.Hall != null ? Model.Hall.HallName : "غير محدد")
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 bg-white rounded shadow-sm border-start border-info border-4 h-100">
                            <div class="small text-muted mb-1">سعة اللجان المتاحة بالبلوك</div>
                            <div class="fw-bold text-dark fs-5">@Model.MaxCommittees لجان مسموحة</div>
                        </div>
                    </div>
                </div>

                <h5 class="fw-bold pb-2 mb-3 border-bottom text-secondary" style="font-size: 1.1rem;">
                    <i class="bi bi-grid-3x3-gap-fill me-2 text-primary"></i> اللجان الامتحانية المدرجة داخل هذا البلوك
                </h5>

                @if (Model.Committees != null && Model.Committees.Any())
                {
                    <div class="row g-3">
                        @foreach (var c in Model.Committees.OrderBy(committee => committee.CommitteeNumber))
                        {
                            <div class="col-md-4">
                                <div class="card h-100 border-0 shadow-sm" style="border-radius: 10px;">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                                            <div class="fw-bold text-dark fs-6">
                                                <i class="bi bi-person-workspace me-1 text-success"></i> لجنة: @c.CommitteeNumber
                                            </div>
                                            <span class="badge bg-light text-secondary border small">كود: #@c.CommitteeId</span>
                                        </div>

                                        <div class="mt-2 d-flex justify-content-between align-items-center">
                                            <span class="small text-muted">
                                                <i class="bi bi-people me-1"></i> سعة الطلاب:
                                            </span>
                                            <span class="fw-bold text-dark">@c.NumberOfStudent طالب</span>
                                        </div>

                                        <div class="mt-2 d-flex justify-content-between align-items-center">
                                            <span class="small text-muted">
                                                <i class="bi bi-flag me-1"></i> حالة اللجنة:
                                            </span>
                                            <span class="badge @(c.StatusOfCommittee == "مكتمل" ? "bg-success" : "bg-info text-dark") px-2 py-1" style="font-size: 0.75rem; border-radius: 6px;">
                                                @(string.IsNullOrEmpty(c.StatusOfCommittee) ? "نشطة" : c.StatusOfCommittee)
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-white border text-center text-muted p-5 mb-0" style="border-radius: 10px; background-color: #fff;">
                        <i class="bi bi-folder-x fs-1 d-block mb-2 text-warning"></i>
                        لا توجد لجان امتحانية مسجلة أو مرتبطة بهذا البلوك حالياً.
                    </div>
                }
            </div>

            <div class="card-footer bg-white p-3 d-flex justify-content-start gap-2 border-top">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.BlockId" class="btn text-white px-4 fw-bold shadow-sm" style="background-color: #1a3a5a; border-radius: 8px;">
                        <i class="bi bi-pencil-square me-1"></i> تعديل بيانات البلوك
                    </a>
                }
                <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold shadow-sm" style="border-radius: 8px;">
                    <i class="bi bi-arrow-right-circle me-1"></i> العودة للقائمة
                </a>
            </div>

        </div>
    </div>
</div>