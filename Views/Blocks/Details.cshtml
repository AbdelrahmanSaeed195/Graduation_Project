@model projectweb.Models.Block

@{
    ViewData["Title"] = "تفاصيل البلوك";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-10">
        <div class="card academic-card mb-4">
            <div class="card-header academic-card-header text-white p-4 d-flex justify-content-between align-items-center">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-info-circle-fill me-2"></i> بيانات البلوك: @Model.BlockName</h4>
                <span class="badge bg-light fs-6" style="color: var(--primary-navy);">كود البلوك #@Model.BlockID</span>
            </div>
            <div class="card-body p-4 bg-white">

                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="bg-light rounded p-3 border" style="border-color: var(--border-color) !important;">
                            <div class="small academic-label mb-1">اسم البلوك (الجزء)</div>
                            <div class="fw-bold fs-5" style="color: var(--text-main);">@Model.BlockName</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-light rounded p-3 border" style="border-color: var(--border-color) !important;">
                            <div class="small academic-label mb-1">عدد اللجان المتاحة</div>
                            <div class="fw-bold fs-5" style="color: var(--text-main);">@Model.MaxCommittees لجان</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-light rounded p-3 border" style="border-color: var(--border-color) !important;">
                            <div class="small academic-label mb-1">الصالة / القاعة</div>
                            <div class="fw-bold fs-5 academic-heading">
                                @(Model.Hall != null ? $"صالة رقم {Model.Hall.HallId}" : $"صالة رقم {Model.HallId}")
                            </div>
                        </div>
                    </div>
                </div>

                <h5 class="fw-bold academic-heading border-bottom pb-2 mb-3 mt-4" style="border-color: var(--border-color) !important;">
                    <i class="bi bi-ui-checks-grid me-2"></i> اللجان المرتبطة بهذا البلوك
                </h5>

                @if (Model.Committees != null && Model.Committees.Any())
                {
                    <div class="table-responsive">
                        <table class="table academic-table align-middle">
                            <thead>
                                <tr>
                                    <th>رقم اللجنة</th>
                                    <th>سعة الطلاب</th>
                                    <th>حالة اللجنة</th>
                                    <th>الملاحظ المعين (تلقائياً)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.Committees)
                                {
                                    <tr>
                                        <td class="fw-bold academic-heading">لجنة @c.CommitteeNumber</td>
                                        <td style="color: var(--text-main);">@c.NumberOfStudent طالب</td>
                                        <td><span class="badge bg-success">@c.StatusOfCommittee</span></td>
                                        <td>
                                            @if (c.CommitteesAssignments != null && c.CommitteesAssignments.Any())
                                            {
                                                <ul class="list-unstyled mb-0">
                                                    @foreach (var assignment in c.CommitteesAssignments)
                                                    {
                                                        if (assignment.Person != null)
                                                        {
                                                            <li style="color: var(--text-main);"><i class="bi bi-person-badge text-muted me-1"></i> @assignment.Person.FullName</li>
                                                        }
                                                    }
                                                </ul>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">لم يتم تعيين ملاحظ</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary border-0 text-center" style="background-color: var(--bg-light); color: var(--text-main);">
                        لا توجد لجان مرتبطة بهذا البلوك حالياً.
                    </div>
                }

                <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top" style="border-color: var(--border-color) !important;">
                    <a asp-action="Edit" asp-route-id="@Model.BlockID" class="btn btn-academic-primary px-4 fw-bold">
                        <i class="bi bi-pencil-square me-1"></i> تعديل
                    </a>
                    <a asp-action="AssignCommittees" asp-route-blockId="@Model.BlockID" class="btn btn-outline-success px-4">
                        <i class="bi bi-diagram-3 me-1"></i> توزيع اللجان
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">العودة للقائمة</a>
                </div>
            </div>
        </div>
    </div>
</div>