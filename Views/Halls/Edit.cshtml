@model projectweb.Models.Hall

@{
    ViewData["Title"] = "تعديل صالة";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-8">
        <div class="card academic-card">
            <div class="card-header academic-card-header text-white p-4">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-pencil-square me-2"></i> تعديل بيانات الصالة</h4>
            </div>
            <div class="card-body p-4" style="background-color: var(--surface-white);">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="HallId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-8">
                            <label asp-for="HallName" class="form-label academic-label required">اسم الصالة</label>
                            <input asp-for="HallName" class="form-control academic-input" maxlength="100" />
                            <span asp-validation-for="HallName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Floor" class="form-label academic-label required">رقم الدور</label>
                            <input asp-for="Floor" class="form-control academic-input" type="number" />
                            <span asp-validation-for="Floor" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="HallSupervisorID" class="form-label academic-label">مشرف الصالة</label>
                            <select asp-for="HallSupervisorID" asp-items="ViewBag.HallSupervisorID" class="form-select academic-input">
                                <option value="">-- اختر مشرفاً للصالة --</option>
                            </select>
                            <span asp-validation-for="HallSupervisorID" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top" style="border-color: var(--border-color) !important;">
                        <button type="submit" class="btn btn-academic-primary px-4 fw-bold">
                            <i class="bi bi-check2-circle"></i> حفظ التعديلات
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">العودة للقائمة</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}