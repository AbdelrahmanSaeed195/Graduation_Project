@model projectweb.Models.Hall

@{
    ViewData["Title"] = "إضافة صالة جديدة";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-8">
        <div class="card academic-card">
            <div class="card-header academic-card-header text-white p-4">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-plus-square-fill me-2"></i> إضافة صالة / قاعة امتحانات</h4>
            </div>
            <div class="card-body p-4 bg-white">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3 border-0 shadow-sm"></div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="HallName" class="form-label academic-label required">اسم الصالة</label>
                            <input asp-for="HallName" class="form-control academic-input" placeholder="مثال: صالة الامتحانات الرئيسية" maxlength="100" />
                            <span asp-validation-for="HallName" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="Floor" class="form-label academic-label required">رقم الدور</label>
                            <input asp-for="Floor" class="form-control academic-input" type="number" placeholder="مثال: 1" />
                            <span asp-validation-for="Floor" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="MaxBlocks" class="form-label academic-label required">السعة (عدد البلوكات)</label>
                            <input asp-for="MaxBlocks" type="number" min="1" max="20" class="form-control academic-input" placeholder="الحد الأقصى" />
                            <span asp-validation-for="MaxBlocks" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="HallSupervisorID" class="form-label academic-label">مشرف الصالة (اختياري)</label>
                            <select asp-for="HallSupervisorID" asp-items="ViewBag.HallSupervisorID" class="form-select academic-input">
                                <option value="">-- اختر مشرفاً للصالة --</option>
                            </select>
                            <span asp-validation-for="HallSupervisorID" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top" style="border-color: var(--border-color) !important;">
                        <button type="submit" class="btn btn-academic-primary px-4 fw-bold">
                            <i class="bi bi-check-circle me-1"></i> حفظ وإنشاء
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}