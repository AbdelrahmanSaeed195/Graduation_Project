@model projectweb.Models.Hall

@{
    ViewData["Title"] = "تفاصيل الصالة";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-9">
        <div class="card academic-card shadow-sm">
            <div class="card-header academic-card-header text-white p-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-white"><i class="bi bi-info-circle-fill me-2"></i> بيانات الصالة: @Model.HallName</h5>
                <span class="badge bg-white text-navy px-3">كود الصالة: #@Model.HallId</span>
            </div>

            <div class="card-body p-0">
       
                <table class="table table-bordered mb-0">
                    <tbody>
                        <tr>
                            <th class="bg-light" style="width: 25%;">اسم الصالة / القاعة</th>
                            <td style="width: 25%;">@Model.HallName</td>
                            <th class="bg-light" style="width: 25%;">الدور</th>
                            <td style="width: 25%;">الدور @Model.Floor</td>
                        </tr>
                        <tr>
                            <th class="bg-light">مشرف الصالة</th>
                            <td>@(Model.HallSupervisor?.FullName ?? "لم يتم التعيين")</td>
                            <th class="bg-light">السعة المتاحة</th>
                            <td>@Model.MaxBlocks بلوكات</td>
                        </tr>
                    </tbody>
                </table>

                <div class="p-4">
                    <h5 class="fw-bold academic-heading border-bottom pb-2 mb-3">
                        <i class="bi bi-collection-fill me-2"></i> البلوكات (الأجزاء) التابعة
                    </h5>

                    @if (Model.Blocks != null && Model.Blocks.Any())
                    {
                        <div class="table-responsive">
                            <table class="table academic-table align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>كود البلوك</th>
                                        <th>اسم البلوك</th>
                                        <th class="text-center">عدد اللجان المرتبطة</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var block in Model.Blocks)
                                    {
                                        <tr>
                                            <td class="fw-bold">#@block.BlockID</td>
                                            <td>@block.BlockName</td>
                                            <td class="text-center">
                                                <span class="badge @(block.Committees?.Count > 0 ? "bg-success" : "bg-secondary")">
                                                    @(block.Committees?.Count ?? 0) لجان
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-light border text-center text-muted mb-0">
                            لا توجد بلوكات مسجلة حالياً لهذه الصالة.
                        </div>
                    }
                </div>


                <div class="card-footer bg-light p-3 d-flex justify-content-end gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.HallId" class="btn btn-academic-primary px-4 fw-bold">
                        <i class="bi bi-pencil-square me-1"></i> تعديل
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">العودة للقائمة</a>
                </div>
            </div>
        </div>
    </div>
</div>