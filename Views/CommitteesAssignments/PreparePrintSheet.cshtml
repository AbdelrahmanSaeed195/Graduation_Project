@model projectweb.Models.ExamSchedule

@{
    ViewData["Title"] = "إعداد نطاق الطباعة";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-lg-8">
        <div class="card academic-card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">

            @* رأس الكارت بتصميم صفحة التوزيع *@
            <div class="card-header p-4 d-flex justify-content-between align-items-center" style="background-color: #1a2c4e; border-bottom: 4px solid #00a8ff;">
                <h4 class="mb-0 fw-bold text-white">
                    <i class="bi bi-printer-fill me-2"></i> إعداد نطاق طباعة استمارة اللجنة
                </h4>
                <span class="badge bg-info text-dark px-3 py-2">نظام إدارة الامتحانات</span>
            </div>

            <div class="card-body p-5 bg-white">

                @* رسالة الخطأ في حال عدم وجود تكليفات *@
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-warning border-0 shadow-sm mb-4 d-flex align-items-center" style="border-radius: 10px; background-color: #fff3cd; color: #856404;">
                        <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
                        <div class="fw-bold">@TempData["ErrorMessage"]</div>
                    </div>
                }

                @* التحقق من وجود بيانات لتجنب خطأ NullReferenceException (تم التعديل ليفحص الـ Halls) *@
                @if (ViewBag.Exams == null || ViewBag.Halls == null)
                {
                    <div class="alert alert-danger border-0 shadow-sm mb-4 d-flex align-items-center" style="border-radius: 8px;">
                        <i class="bi bi-exclamation-octagon-fill fs-4 me-3"></i>
                        <div>
                            <strong>تنبيه:</strong> لم يتم تحميل القوائم من الخادم.
                            يرجى التأكد من الوصول للصفحة عبر ميثود <b>PreparePrintSheet</b>.
                        </div>
                    </div>
                    <div class="text-center mt-4">
                        <a asp-action="Index" class="btn btn-primary px-5 fw-bold" style="border-radius: 10px;">العودة للرئيسية</a>
                    </div>
                }
                else
                {
                    <form asp-action="PrintControlSheet" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row g-4">
                            @* اختيار الصالة الكاملة المجمعة للبلوكات *@
                            <div class="col-md-6">
                                <div class="p-4 rounded border h-100 shadow-sm" style="background-color: #f8f9fa;">
                                    <label class="small fw-bold mb-3 d-block" style="color: #6c757d;">
                                        <i class="bi bi-building me-1"></i> اختر الصالة الرئيسية للامتحان:
                                    </label>
                                    @* تم تغيير الاسم هنا ليرسل hallId للـ POST *@
                                    <select name="hallId" class="form-select form-select-lg fw-bold" style="color: #1a2c4e; border-color: #dee2e6;" required>
                                        <option value="">-- حدد الصالة الرئيسية --</option>
                                        @foreach (var item in (SelectList)ViewBag.Halls)
                                        {
                                            <option value="@item.Value">صالة (@item.Text)</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            @* اختيار الامتحان *@
                            <div class="col-md-6">
                                <div class="p-4 rounded border h-100 shadow-sm" style="background-color: #f8f9fa;">
                                    <label class="small fw-bold mb-3 d-block" style="color: #6c757d;">
                                        <i class="bi bi-book me-1"></i> اختر الامتحان:
                                    </label>
                                    <select name="examId" class="form-select form-select-lg fw-bold" style="color: #1a2c4e; border-color: #dee2e6;" required>
                                        <option value="">-- حدد المادة --</option>
                                        @foreach (var item in (SelectList)ViewBag.Exams)
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        @* أزرار التحكم *@
                        <div class="mt-5 pt-4 border-top text-center d-flex justify-content-center gap-3">
                            <button type="submit" class="btn btn-lg px-5 fw-bold text-white shadow-sm"
                                    style="background-color: #28a745; border-radius: 10px; transition: 0.3s;">
                                <i class="bi bi-printer me-1"></i> بدء الطباعة الآن
                            </button>

                            <a asp-action="Index" class="btn btn-lg btn-outline-secondary px-5 fw-bold shadow-sm"
                               style="border-radius: 10px;">
                                إلغاء وتراجع
                            </a>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .academic-card {
        border-top: 5px solid #1a2c4e;
    }

    .btn-lg:hover {
        opacity: 0.9;
        transform: translateY(-2px);
    }

    .form-select-lg {
        font-size: 1.1rem;
        padding: 0.75rem 1rem;
    }

    .alert-warning {
        border-right: 5px solid #ffc107 !important;
    }
</style>