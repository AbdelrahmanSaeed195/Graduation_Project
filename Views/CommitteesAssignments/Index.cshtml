@model IEnumerable<projectweb.Models.CommitteesAssignment>

<div class="container-fluid mt-4 px-4 text-end" dir="rtl">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0" style="color: #1a3a5a;">إدارة توزيعات المراقبين</h3>
            <span class="badge bg-secondary">إجمالي التكليفات: @Model.Count()</span>
        </div>

        <div class="d-flex gap-2">
            <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center">
                <select name="scheduleId" class="form-select form-select-sm shadow-sm"
                        asp-items="ViewBag.ExamScheduleId" onchange="this.form.submit()">
                    <option value="">-- اختر الجلسة لعرض التوزيع --</option>
                </select>
            </form>

            @if (ViewBag.CurrentScheduleId != null)
            {
                <form asp-action="AutoAssign" method="post">
                    <input type="hidden" name="scheduleId" value="@ViewBag.CurrentScheduleId" />
                    <button type="submit" class="btn btn-success shadow-sm">
                        <i class="bi bi-magic"></i> تشغيل التوزيع التلقائي
                    </button>
                </form>
            }

            <a asp-action="Create" class="btn text-white shadow-sm" style="background-color: #1a3a5a;">
                <i class="bi bi-plus-circle"></i> إضافة تكليف يدوي
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm border-0 alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <table class="table table-hover text-center align-middle mb-0">
            <thead class="table-light">
                <tr class="text-secondary small text-uppercase">
                    <th>المراقب</th>
                    <th>نطاق المسئولية (المكان)</th>
                    <th>الدور الوظيفي</th>
                    <th>المادة / التفاصيل الزمنية</th> @* تم تعديل العنوان *@
                    <th>المصدر</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.Person.FullName</td>
                        <td>
                            @if (item.Committee != null)
                            {
                                <div class="small text-muted mb-1">
                                    @item.Committee.Block?.Hall?.HallName <i class="bi bi-chevron-left"></i> @item.Committee.Block?.BlockName
                                </div>
                                <span class="badge bg-primary px-3">لجنة: @item.Committee.CommitteeNumber</span>
                            }
                            else if (item.Block != null)
                            {
                                <div class="small text-muted mb-1">@item.Block.Hall?.HallName</div>
                                <span class="badge bg-info text-dark px-3">بلوك: @item.Block.BlockName</span>
                            }
                            else if (item.Hall != null)
                            {
                                <span class="badge bg-warning text-dark px-3">صالة: @item.Hall.HallName</span>
                            }
                        </td>
                        <td>
                            <span class="badge rounded-pill bg-light text-dark border px-3">@item.RoleType</span>
                        </td>
                        <td>
                            <div class="fw-bold text-dark">@item.ExamSchedule?.Exam?.Subject?.SubjectName</div>
                            <div class="small text-muted">
                                <i class="bi bi-calendar3 me-1"></i> @item.ExamSchedule?.ScheduledDate.ToShortDateString()
                            </div>
                            @* إضافة الوقت المسحوب من جدول Exam *@
                            <div class="small text-danger fw-bold mt-1">
                                <i class="bi bi-clock me-1"></i> @item.ExamSchedule?.Exam?.StartTime.ToString(@"hh\:mm") - @item.ExamSchedule?.Exam?.EndTime.ToString(@"hh\:mm")
                            </div>
                        </td>
                        <td>
                            @if (item.AssignmentType == "Auto")
                            {
                                <i class="bi bi-robot text-success fs-5" title="توزيع تلقائي"></i>
                            }
                            else
                            {
                                <i class="bi bi-person-fill text-secondary fs-5" title="إدخال يدوي"></i>
                            }
                        </td>
                        <td>
                            <div class="btn-group shadow-sm">
                                <a asp-action="Details" asp-route-id="@item.AssignmentID" class="btn btn-sm btn-outline-info" title="عرض"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.AssignmentID" class="btn btn-sm btn-outline-secondary mx-1" title="تعديل"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.AssignmentID" class="btn btn-sm btn-outline-danger" title="حذف"><i class="bi bi-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                            لا توجد توزيعات مسجلة لهذه الجلسة.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>