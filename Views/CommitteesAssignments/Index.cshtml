@model IEnumerable<projectweb.Models.CommitteesAssignment>
@using projectweb.Models

<div class="container-fluid mt-4 px-4 text-end" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0" style="color: #1a3a5a;">إدارة توزيعات المراقبين</h3>
            <span class="badge bg-secondary shadow-sm mt-1">إجمالي التكليفات: @Model.Count()</span>
        </div>

        <form asp-action="Index" method="get" class="d-flex gap-2 align-items-end border p-2 rounded bg-light shadow-sm">
            <div>
                <label class="small fw-bold text-muted">البحث بالامتحان:</label>
                <select name="examId" class="form-select form-select-sm" asp-items="ViewBag.Exams" onchange="this.form.submit()">
                    <option value="">-- اختر الامتحان --</option>
                </select>
            </div>
            <div>
                <label class="small fw-bold text-muted">المستوى:</label>
                <select name="academicYear" class="form-select form-select-sm" asp-items="ViewBag.AcademicYears" onchange="this.form.submit()">
                    <option value="">-- كل المستويات --</option>
                </select>
            </div>
            @if (Context.Request.Query["examId"].Any() || Context.Request.Query["academicYear"].Any())
            {
                <div class="align-self-end">
                    <a asp-action="Index" class="btn btn-sm btn-outline-danger">إعادة ضبط</a>
                </div>
            }
        </form>

        <div class="d-flex gap-2">
            <a asp-action="PreparePrintSheet" class="btn btn-dark shadow-sm fw-bold"><i class="bi bi-printer me-1"></i> طباعة الكشوف</a>
            <a asp-action="ConfirmAutoAssign" class="btn btn-success shadow-sm fw-bold"><i class="bi bi-robot me-1"></i> التوزيع التلقائي</a>
            <a asp-action="Create" class="btn btn-primary text-white shadow-sm fw-bold"><i class="bi bi-plus-circle me-1"></i> إضافة تكليف</a>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <table class="table table-hover text-center align-middle mb-0">
            <thead class="table-light border-bottom">
                <tr class="text-secondary small text-uppercase">
                    <th>المراقب / الموظف</th>
                    <th>نطاق المسئولية (المكان)</th>
                    <th>الدور الوظيفي في اللجنة</th>
                    <th>المادة / التفاصيل الزمنية</th>
                    <th>المصدر</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    @* تحديد لون الدور الوظيفي *@
                    string roleBadgeStyle = "background-color: #6c757d; color: #fff;"; // افتراضي
                    if (item.RoleType.Contains("رئيس")) { roleBadgeStyle = "background-color: #6f42c1; color: #fff;"; }
                    else if (item.RoleType.Contains("مراقب")) { roleBadgeStyle = "background-color: #198754; color: #fff;"; }
                    else if (item.RoleType.Contains("ملاحظ")) { roleBadgeStyle = "background-color: #0d6efd; color: #fff;"; }

                    <tr>
                        <td class="fw-bold py-3">
                            <div class="text-dark">@item.Person.FullName</div>
                            <div class="small text-muted fw-bold" style="font-size: 0.75rem;">
                                <i class="bi bi-briefcase me-1"></i> @ViewData["Job_" + item.PersonId]
                            </div>
                        </td>

                        <td>
                            @if (item.ExamLocation != null)
                            {
                                var job = item.Person?.JobRole;
                                var role = item.RoleType ?? "";

                                // 1. مراقب احتياطي
                                if (role.Contains("مراقب احتياطي"))
                                {
                                    <span class="badge px-3 py-2 shadow-sm" style="background-color: #fd7e14; color: #fff; border-radius: 8px;">
                                        مراقب احتياطي (جراش: @(item.ExamLocation.ParentLocation?.ParentLocation?.LocationName ?? item.ExamLocation.ParentLocation?.LocationName ?? item.ExamLocation.LocationName))
                                    </span>
                                }
                                // 2. ملاحظ احتياطي
                                else if (role.Contains("ملاحظ احتياطي"))
                                {
                                    <span class="badge px-3 py-2 shadow-sm" style="background-color: #e83e8c; color: #fff; border-radius: 8px;">
                                        ملاحظ احتياطي (صالة: @item.ExamLocation.LocationName)
                                    </span>
                                }
                                // 3. الأساتذة (   جراش أساسي)
                                else if (job == JobTitle.Professor || job == JobTitle.ProfessorEmeritus || job == JobTitle.AssistantProfessor)
                                {
                                    <span class="badge px-3 py-2 shadow-sm" style="background-color: #6f42c1; color: #fff; border-radius: 8px;">
                                        جراش أساسي: @(item.ExamLocation.ParentLocation?.ParentLocation?.LocationName ?? item.ExamLocation.ParentLocation?.LocationName ?? item.ExamLocation.LocationName)
                                    </span>
                                }
                                // 4. الطاقم الطبي
                                else if (job == JobTitle.Doctor || job == JobTitle.Nurse)
                                {
                                    <span class="badge px-3 py-2 shadow-sm" style="background-color: #adb5bd; color: #000; border-radius: 8px;">
                                        جراش: @(item.ExamLocation.ParentLocation?.ParentLocation?.LocationName ?? item.ExamLocation.ParentLocation?.LocationName ?? item.ExamLocation.LocationName)
                                    </span>
                                }
                                // 5. مراقب صالة
                                else if (job == JobTitle.StaffObserver)
                                {
                                    <span class="badge px-3 py-2 shadow-sm" style="background-color: #198754; color: #fff; border-radius: 8px;">
                                        صالة: @item.ExamLocation.LocationName (جراش: @item.ExamLocation.ParentLocation?.LocationName)
                                    </span>
                                }
                                // 6. لجنة
                                else
                                {
                                    <span class="badge px-3 py-2 shadow-sm" style="background-color: #0dcaf0; color: #000; border-radius: 8px;">
                                        لجنة: @item.ExamLocation.LocationName (صالة: @item.ExamLocation.ParentLocation?.LocationName)
                                    </span>
                                }
                            }
                        </td>

                        <td><span class="badge rounded-pill px-3 py-1 shadow-sm" style="@roleBadgeStyle">@item.RoleType</span></td>

                        <td>
                            <div class="fw-bold">@item.ExamSchedule?.Exam?.Subject?.SubjectName</div>
                            <div class="small text-muted">@item.ExamSchedule?.Exam?.ExamDate.ToString("yyyy/MM/dd")</div>
                        </td>

                        <td>@(item.AssignmentType == "Auto" ? "توزيع تلقائي" : "يدوي")</td>

                        <td>
                            <a asp-action="Details" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>