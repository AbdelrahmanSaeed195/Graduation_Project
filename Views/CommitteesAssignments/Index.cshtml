@model IEnumerable<projectweb.Models.CommitteesAssignment>
@using projectweb.Models

<div class="container-fluid mt-4 px-4 text-end" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0" style="color: #1a3a5a;">إدارة توزيعات المراقبين</h3>
            <span class="badge bg-secondary shadow-sm mt-1">إجمالي التكليفات: @Model.Count()</span>
        </div>

        <form asp-action="Index" method="get" class="d-flex gap-2 align-items-end border p-2 rounded bg-light shadow-sm">
            <div>
                <label class="small fw-bold text-muted">البحث بالامتحان:</label>
                <select name="examId" class="form-select form-select-sm" asp-items="ViewBag.Exams" onchange="this.form.submit()">
                    <option value="">-- اختر الامتحان --</option>
                </select>
            </div>
            <div>
                <label class="small fw-bold text-muted">المستوى:</label>
                <select name="academicYear" class="form-select form-select-sm" asp-items="ViewBag.AcademicYears" onchange="this.form.submit()">
                    <option value="">-- كل المستويات --</option>
                </select>
            </div>
            @if (Context.Request.Query["examId"].Any() || Context.Request.Query["academicYear"].Any())
            {
                <div class="align-self-end">
                    <a asp-action="Index" class="btn btn-sm btn-outline-danger">إعادة ضبط</a>
                </div>
            }
        </form>

        <div class="d-flex gap-2">
            <a asp-action="PreparePrintSheet" class="btn btn-dark shadow-sm fw-bold"><i class="bi bi-printer me-1"></i> طباعة الكشوف</a>
            <a asp-action="ConfirmAutoAssign" class="btn btn-success shadow-sm fw-bold"><i class="bi bi-robot me-1"></i> التوزيع التلقائي</a>
            <a asp-action="Create" class="btn btn-primary text-white shadow-sm fw-bold"><i class="bi bi-plus-circle me-1"></i> إضافة تكليف</a>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <table class="table table-hover text-center align-middle mb-0">
            <thead class="table-light border-bottom">
                <tr class="text-secondary small text-uppercase">
                    <th>المراقب / الموظف</th>
                    <th>نطاق المسئولية (المكان)</th>
                    <th>الدور الوظيفي في اللجنة</th>
                    <th>المادة / التفاصيل الزمنية</th>
                    <th>المصدر</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @* ترتيب مخصص للعرض داخل الجدول: الرؤساء الأساسيون أولاً، ثم رؤساء الاحتياط، ثم المراقبون، ثم الملاحظون *@
                @{
                    var sortedModel = Model
                    .OrderByDescending(a => a.RoleType == "رئيس جراش")
                    .ThenByDescending(a => a.RoleType == "رئيس جراش احتياطي")
                    .ThenByDescending(a => a.RoleType == "مراقب")
                    .ThenByDescending(a => a.RoleType == "مراقب احتياطي")
                    .ToList();
                }

                @foreach (var item in sortedModel)
                {
                    @* هندسة لوحة الألوان برمجياً للفصل الحاسم بين قطاعات وأدوار الجراش الموحد *@
                    string roleBadgeStyle = "background-color: #6c757d; color: #fff;";
                    string currentRole = item.RoleType ?? "";
                    string subRole = item.SubRoleType ?? "";

                    if (currentRole == "رئيس جراش")
                    {
                        roleBadgeStyle = "background-color: #6f42c1; color: #fff;"; // البنفسجي الغامق للأساسي (الـ 3 في الدورين / الـ 2 في الدور الواحد)
                    }
                    else if (currentRole == "رئيس جراش احتياطي")
                    {
                        roleBadgeStyle = "background-color: #b197fc; color: #fff;"; // البنفسجي الفاتح للاحتياطي (2 في الدورين / 1 في الدور الواحد)
                    }
                    else if (currentRole == "مراقب" && !currentRole.Contains("احتياطي"))
                    {
                        roleBadgeStyle = "background-color: #198754; color: #fff;"; // الأخضر الأساسي لمراقب الصالة
                    }
                    else if (currentRole == "مراقب احتياطي")
                    {
                        roleBadgeStyle = "background-color: #fd7e14; color: #fff;"; // البرتقالي للمراقبين الاحتياطيين للأدوار والمقار
                    }
                    else if (currentRole.Contains("ملاحظ") && !currentRole.Contains("احتياطي"))
                    {
                        roleBadgeStyle = "background-color: #0d6efd; color: #fff;"; // الأزرق القياسي لملاحظ اللجنة
                    }
                    else if (currentRole.Contains("ملاحظ احتياطي"))
                    {
                        roleBadgeStyle = "background-color: #e83e8c; color: #fff;"; // الوردي المخصص للاحتياطي الفرعي
                    }

                    <tr>
                        <td class="fw-bold py-3">
                            <div class="text-dark">@item.Person?.FullName</div>
                            <div class="small text-muted fw-bold" style="font-size: 0.75rem;">
                                <i class="bi bi-briefcase me-1"></i> @ViewData["Job_" + item.PersonId]
                            </div>
                        </td>

                        <td>
                            @if (item.ExamLocation != null)
                            {
                                var job = item.Person?.JobRole;
                                var role = item.RoleType ?? "";

                                if (role.Contains("مراقب احتياطي") || role.Contains("رئيس"))
                                {
                                    <span class="badge px-3 py-2 shadow-sm" style="background-color: #f8f9fa; color: #212529; border: 1px solid #dee2e6; border-radius: 8px;">
                                        <i class="bi bi-building me-1 text-primary"></i> جراش: @(item.ExamLocation.ParentLocation?.ParentLocation?.LocationName ?? item.ExamLocation.ParentLocation?.LocationName ?? item.ExamLocation.LocationName)
                                    </span>
                                }
                                else if (role == "مراقب" || role.Contains("ملاحظ احتياطي"))
                                {
                                    <span class="badge px-3 py-2 shadow-sm" style="background-color: #e8f5e9; color: #198754; border-radius: 8px;">
                                        صالة: @(item.ExamLocation.ParentLocation?.LocationName ?? item.ExamLocation.LocationName)
                                    </span>
                                }
                                else
                                {
                                    <span class="badge px-3 py-2 shadow-sm" style="background-color: #e0f7fa; color: #008094; border-radius: 8px;">
                                        لجنة: @item.ExamLocation.LocationName (صالة: @(item.ExamLocation.ParentLocation?.LocationName ?? "---"))
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">غير محدد</span>
                            }
                        </td>

                        <td>
                            <span class="badge rounded-pill px-3 py-1 shadow-sm fw-bold" style="@roleBadgeStyle">
                                @(string.IsNullOrEmpty(item.RoleType) ? "غير محدد" : item.RoleType)
                            </span>
                            @if (!string.IsNullOrEmpty(item.SubRoleType))
                            {
                                <div class="small text-muted fw-bold mt-1" style="font-size: 0.8rem;">
                                    <span class="badge bg-light text-dark border"><i class="bi bi-layers-half text-danger me-1"></i>@item.SubRoleType</span>
                                </div>
                            }
                        </td>

                        <td>
                            <div class="fw-bold">@item.ExamSchedule?.Exam?.Subject?.SubjectName</div>
                            <div class="small text-muted">@item.ExamSchedule?.Exam?.ExamDate.ToString("yyyy/MM/dd")</div>
                        </td>

                        <td>
                            <span class="badge @(item.AssignmentType == "Auto" ? "bg-light text-success border border-success" : "bg-light text-secondary border") px-2 py-1" style="font-size: 0.75rem;">
                                @(item.AssignmentType == "Auto" ? "توزيع تلقائي" : "يدوي")
                            </span>
                        </td>

                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Details" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-outline-info" title="عرض"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>