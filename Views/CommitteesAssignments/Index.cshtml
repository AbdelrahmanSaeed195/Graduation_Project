@model IEnumerable<projectweb.Models.CommitteesAssignment>
@using projectweb.Models

<div class="container-fluid mt-4 px-4 text-end" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0" style="color: #1a3a5a;">إدارة توزيعات القوى العاملة والمراقبين</h3>
            <span class="badge bg-secondary shadow-sm mt-1">إجمالي التكليفات المسجلة: @Model.Count()</span>
        </div>

        <form asp-action="Index" method="get" class="d-flex gap-2 align-items-end border p-2 rounded bg-light shadow-sm">
            <div>
                <label class="small fw-bold text-muted">البحث بالامتحان الموحد:</label>
                <select name="examId" class="form-select form-select-sm" asp-items="ViewBag.Exams" onchange="this.form.submit()">
                    <option value="">-- اختر الامتحان --</option>
                </select>
            </div>
            <div>
                <label class="small fw-bold text-muted">المستوى الأكاديمي:</label>
                <select name="academicYear" class="form-select form-select-sm" asp-items="ViewBag.AcademicYears" onchange="this.form.submit()">
                    <option value="">-- كل المستويات --</option>
                </select>
            </div>
            @if (Context.Request.Query["examId"].Any() || Context.Request.Query["academicYear"].Any())
            {
                <div class="align-self-end">
                    <a asp-action="Index" class="btn btn-sm btn-outline-danger">إعادة ضبط</a>
                </div>
            }
        </form>

        <div class="d-flex gap-2">
            <a asp-action="PreparePrintSheet" class="btn btn-dark shadow-sm fw-bold">
                <i class="bi bi-printer me-1"></i> طباعة كشوف الكنترول
            </a>

            <a asp-action="PrepareHallStructurePrint" class="btn btn-info text-white shadow-sm fw-bold">
                <i class="bi bi-diagram-3 me-1"></i> تقرير هيكل الجراشات
            </a>

            <a asp-action="ConfirmAutoAssign" class="btn btn-success shadow-sm fw-bold">
                <i class="bi bi-robot me-1"></i> التوزيع التلقائي الذكي
            </a>

            <a asp-action="Create" class="btn btn-primary text-white shadow-sm fw-bold">
                <i class="bi bi-plus-circle me-1"></i> إضافة تكليف يدوي
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <table class="table table-hover text-center align-middle mb-0">
            <thead class="table-light border-bottom">
                <tr class="text-secondary small text-uppercase">
                    <th>المراقب / الموظف</th>
                    <th>نطاق المسئولية وهيكل المقر</th>
                    <th>الدور الوظيفي في اللجنة</th>
                    <th>المادة / التفاصيل الزمنية</th>
                    <th>المصدر</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var sortedModel = Model
                    .OrderByDescending(a => a.RoleType == "رئيس جراش")
                    .ThenByDescending(a => a.RoleType == "رئيس جراش احتياطي")
                    .ThenByDescending(a => a.RoleType == "مراقب")
                    .ThenByDescending(a => a.RoleType == "مراقب احتياطي")
                    .ToList();
                }

                @foreach (var item in sortedModel)
                {
                    string roleBadgeStyle = "background-color: #6c757d; color: #fff;";
                    string currentRole = item.RoleType ?? "";

                    if (currentRole == "رئيس جراش")
                    {
                        roleBadgeStyle = "background-color: #6f42c1; color: #fff;";
                    }
                    else if (currentRole == "رئيس جراش احتياطي")
                    {
                        roleBadgeStyle = "background-color: #b197fc; color: #fff;";
                    }
                    else if (currentRole == "مراقب")
                    {
                        roleBadgeStyle = "background-color: #198754; color: #fff;";
                    }
                    else if (currentRole == "مراقب احتياطي")
                    {
                        roleBadgeStyle = "background-color: #fd7e14; color: #fff;";
                    }
                    else if (currentRole.Contains("ملاحظ") && !currentRole.Contains("احتياطي"))
                    {
                        roleBadgeStyle = "background-color: #0d6efd; color: #fff;";
                    }
                    else if (currentRole.Contains("ملاحظ احتياطي") || currentRole.Contains("احتياطي صالة"))
                    {
                        roleBadgeStyle = "background-color: #e83e8c; color: #fff;";
                    }

                    <tr>
                        <td class="fw-bold py-3">
                            <div class="text-dark">@item.Person?.FullName</div>
                            <div class="small text-muted fw-bold" style="font-size: 0.75rem;">
                                <i class="bi bi-briefcase me-1"></i> @ViewData["Job_" + item.PersonId]
                            </div>
                        </td>

                        <td>
                            @if (item.ExamLocation != null)
                            {
                                var role = item.RoleType ?? "";
                                var loc = item.ExamLocation;

                                @* فحص طبقات الهيكل المكاني وعرض المسميات التتابعية الفرعية بدقة *@
                                if (role.Contains("رئيس") || role.Contains("مراقب احتياطي") || loc.Type == LocationType.Hall)
                                {
                                    <span class="badge px-3 py-2 shadow-sm" style="background-color: #f8f9fa; color: #212529; border: 1px solid #dee2e6; border-radius: 8px;">
                                        <i class="bi bi-building me-1 text-primary"></i> جراش: @(loc.ParentLocation?.ParentLocation?.ParentLocation?.LocationName ?? loc.ParentLocation?.ParentLocation?.LocationName ?? loc.ParentLocation?.LocationName ?? loc.LocationName)
                                    </span>
                                }
                                else if (role == "مراقب" || loc.Type == LocationType.Block)
                                {
                                    <span class="badge px-3 py-2 shadow-sm" style="background-color: #e8f5e9; color: #198754; border-radius: 8px;">
                                        <i class="bi bi-layers-half text-success me-1"></i> صالة: @loc.LocationName (صف: @(loc.ParentLocation?.LocationName ?? "---"))
                                    </span>
                                }
                                else if (loc.Type == LocationType.Committee)
                                {
                                    <span class="badge px-3 py-2 shadow-sm" style="background-color: #e0f7fa; color: #008094; border-radius: 8px;">
                                        <i class="bi bi-border-style me-1 text-info"></i> لجنة: @loc.LocationName (صالة: @(loc.ParentLocation?.LocationName ?? "---"))
                                    </span>
                                }
                                else
                                {
                                    <span class="badge px-3 py-2 shadow-sm" style="background-color: #fff; color: #333; border: 1px solid #eee; border-radius: 8px;">
                                        @loc.LocationName
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">غير محدد للمقر</span>
                            }
                        </td>

                        <td>
                            <span class="badge rounded-pill px-3 py-1 shadow-sm fw-bold" style="@roleBadgeStyle">
                                @(string.IsNullOrEmpty(item.RoleType) ? "غير محدد" : item.RoleType)
                            </span>
                            @if (!string.IsNullOrEmpty(item.SubRoleType))
                            {
                                <div class="small text-muted fw-bold mt-1" style="font-size: 0.8rem;">
                                    <span class="badge bg-light text-dark border"><i class="bi bi-geo-alt text-danger me-1"></i>@item.SubRoleType</span>
                                </div>
                            }
                        </td>

                        <td>
                            <div class="fw-bold">@item.ExamSchedule?.Exam?.Subject?.SubjectName</div>
                            <div class="small text-muted">📅 @item.ExamSchedule?.Exam?.ExamDate.ToString("yyyy/MM/dd")</div>
                        </td>

                        <td>
                            <span class="badge @(item.AssignmentType == "Auto" ? "bg-light text-success border border-success" : "bg-light text-secondary border") px-2 py-1" style="font-size: 0.75rem;">
                                @(item.AssignmentType == "Auto" ? "توزيع تلقائي" : "يدوي")
                            </span>
                        </td>

                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Details" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-white text-info border" title="عرض التفاصيل"><i class="bi bi-eye-fill"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-white text-primary border" title="تعديل"><i class="bi bi-pencil-square"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-white text-danger border" title="حذف وإلغاء"><i class="bi bi-trash-fill"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .btn-white {
        background-color: #fff;
        transition: all 0.2s;
    }

        .btn-white:hover {
            background-color: #f8f9fa;
            transform: translateY(-1px);
        }
</style>