@model IEnumerable<projectweb.Models.CommitteesAssignment>
@using System.ComponentModel.DataAnnotations
@using System.Reflection

<div class="container-fluid mt-4 px-4 text-end" dir="rtl">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0" style="color: #1a3a5a;">إدارة توزيعات المراقبين</h3>
            <span class="badge bg-secondary shadow-sm mt-1">إجمالي التكليفات المعروضة: @Model.Count()</span>
        </div>

        <div class="d-flex gap-2 align-items-end">
            <form asp-action="Index" method="get" class="d-flex gap-2 align-items-end border p-2 rounded bg-light shadow-sm">
              <div class="flex-grow-1">
        <label class="small fw-bold d-block mb-1 text-muted">البحث بالامتحان:</label>
        <select name="examId" class="form-select form-select-sm shadow-sm" style="min-width: 250px;"
                asp-items="ViewBag.Exams" onchange="this.form.submit()">
            <option value="">-- اختر الامتحان للبحث  --</option>
        </select>
    </div>

    <div class="flex-grow-1">
        <label class="small fw-bold d-block mb-1 text-muted">المستوى:</label>
        <select name="academicYear" class="form-select form-select-sm shadow-sm" style="min-width: 180px;"
                asp-items="ViewBag.AcademicYears" onchange="this.form.submit()">
            <option value="">-- كل المستويات --</option>
        </select>
    </div>

    @if (ViewBag.SelectedExamId != null || !string.IsNullOrEmpty(Context.Request.Query["academicYear"]))
    {
        <div>
            <a asp-action="Index" class="btn btn-sm btn-outline-danger shadow-sm fw-bold">
                <i class="bi bi-x-circle me-1"></i> إعادة ضبط
            </a>
        </div>
    }
            </form>
             @if (User.IsInRole("Admin"))
            {
               <div class="d-flex gap-2">
    <a asp-action="PreparePrintSheet" class="btn btn-academic-primary shadow-sm fw-bold">
        <i class="bi bi-printer me-1"></i> طباعة كشوف اللجان
    </a>
</div>
                    <a asp-action="ConfirmAutoAssign" class="btn btn-success shadow-sm fw-bold">
                    <i class="bi bi-robot me-1"></i> تشغيل التوزيع التلقائي
                     </a>
                    <a asp-action="Create" class="btn text-white shadow-sm fw-bold" style="background-color: #1a3a5a;">
                     <i class="bi bi-plus-circle me-1"></i> إضافة تكليف يدوي
                    </a>
            }
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm border-0 alert-dismissible fade show text-end" style="border-radius: 10px;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm border-0 alert-dismissible fade show text-end" style="border-radius: 10px;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <table class="table table-hover text-center align-middle mb-0">
            <thead class="table-light border-bottom">
                <tr class="text-secondary small text-uppercase">
                    <th>المراقب / الموظف</th>
                    <th>نطاق المسئولية (المكان)</th>
                    <th>الدور الوظيفي في اللجنة</th>
                    <th>المادة / التفاصيل الزمنية</th>
                    <th>المصدر</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    // منطق تحديد الألوان برمجياً بناءً على مسميات الأدوار والاحتياطيين التابعين لهم لربطهم بصرياً
                    string rowBadgeStyle = "background-color: #0d6efd; color: #fff;"; // الافتراضي أزرق للملاحظين
                    
                    if (item.RoleType.Contains("رئيس صالة أساسي (القطاع الأول)") || item.RoleType.Contains("تبع رئيس 1"))
                    {
                        rowBadgeStyle = "background-color: #6f42c1; color: #fff;"; // القطاع الأول والاحتياطي تبعه (بنفسجي متميز)
                    }
                    else if (item.RoleType.Contains("رئيس صالة أساسي (القطاع الثاني)") || item.RoleType.Contains("تبع رئيس 2"))
                    {
                        rowBadgeStyle = "background-color: #e83e8c; color: #fff;"; // القطاع الثاني والاحتياطي تبعه (وردي غامق متميز)
                    }
                    else if (item.RoleType.Contains("رئيس صالة احتياطي"))
                    {
                        rowBadgeStyle = "background-color: #fd7e14; color: #fff;"; // رئيس صالة احتياطي عام (برتقالي موجه)
                    }
                    else if (item.RoleType == "مراقب")
                    {
                        rowBadgeStyle = "background-color: #198754; color: #fff;"; // معيد مراقب بلوك (أخضر أكاديمي صريح)
                    }
                    else if (item.RoleType.Contains("الطاقم الطبي") || item.RoleType.Contains("الصالة"))
                    {
                        rowBadgeStyle = "background-color: #adb5bd; color: #000;"; // طبي وممرض (رمادي محايد)
                    }

                    <tr>
                        <td class="fw-bold py-3">
                            <div class="text-dark">@item.Person.FullName</div>
                            <div class="small text-muted fw-bold" style="font-size: 0.75rem;">
                                @{
                                    var jobEnum = item.Person.JobRole;
                                    var arabicName = jobEnum.GetType()
                                        .GetMember(jobEnum.ToString())
                                        .FirstOrDefault()?
                                        .GetCustomAttribute<DisplayAttribute>()?
                                        .GetName() ?? jobEnum.ToString();
                                }
                                <i class="bi bi-briefcase me-1"></i> @arabicName
                            </div>
                        </td>

                        <td>
                            @if (item.Hall != null && item.BlockId == null && item.CommitteeId == null)
                            {
                                <span class="badge px-3 py-2 text-dark" style="background-color: #ffc107; border-radius: 8px;">
                                    <i class="bi bi-building me-1"></i> نطاق الصالة: @item.Hall.HallName
                                </span>
                            }
                            else if (item.Block != null && item.CommitteeId == null)
                            {
                                <div class="small text-muted mb-1">@item.Block.Hall?.HallName</div>
                                <span class="badge px-3 py-2 text-dark" style="background-color: #0dcaf0; border-radius: 8px;">
                                    <i class="bi bi-grid-3x3 me-1"></i> بلوك: @item.Block.BlockName
                                </span>
                            }
                            else if (item.Committee != null)
                            {
                                <div class="small text-muted mb-1">
                                    @item.Committee.Block?.Hall?.HallName <i class="bi bi-chevron-left small"></i> @item.Committee.Block?.BlockName
                                </div>
                                <span class="badge px-3 py-2" style="background-color: #20c997; color: #fff; border-radius: 8px;">
                                    <i class="bi bi-person-workspace me-1"></i> لجنة: @item.Committee.CommitteeNumber
                                </span>
                            }
                        </td>

                        <td>
                            <span class="badge rounded-pill px-3 py-2 border shadow-sm" style="@rowBadgeStyle">
                                @item.RoleType
                            </span>
                        </td>

                        <td>
                            <div class="fw-bold text-dark">@item.ExamSchedule?.Exam?.Subject?.SubjectName</div>
                            <div class="small text-muted">
                                <i class="bi bi-calendar3 me-1 text-primary"></i>
                                @(item.ExamSchedule?.Exam?.ExamDate.ToString("yyyy/MM/dd") ?? "غير محدد")
                            </div>
                            <div class="small text-danger fw-bold mt-1">
                                <i class="bi bi-clock me-1"></i>
                                @if (item.ExamSchedule?.Exam != null)
                                {
                                    var start = DateTime.Today.Add(item.ExamSchedule.Exam.StartTime).ToString("hh:mm tt");
                                    var end = DateTime.Today.Add(item.ExamSchedule.Exam.EndTime).ToString("hh:mm tt");
                                    @start @:- @end
                                }
                            </div>
                        </td>

                        <td>
                            @if (item.AssignmentType == "Auto")
                            {
                                <span class="text-success small fw-bold">
                                    <i class="bi bi-robot me-1"></i> توزيع تلقائي
                                </span>
                            }
                            else
                            {
                                <span class="text-secondary small fw-bold">
                                    <i class="bi bi-person-fill me-1"></i> إدخال يدوي
                                </span>
                            }
                        </td>

                        <td>
                            <div class="d-flex justify-content-center gap-1">
                                <a asp-action="Details" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-outline-info border shadow-sm" title="تفاصيل"><i class="bi bi-eye"></i></a>
                                @if (User.IsInRole("Admin"))
                                {
                                   <a asp-action="Edit" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-outline-secondary border shadow-sm" title="تعديل"><i class="bi bi-pencil"></i></a>
                                   <a asp-action="Delete" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-outline-danger border shadow-sm" title="حذف"><i class="bi bi-trash"></i></a>
                                }
                            </div>
                        </td>
                    </tr>
                }

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="py-5 text-muted text-center bg-light">
                            <i class="bi bi-search fs-1 d-block mb-3"></i>
                            لم يتم العثور على توزيعات مطابقة للبحث. جرب اختيار امتحان آخر من القائمة أعلاه.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .table th { font-weight: 600; font-size: 0.85rem; }
    .badge { font-weight: 500; }
    .btn-sm { padding: 0.25rem 0.5rem; }
    .alert { border-radius: 10px; }
</style>