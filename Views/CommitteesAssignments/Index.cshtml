@model IEnumerable<projectweb.Models.CommitteesAssignment>

@{
    ViewData["Title"] = "التكليف العشوائي";
}

<div class="container-fluid mt-4" dir="rtl">
    <div class="text-center mb-4">
        <h3 class="fw-bold text-dark">
            <i class="fas fa-random text-primary me-2"></i> التكليف العشوائي
        </h3>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-dark text-white py-3 rounded-top-4">
            <h6 class="mb-0 fw-bold"><i class="fas fa-sliders-h me-2"></i> معايير الاختيار</h6>
        </div>
        <div class="card-body p-4">
            <form asp-action="AutoAssign" method="post">
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-danger">اختر الصالة **</label>
                        <select class="form-select bg-light border-0 py-2 shadow-none">
                            <option value="">-- اختر الصالة --</option>
                            @* هنا يتم تحميل الصالات لو حبيت تضيفها مستقبلاً *@
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-danger">اختر البلوك **</label>
                        <select class="form-select bg-light border-0 py-2 shadow-none">
                            <option value="">-- اختر البلوك --</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-danger">اختر الامتحان **</label>
                        <select name="examScheduleId" class="form-select bg-light border-0 py-2 shadow-none" asp-items="ViewBag.ExamScheduleId" required>
                            <option value="">-- اختر الامتحان --</option>
                        </select>
                    </div>

                    <div class="col-12 text-start mt-3">
                        <button type="submit" class="btn btn-dark px-4 py-2 rounded-3 shadow-sm">
                            <i class="fas fa-play me-2"></i> تشغيل خوارزمية التكليف
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="alert alert-info border-0 shadow-sm d-flex align-items-center small py-2 mb-4">
        <i class="fas fa-info-circle me-2 text-primary"></i>
        <span>اختر الصالة والبلوك والامتحان ثم اضغط على "تشغيل خوارزمية التكليف" لعرض ومراجعة التكليفات المقترحة.</span>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold text-dark mb-0"><i class="fas fa-table me-2"></i> سجل التكليفات</h6>
        <a asp-action="Create" class="btn btn-dark btn-sm rounded-3 px-3 shadow-sm">
            <i class="fas fa-plus-circle me-1"></i> إضافة تكليف يدوي
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-center">
                    <thead class="bg-light text-secondary small">
                        <tr>
                            <th class="py-3">كود التكليف</th>
                            <th>الموظف</th>
                            <th>اللجنة</th>
                            <th>الدور الوظيفي</th>
                            <th>جلسة الامتحان</th>
                            <th>احتياطي</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold">#@item.AssignmentID</td>
                                    <td>@item.Person?.FullName</td>
                                    <td>@item.Committee?.CommitteeNumber</td>
                                    <td>@item.RoleType</td>
                                    <td>@item.ExamSchedule?.ScheduledDate.ToShortDateString()</td>
                                    <td>
                                        @if (item.isReserve)
                                        {
                                            <i class="fas fa-check-circle text-success"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-times-circle text-muted opacity-50"></i>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center gap-1">
                                            <a asp-action="Edit" asp-route-id="@item.AssignmentID" class="btn btn-sm btn-outline-dark border-0"><i class="fas fa-edit"></i></a>
                                            <a asp-action="Delete" asp-route-id="@item.AssignmentID" class="btn btn-sm btn-outline-danger border-0"><i class="fas fa-trash"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="py-5 text-center text-muted">
                                    <div class="mb-3">
                                        <i class="fas fa-users-slash fs-1 opacity-25"></i>
                                    </div>
                                    <p class="mb-0">لا توجد تكليفات مسجلة حالياً. اختر الصالة والبلوك والامتحان ثم اضغط "تشغيل خوارزمية التكليف" للبدء.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* تنسيقات لمحاكاة الصورة */
    .bg-light {
        background-color: #f8f9fa !important;
    }

    .card {
        border-radius: 12px;
    }

    .form-select {
        font-size: 0.85rem;
        border: 1px solid #eee !important;
    }

    .table thead th {
        border-bottom: none;
        font-weight: 600;
    }

    .alert-info {
        background-color: #eef7ff;
        color: #31708f;
    }

    .btn-dark {
        background-color: #0b1e33;
    }
</style>