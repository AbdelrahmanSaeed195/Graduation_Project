@model projectweb.Models.CommitteesAssignment

<div class="container mt-5 text-center" dir="rtl">
    <div class="card shadow-sm border-danger mx-auto" style="max-width: 500px; border-radius: 15px;">
        <div class="card-body p-5">
            <div class="text-danger mb-3"><i class="bi bi-trash3" style="font-size: 3.5rem;"></i></div>
            <h4 class="fw-bold">هل أنت متأكد من حذف هذا التكليف؟</h4>

            <div class="alert alert-warning border-0 small">
                سيتم إلغاء تكليف الموظف <strong>@Model.Person.FullName</strong>
                من مادة (<strong>@Model.ExamSchedule.Exam.Subject.SubjectName</strong>)
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="AssignmentID" />

                <div class="d-flex justify-content-center gap-2 mt-4">
                    <button type="submit" class="btn btn-danger px-5 btn-lg shadow-sm">تأكيد الحذف</button>

                    <a asp-action="Index" asp-route-scheduleId="@Model.ExamScheduleId" class="btn btn-light px-5 btn-lg border">تراجع</a>
                </div>
            </form>
        </div>
    </div>
</div>