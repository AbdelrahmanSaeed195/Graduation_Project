@model projectweb.Models.CommitteesAssignment

@{
    ViewData["Title"] = "حذف تكليف";
}

<div class="container mt-5 text-center" dir="rtl">
    <div class="card shadow border-0 mx-auto" style="max-width: 550px; border-radius: 20px; overflow: hidden;">
        <div class="py-2 bg-danger"></div>
        <div class="card-body p-5">
           
            <div class="text-danger mb-4">
                <div class="d-inline-block p-3 rounded-circle bg-danger bg-opacity-10">
                    <i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i>
                </div>
            </div>

            <h3 class="fw-bold text-dark mb-3">تأكيد حذف التكليف</h3>
            <p class="text-muted mb-4">أنت على وشك القيام بإجراء لا يمكن التراجع عنه. يرجى مراجعة البيانات التالية بعناية:</p>

            <div class="alert alert-light border shadow-sm text-end mb-4 p-3">
                <div class="mb-2 border-bottom pb-2">
                    <span class="text-muted small">الموظف:</span>
                    <strong class="text-dark d-block">@Model.Person?.FullName</strong>
                    <span class="badge bg-light text-secondary border">@Model.Person?.JobRole</span>
                </div>
                
                <div class="mb-2">
                    <span class="text-muted small">الدور المكلف به:</span>
                    <span class="badge bg-secondary px-3">@Model.RoleType</span>
                </div>

                <div class="mb-2">
                    <span class="text-muted small">المادة الدراسية:</span>
                    <strong class="text-primary">@Model.ExamSchedule?.Exam?.Subject?.SubjectName</strong>
                </div>

                @* عرض التاريخ والوقت المنسق *@
                <div class="mb-2">
                    <span class="text-muted small">التاريخ والوقت:</span>
                    <div class="small fw-bold">
                        <i class="bi bi-calendar3 me-1"></i>
                        @if (Model.ExamSchedule?.Exam != null && Model.ExamSchedule.Exam.ExamDate != DateTime.MinValue)
                        {
                            @Model.ExamSchedule.Exam.ExamDate.ToString("yyyy/MM/dd")
                        }
                        else
                        {
                            @:غير محدد
                        }
                    </div>
                    <div class="small text-danger fw-bold mt-1">
                        <i class="bi bi-clock me-1"></i>
                        @if (Model.ExamSchedule?.Exam != null)
                        {
                            var start = DateTime.Today.Add(Model.ExamSchedule.Exam.StartTime).ToString("hh:mm tt");
                            var end = DateTime.Today.Add(Model.ExamSchedule.Exam.EndTime).ToString("hh:mm tt");
                            @start @:- @end
                        }
                    </div>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="AssignmentID" />
                @* الاحتفاظ بـ ExamId أو SubjectId للرجوع لصفحة الفلترة الصحيحة *@
                <input type="hidden" name="returnExamId" value="@Model.ExamSchedule?.ExamId" />

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger btn-lg shadow-sm fw-bold">
                        <i class="bi bi-trash3 me-1"></i> تأكيد الحذف النهائي
                    </button>

                    <a asp-action="Index" asp-route-examId="@Model.ExamSchedule?.ExamId" class="btn btn-light btn-lg border fw-bold text-secondary">
                        إلغاء والتراجع
                    </a>
                </div>
            </form>
        </div>

        <div class="card-footer bg-light py-3 border-0">
            <small class="text-muted"><i class="bi bi-info-circle me-1"></i> سيتم حذف هذا السجل من جدول توزيعات المراقبين فقط ولن يتأثر جدول الامتحانات.</small>
        </div>
    </div>
</div>