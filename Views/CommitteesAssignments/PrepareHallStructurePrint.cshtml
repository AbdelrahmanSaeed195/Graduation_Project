@model projectweb.Models.ExamLocation
@{
    ViewData["Title"] = "طباعة هيكل الجراش";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-4" dir="rtl" style="text-align: right;">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header p-4 text-white" style="background-color: #1a2c4e; border-bottom: 4px solid #17a2b8;">
                <h4 class="mb-0 fw-bold"><i class="bi bi-printer-fill me-2"></i> طباعة كشوف الهياكل الهندسية للجراشات</h4>
            </div>
            <div class="card-body p-5 bg-white">
                <form asp-action="PrintHallStructureSheet" method="post" target="_blank">
                    @Html.AntiForgeryToken()

                    <div class="p-4 rounded border mb-4 shadow-sm" style="background-color: #f8f9fa;">
                        <label class="form-label fw-bold text-secondary mb-3">اختر الجراش الرئيسي المراد طباعة إحصائيات صالاته ولجانه:</label>
                        <select name="locationId" class="form-select form-select-lg fw-bold" style="border-radius: 8px;" asp-items="ViewBag.Halls" required>
                            <option value="">-- حدد الجراش المستهدف --</option>
                        </select>
                    </div>

                    <div class="d-flex gap-3 justify-content-center pt-3 border-top">
                        <button type="submit" class="btn btn-info btn-lg px-5 fw-bold text-white shadow-sm" style="border-radius: 8px;">
                            <i class="bi bi-file-earmark-pdf-fill me-1"></i> عرض استمارة الهيكل
                        </button>
                        <a asp-action="Index" class="btn btn-light btn-lg px-4 border" style="border-radius: 8px;">العودة للخلف</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>