@model projectweb.Models.CommitteesAssignment

@{
    ViewData["Title"] = "تفاصيل التكليف";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" dir="rtl">
    <div class="col-xl-10">
        <div class="card academic-card mb-4">
            <div class="card-header academic-card-header text-white p-4 d-flex justify-content-between align-items-center">
                <h4 class="mb-0 fw-bold text-white"><i class="bi bi-info-circle-fill me-2"></i> بيانات التكليف</h4>
                <span class="badge bg-light fs-6" style="color: var(--primary-navy);">كود التكليف #@Model.AssignmentID</span>
            </div>
            <div class="card-body p-4" style="background-color: var(--surface-white);">

                <!-- بيانات الموظف -->
                <h5 class="fw-bold academic-heading border-bottom pb-2 mb-3" style="border-color: var(--border-color) !important;">
                    <i class="bi bi-person-fill me-2"></i> بيانات الموظف
                </h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="data-panel">
                            <div class="panel-label">اسم الموظف</div>
                            <div class="panel-value">
                                @if (Model.Person != null)
                                {
                                    <i class="bi bi-person me-1" style="color: var(--accent-blue);"></i> 
                                    @Model.Person.FullName
                                }
                                else
                                {
                                    <span class="text-muted">غير محدد</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="data-panel">
                            <div class="panel-label">الرقم القومي</div>
                            <div class="panel-value">
                                @(Model.Person != null ? Model.Person.NationalId : "—")
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="data-panel">
                            <div class="panel-label">حالة النشاط</div>
                            <div class="panel-value mt-1">
                                @if (Model.Person != null && Model.Person.IsActiveForAssignment)
                                {
                                    <span class="badge bg-success px-3 py-2"><i class="bi bi-check-circle me-1"></i> نشط</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary px-3 py-2"><i class="bi bi-x-circle me-1"></i> غير نشط</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- بيانات التكليف -->
                <h5 class="fw-bold academic-heading border-bottom pb-2 mb-3" style="border-color: var(--border-color) !important;">
                    <i class="bi bi-clipboard-check me-2"></i> تفاصيل التكليف
                </h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="data-panel">
                            <div class="panel-label">اللجنة</div>
                            <div class="panel-value">
                                @if (Model.Committee != null)
                                {
                                    <i class="bi bi-people me-1"></i>
                                    @Model.Committee.CommitteeNumber
                                }
                                else
                                {
                                    <span class="text-muted">غير محدد</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="data-panel">
                            <div class="panel-label">البلوك</div>
                            <div class="panel-value">
                                @if (Model.Committee != null && Model.Committee.Block != null)
                                {
                                    <i class="bi bi-box me-1"></i> 
                                    @Model.Committee.Block.BlockName
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="data-panel">
                            <div class="panel-label">الدور الوظيفي</div>
                            <div class="panel-value mt-1">
                                @if (Model.Role != null)
                                {
                                    switch (Model.Role.RoleName)
                                    {
                                        case StaffPosition.HallManager:
                                            <span class="badge bg-primary px-3 py-2"><i class="bi bi-building me-1"></i> رئيس صالة</span>
                                            break;
                                        case StaffPosition.BlockGroupLeader:
                                            <span class="badge bg-info px-3 py-2"><i class="bi bi-layers me-1"></i> رئيس مجموعة بلوكات</span>
                                            break;
                                        case StaffPosition.CommitteeObserver:
                                            <span class="badge bg-success px-3 py-2"><i class="bi bi-eye me-1"></i> مراقب</span>
                                            break;
                                        case StaffPosition.Doctor:
                                            <span class="badge bg-danger px-3 py-2"><i class="bi bi-heart-pulse me-1"></i> طبيب</span>
                                            break;
                                        case StaffPosition.Nurse:
                                            <span class="badge bg-warning text-dark px-3 py-2"><i class="bi bi-nurse me-1"></i> ممرض</span>
                                            break;
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">غير محدد</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="data-panel">
                            <div class="panel-label">حالة التكليف</div>
                            <div class="panel-value mt-1">
                                @if (Model.isReserve)
                                {
                                    <span class="badge bg-warning text-dark px-3 py-2"><i class="bi bi-person-plus me-1"></i> احتياطي</span>
                                }
                                else
                                {
                                    <span class="badge bg-success px-3 py-2"><i class="bi bi-check-circle me-1"></i> أساسي</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="data-panel">
                            <div class="panel-label">نوع التكليف</div>
                            <div class="panel-value">
                                @if (!string.IsNullOrEmpty(Model.AssignmentType))
                                {
                                    <i class="bi bi-tag me-1"></i> 
                                    @Model.AssignmentType
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="data-panel">
                            <div class="panel-label">مسمى الدور</div>
                            <div class="panel-value">
                                @if (!string.IsNullOrEmpty(Model.RoleType))
                                {
                                    <i class="bi bi-card-text me-1"></i> 
                                    @Model.RoleType
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- بيانات الجلسة الامتحانية -->
                <h5 class="fw-bold academic-heading border-bottom pb-2 mb-3" style="border-color: var(--border-color) !important;">
                    <i class="bi bi-calendar-event me-2"></i> بيانات الجلسة الامتحانية
                </h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="data-panel">
                            <div class="panel-label">المادة</div>
                            <div class="panel-value">
                                @if (Model.ExamSchedule != null && Model.ExamSchedule.Exam != null && Model.ExamSchedule.Exam.Subject != null)
                                {
                                    <i class="bi bi-book me-1" style="color: var(--accent-blue);"></i> 
                                    @Model.ExamSchedule.Exam.Subject.SubjectName
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="data-panel">
                            <div class="panel-label">تاريخ الجلسة</div>
                            <div class="panel-value">
                                @if (Model.ExamSchedule != null)
                                {
                                    <i class="bi bi-calendar3 me-1"></i> 
                                    @Model.ExamSchedule.ScheduledDate.ToString("yyyy/MM/dd")
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="data-panel">
                            <div class="panel-label">وقت الجلسة</div>
                            <div class="panel-value">
                                @if (Model.ExamSchedule != null)
                                {
                                    <i class="bi bi-clock me-1"></i> 
                                    @Model.ExamSchedule.StartTime.ToString(@"hh\:mm")
                                    @Model.ExamSchedule.EndTime.ToString(@"hh\:mm")
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- أزرار الإجراءات -->
                <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top" style="border-color: var(--border-color) !important;">
                    <a asp-action="Edit" asp-route-id="@Model.AssignmentID" class="btn btn-academic-primary px-4 fw-bold">
                        <i class="bi bi-pencil-square me-1"></i> تعديل
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.AssignmentID" class="btn btn-outline-danger px-4">
                        <i class="bi bi-trash me-1"></i> حذف
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">العودة للقائمة</a>
                </div>
            </div>
        </div>
    </div>
</div>
