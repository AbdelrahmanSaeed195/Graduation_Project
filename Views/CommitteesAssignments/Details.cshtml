@model projectweb.Models.CommitteesAssignment

@{
    ViewData["Title"] = "تفاصيل التكليف";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 text-end" dir="rtl">
    <div class="card mx-auto shadow-lg border-0 main-details-card" style="max-width: 800px; border-radius: 15px;">
        <div class="card-header bg-white py-4 text-center border-0 position-relative">
            <div class="position-absolute top-0 start-50 translate-middle-x mt-n3">
                <span class="badge rounded-pill bg-primary px-4 py-2 shadow badge-animate">بطاقة تكليف إداري</span>
            </div>
            <h3 class="fw-bold mt-3 header-title" style="color: #1a3a5a;">
                <i class="bi bi-person-check-fill me-2"></i> تفاصيل التكليف النهائي
            </h3>
        </div>

        <div class="card-body p-5 pt-0">
            <div class="row g-4">
                <div class="col-md-6 border-start border-light info-section">
                    <label class="text-muted small d-block mb-1">اسم الموظف المكلف:</label>
                    <h5 class="fw-bold text-dark mb-0 person-name">@Model.Person.FullName</h5>
                </div>

                <div class="col-md-6 info-section">
                    <label class="text-muted small d-block mb-1">المسمى الوظيفي في اللجنة:</label>
                    <h5 class="text-primary fw-bold mb-0 role-badge">@Model.RoleType</h5>
                    <small class="text-muted status-text">(@(Model.AssignmentType == "Auto" ? "تم التوزيع بواسطة النظام" : "تم التكليف يدوياً"))</small>
                </div>

                <div class="col-12"><hr class="opacity-25" /></div>

                <div class="col-12">
                    <div class="p-4 rounded-4 shadow-sm text-center border-start border-4 border-primary scope-box" style="background-color: #f8faff;">
                        <label class="text-muted d-block mb-3 fw-bold text-uppercase small">نطاق التكليف والمسئولية الجغرافية</label>

                        <div class="d-flex justify-content-center align-items-center gap-2 flex-wrap">
                            @if (Model.ExamLocation != null)
                            {
                                if (Model.ExamLocation.Type == projectweb.Models.LocationType.Hall)
                                {
                                    <h4 class="mb-0 text-dark fw-bold"><i class="bi bi-building me-1 text-primary"></i> كامل نطاق الجراش الرئيسي: (@Model.ExamLocation.LocationName)</h4>
                                }
                                else if (Model.ExamLocation.Type == projectweb.Models.LocationType.Block)
                                {
                                    <div class="text-muted">الجراش: @(Model.ExamLocation.ParentLocation?.LocationName ?? "عام")</div>
                                    <i class="bi bi-chevron-left text-primary mx-1"></i>
                                    <h4 class="mb-0 text-dark fw-bold"><i class="bi bi-grid-3x3 me-1 text-info"></i> كامل نطاق الصالة / البلوك: (@Model.ExamLocation.LocationName)</h4>
                                }
                                else if (Model.ExamLocation.Type == projectweb.Models.LocationType.Committee)
                                {
                                    <div class="text-muted">الجراش: @(Model.ExamLocation.ParentLocation?.ParentLocation?.LocationName ?? "عام")</div>
                                    <i class="bi bi-chevron-left text-primary mx-1"></i>
                                    <div class="text-muted">الصالة: @(Model.ExamLocation.ParentLocation?.LocationName ?? "عام")</div>
                                    <i class="bi bi-chevron-left text-primary mx-1"></i>
                                    <h4 class="mb-0 text-dark fw-bold"><i class="bi bi-person-workspace me-1 text-success"></i> @Model.ExamLocation.LocationName</h4>
                                }
                            }
                            else
                            {
                                <h4 class="mb-0 text-muted fw-bold">قوة احتياطية عامة (ملاحظ احتياطي بالكلية)</h4>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-md-4 text-center">
                    <div class="p-3 border rounded-3 bg-white h-100 shadow-sm info-card">
                        <i class="bi bi-book text-primary fs-4 d-block mb-2 icon-animate"></i>
                        <label class="text-muted small d-block">المادة الدراسية</label>
                        <p class="fw-bold mb-0">@Model.ExamSchedule?.Exam?.Subject?.SubjectName</p>
                    </div>
                </div>

                <div class="col-md-4 text-center">
                    <div class="p-3 border rounded-3 bg-white h-100 shadow-sm info-card">
                        <i class="bi bi-calendar-event text-success fs-4 d-block mb-2 icon-animate"></i>
                        <label class="text-muted small d-block">تاريخ الامتحان</label>
                        <p class="fw-bold mb-0">
                            @(Model.ExamSchedule?.Exam?.ExamDate.ToString("yyyy/MM/dd") ?? "غير محدد")
                        </p>
                    </div>
                </div>

                <div class="col-md-4 text-center">
                    <div class="p-3 border rounded-3 bg-white h-100 shadow-sm border-danger-subtle info-card highlight-card">
                        <i class="bi bi-clock-history text-danger fs-4 d-block mb-2 icon-animate"></i>
                        <label class="text-muted small d-block">توقيت الجلسة</label>
                        <p class="fw-bold mb-0 text-danger">
                            @if (Model.ExamSchedule?.Exam != null)
                            {
                                @(DateTime.Today.Add(Model.ExamSchedule.Exam.StartTime).ToString("hh:mm tt"))
                                <span> - </span>
                                @(DateTime.Today.Add(Model.ExamSchedule.Exam.EndTime).ToString("hh:mm tt"))
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer bg-light border-0 d-flex justify-content-center gap-3 py-4" style="border-radius: 0 0 15px 15px;">
            <a asp-action="Edit" asp-route-id="@Model.AssignmentId" class="btn btn-primary px-5 shadow-sm btn-hover-effect">
                <i class="bi bi-pencil-square me-1"></i> تعديل التكليف
            </a>
            <a asp-action="Index" asp-route-examId="@Model.ExamSchedule?.ExamId" class="btn btn-outline-dark px-5 shadow-sm bg-white btn-hover-effect-outline">
                <i class="bi bi-arrow-right-circle me-1"></i> العودة للجدول
            </a>
        </div>
    </div>
</div>

<style>
    .rounded-4 {
        border-radius: 1.2rem !important;
    }

    .main-details-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .info-card {
        transition: all 0.3s ease;
        cursor: default;
    }

        .info-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
            border-color: #0d6efd !important;
        }

    .highlight-card:hover {
        border-color: #dc3545 !important;
    }

    .info-card:hover .icon-animate {
        transform: scale(1.2);
        transition: transform 0.3s ease;
    }

    .scope-box {
        transition: all 0.4s ease;
    }

        .scope-box:hover {
            background-color: #eff6ff !important;
            transform: scale(1.02);
        }

    .btn-hover-effect {
        transition: all 0.3s ease;
    }

        .btn-hover-effect:hover {
            background-color: #0b4a8a !important;
            transform: translateX(-5px);
            box-shadow: 0 5px 15px rgba(13, 110, 253, 0.3);
        }

    .btn-hover-effect-outline {
        transition: all 0.3s ease;
    }

        .btn-hover-effect-outline:hover {
            background-color: #343a40 !important;
            color: white !important;
            transform: translateX(5px);
        }

    .badge-animate {
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.4);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(13, 110, 253, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(13, 110, 253, 0);
        }
    }
</style>