@model projectweb.Models.CommitteesAssignment

<div class="container mt-5 text-end" dir="rtl">
    <div class="card mx-auto shadow-sm border-0" style="max-width: 750px; border-radius: 15px;">
        <div class="card-header bg-white py-3 text-center border-0">
            <h4 class="fw-bold" style="color: #1a3a5a;"><i class="bi bi-info-square me-2"></i> تفاصيل التكليف الإداري</h4>
        </div>
        <div class="card-body p-4">
            <div class="row g-4 text-end">
                <div class="col-md-6">
                    <label class="text-muted small d-block">اسم الموظف:</label>
                    <h5 class="fw-bold text-dark">@Model.Person.FullName</h5>
                </div>
                <div class="col-md-6">
                    <label class="text-muted small d-block">المسمى الوظيفي في اللجنة:</label>
                    <h5 class="text-primary fw-bold">@Model.RoleType</h5>
                </div>

                <div class="col-md-12"><hr class="my-1 opacity-25" /></div>

                <div class="col-md-12 bg-light p-4 rounded shadow-sm text-center border-start border-4 border-primary">
                    <label class="text-muted d-block mb-2 fw-bold">نطاق التكليف والمسئولية:</label>
                    <h4 class="mb-0 text-dark fw-bold">
                        @if (Model.Committee != null)
                        {
                            <span class="badge bg-primary fs-5">لجنة رقم (@Model.Committee.CommitteeNumber)</span>
                        }
                        else if (Model.Block != null)
                        {
                            <span class="badge bg-info text-dark fs-5">بلوك (@Model.Block.BlockName) بالكامل</span>
                        }
                        else if (Model.Hall != null)
                        {
                            <span class="badge bg-warning text-dark fs-5">صالة (@Model.Hall.HallName) بالكامل</span>
                        }
                    </h4>
                    <p class="text-muted small mt-2 mb-0">تم التكليف بنظام: @(Model.AssignmentType == "Auto" ? "توزيع تلقائي" : "توزيع يدوي")</p>
                </div>

                <div class="col-md-4 pt-3 text-center border-end">
                    <label class="text-muted small d-block">المادة الدراسية:</label>
                    <p class="fw-bold mb-0">@Model.ExamSchedule?.Exam?.Subject?.SubjectName</p>
                </div>
                <div class="col-md-4 pt-3 text-center border-end">
                    <label class="text-muted small d-block">تاريخ الامتحان:</label>
                    <p class="fw-bold mb-0">@Model.ExamSchedule?.ScheduledDate.ToShortDateString()</p>
                </div>
                <div class="col-md-4 pt-3 text-center">
                    <label class="text-muted small d-block">وقت الجلسة:</label>
                    <p class="fw-bold mb-0 text-danger">
                        @if (Model.ExamSchedule?.Exam != null)
                        {
                            @* تحويل TimeSpan إلى وقت بصيغة 12 ساعة (ص/م) لعرض احترافي *@
                            @(DateTime.Today.Add(Model.ExamSchedule.Exam.StartTime).ToString("hh:mm tt"))
                            @:-
                            @(DateTime.Today.Add(Model.ExamSchedule.Exam.EndTime).ToString("hh:mm tt"))
                        }
                    </p>
                </div>
            </div>
        </div>

        <div class="card-footer bg-white border-0 d-flex justify-content-center gap-3 py-4">
            <a asp-action="Edit" asp-route-id="@Model.AssignmentID" class="btn btn-secondary px-5 shadow-sm">
                <i class="bi bi-pencil-square me-1"></i> تعديل
            </a>

            <a asp-action="Index" asp-route-scheduleId="@Model.ExamScheduleId" class="btn btn-outline-dark px-5 shadow-sm">
                <i class="bi bi-arrow-right-circle me-1"></i> العودة للقائمة
            </a>
        </div>
    </div>
</div>