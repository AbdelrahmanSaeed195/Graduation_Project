@model projectweb.Models.CommitteesAssignment

@{
    ViewData["Title"] = "تعديل بيانات التكليف";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 text-end" dir="rtl">
    <div class="card mx-auto shadow border-0" style="max-width: 700px; border-radius: 15px;">
        <div class="card-header text-white text-center py-3" style="border-radius: 15px 15px 0 0; background-color: #1a3a5a;">
            <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i> تعديل بيانات التكليف</h4>
        </div>
        <div class="card-body p-4 text-end">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4 py-2 small"></div>

                <input type="hidden" asp-for="AssignmentId" />
                <input type="hidden" asp-for="AssignmentType" />
                <input type="hidden" asp-for="ExamScheduleId" />
                <input type="hidden" asp-for="RoleId" id="roleInput" />
                <input type="hidden" asp-for="RoleType" id="roleTypeText" />

                <div class="mb-4">
                    <label class="form-label fw-bold"><i class="bi bi-person-badge me-1"></i> الموظف المكلف</label>
                    <select asp-for="PersonId" id="personSelect" class="form-select shadow-sm border-primary" asp-items="ViewBag.PersonId" style="border-radius: 8px;">
                        <option value="">-- اختر الموظف --</option>
                    </select>
                    <span asp-validation-for="PersonId" class="text-danger small"></span>
                </div>

                <div class="row bg-light p-3 rounded border mb-3 mx-0 shadow-sm" style="border-radius: 10px;">
                    <h6 class="fw-bold border-bottom pb-2 mb-3 text-secondary">
                        <i class="bi bi-geo-alt me-1"></i> تعديل نطاق المسئولية (المكان)
                    </h6>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold small text-muted">الجراش الرئيسي</label>
                        <select asp-for="LocationId" id="hallSelect" class="form-select shadow-sm" asp-items="ViewBag.LocationId" style="border-radius: 8px;">
                            <option value="">-- بلا --</option>
                        </select>
                        <small class="text-muted" style="font-size: 0.65rem;">خاص برؤساء الصالة والطاقم الطبي</small>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold small text-muted">الصالة / البلوك</label>
                        <select id="blockSelect" name="BlockLocationId" class="form-select shadow-sm" style="border-radius: 8px;">
                            <option value="">-- بلا --</option>
                        </select>
                        <small class="text-muted" style="font-size: 0.65rem;">خاص بمراقبي البلوكات</small>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold small text-muted">اللجنة الدقيقة</label>
                        <select id="committeeSelect" name="CommitteeLocationId" class="form-select shadow-sm" style="border-radius: 8px;">
                            <option value="">-- بلا --</option>
                        </select>
                        <small class="text-muted" style="font-size: 0.65rem;">خاص بملاحظي اللجان</small>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-primary btn-lg shadow fw-bold py-2" style="background-color: #1a3a5a; border: none; border-radius: 8px;">
                        <i class="bi bi-save me-1"></i> حفظ التغييرات
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg fw-bold py-2" style="border-radius: 8px;">
                        <i class="bi bi-x-circle me-1"></i> إلغاء والعودة للقائمة
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            const personSelect = $('#personSelect');
            const hallSelect = $('#hallSelect');
            const blockSelect = $('#blockSelect');
            const committeeSelect = $('#committeeSelect');

            // وظيفة التحكم في تفعيل وتعطيل الحقول بناءً على درجة الموظف
            function updateFieldsAvailability() {
                const selectedText = personSelect.find('option:selected').text() || "";

                hallSelect.prop('disabled', false);
                blockSelect.prop('disabled', false);
                committeeSelect.prop('disabled', false);

                if (selectedText.includes("أستاذ") || selectedText.includes("دكتور") || selectedText.includes("ممرض") || selectedText.includes("عميد")) {
                    blockSelect.val("").prop('disabled', true);
                    committeeSelect.val("").prop('disabled', true);
                }
                else if (selectedText.includes("مدرس") || selectedText.includes("معيد")) {
                    committeeSelect.val("").prop('disabled', true);
                }
            }

            // ميكانيكية مزامنة القيمة النهائية لـ LocationId الموحد قبل إرسال الفورم
            $('form').submit(function() {
                let finalLocationId = hallSelect.val();

                if (committeeSelect.val()) {
                    finalLocationId = committeeSelect.val();
                } else if (blockSelect.val()) {
                    finalLocationId = blockSelect.val();
                }

                // تعيين القيمة الأكثر دقة في شجرة المكان للحقل الأصلي المرسل للـ Controller
                hallSelect.val(finalLocationId);
            });

            personSelect.change(updateFieldsAvailability);
            updateFieldsAvailability();

            // إشعار التحميل الديناميكي المحدث عبر الـ Ajax المتوافق مع جدول ExamLocations
            hallSelect.change(function () {
                const hallId = $(this).val();

                blockSelect.html('<option value="">-- بلا --</option>');
                committeeSelect.html('<option value="">-- بلا --</option>');

                if (!hallId) return;

                // استدعاء أكشن الكنترولر المحدث GetHallDetails
                $.getJSON('@Url.Action("GetHallDetails")', { hallId: hallId }, function (data) {
                    $.each(data.blocks, function (i, b) {
                        blockSelect.append($('<option>', { value: b.id, text: b.name }));
                    });
                    $.each(data.committees, function (i, c) {
                        committeeSelect.append($('<option>', { value: c.id, text: c.name }));
                    });

                    updateFieldsAvailability();
                }).fail(function(err) {
                    console.error("Error loading spatial structural details:", err);
                });
            });
        });
    </script>
}