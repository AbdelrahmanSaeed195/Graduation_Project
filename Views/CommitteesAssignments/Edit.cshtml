@model projectweb.Models.CommitteesAssignment

@{
    ViewData["Title"] = "تعديل بيانات التكليف";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 text-end" dir="rtl">
    <div class="card mx-auto shadow border-0" style="max-width: 800px; border-radius: 15px;">
        <div class="card-header text-white text-center py-3" style="border-radius: 15px 15px 0 0; background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%);">
            <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i> تعديل بيانات التكليف الإداري</h4>
        </div>
        <div class="card-body p-4 p-md-5 text-end bg-white">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4 py-2 small"></div>

                <input type="hidden" asp-for="AssignmentId" />
                <input type="hidden" asp-for="AssignmentType" />
                <input type="hidden" asp-for="ExamScheduleId" />
                <input type="hidden" asp-for="RoleId" id="roleInput" />
                <input type="hidden" asp-for="RoleType" id="roleTypeText" />

                <div class="mb-4">
                    <label class="form-label fw-bold"><i class="bi bi-person-badge me-1 text-primary"></i> الموظف المكلف</label>
                    <select asp-for="PersonId" id="personSelect" class="form-select shadow-sm border-primary" asp-items="ViewBag.PersonId" style="border-radius: 8px;">
                        <option value="">-- اختر الموظف أو عضو هيئة التدريس --</option>
                    </select>
                    <span asp-validation-for="PersonId" class="text-danger small fw-bold"></span>
                </div>

                <div class="row bg-light p-4 rounded border mb-4 mx-0 shadow-sm" style="border-radius: 12px;">
                    <h6 class="fw-bold border-bottom pb-2 mb-3 text-secondary" style="color: #1a3a5a !important;">
                        <i class="bi bi-geo-alt-fill me-1 text-danger"></i> هندسة المسئولية المكانية التتابعية
                    </h6>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold small text-muted">1. الجراش الرئيسي الأب</label>
                        <select id="hallSelect" class="form-select shadow-sm" asp-items="ViewBag.LocationId" style="border-radius: 8px;">
                            <option value="">-- اختر الجراش الرئيسي --</option>
                        </select>
                        <div class="form-text" style="font-size: 0.7rem;"><i class="bi bi-info-circle"></i> خاص برؤساء الجراشات والقطاعات والأطباء</div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold small text-muted">2. القطاع / الصف الفرعي</label>
                        <select id="rowSelect" class="form-select shadow-sm" style="border-radius: 8px;" disabled>
                            <option value="">-- اختر الصف التنظيمي --</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3 mt-2">
                        <label class="form-label fw-bold small text-muted">3. الصالة المختصة</label>
                        <select id="blockSelect" class="form-select shadow-sm" style="border-radius: 8px;" disabled>
                            <option value="">-- اختر الصالة الفرعية --</option>
                        </select>
                        <div class="form-text" style="font-size: 0.7rem;"><i class="bi bi-info-circle"></i> النطاق التدريسي لمراقبي الصالات (مدرس)</div>
                    </div>

                    <div class="col-md-6 mb-3 mt-2">
                        <label class="form-label fw-bold small text-muted">4. اللجنة الدقيقة (المقاعد)</label>
                        <select id="committeeSelect" class="form-select shadow-sm" style="border-radius: 8px;" disabled>
                            <option value="">-- اختر اللجنة الفرعية --</option>
                        </select>
                        <div class="form-text" style="font-size: 0.7rem;"><i class="bi bi-info-circle"></i> النطاق الرقابي للملاحظين (معيد / موظف)</div>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-primary btn-lg shadow fw-bold py-2" style="background-color: #1a3a5a; border: none; border-radius: 8px;">
                        <i class="bi bi-save me-1"></i> حفظ التغييرات الحالية
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg fw-bold py-2" style="border-radius: 8px;">
                        <i class="bi bi-x-circle me-1"></i> إلغاء والعودة للقائمة
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            const personSelect = $('#personSelect');
            const hallSelect = $('#hallSelect');
            const rowSelect = $('#rowSelect');
            const blockSelect = $('#blockSelect');
            const committeeSelect = $('#committeeSelect');

            // قراءة الأكواد المحملة من السجل الحالي لغرض إعادة التسكين التلقائي عند فتح الشاشة
            const initialLocationId = '@Model.LocationId';

            function updateFieldsAvailability() {
                const selectedText = personSelect.find('option:selected').text() || "";

                // إعادة الضبط الأولية لخيارات التمكين
                hallSelect.prop('disabled', false);
                rowSelect.prop('disabled', !hallSelect.val());
                blockSelect.prop('disabled', !rowSelect.val());
                committeeSelect.prop('disabled', !blockSelect.val());

                // تطبيق الفحص الرتبي الصارم المتوافق مع الـ Service والـ JobTitle
                const isSenior = selectedText.includes("أستاذ") || selectedText.includes("دكتور") || selectedText.includes("مساعد دكتور");
                const isObserver = selectedText.includes("مدرس") && !selectedText.includes("مساعد");

                if (isSenior) {
                    // رؤساء الجراش والأطباء يربطون بالجراش مباشرة ويغلق ما دونه
                    rowSelect.val("").prop('disabled', true);
                    blockSelect.val("").prop('disabled', true);
                    committeeSelect.val("").prop('disabled', true);
                } else if (isObserver) {
                    // المراقب يربط بالصالة الفرعية ويغلق اللجان الدقيقة
                    committeeSelect.val("").prop('disabled', true);
                }
            }

            // الماكينة الهجين للـ AJAX: التتبع الرباعي الكامل لربط القوائم بالتتابع
            hallSelect.change(function () {
                const hallId = $(this).val();
                rowSelect.empty().append('<option value="">-- اختر الصف التنظيمي --</option>').prop('disabled', true);
                blockSelect.empty().append('<option value="">-- اختر الصالة الفرعية --</option>').prop('disabled', true);
                committeeSelect.empty().append('<option value="">-- اختر اللجنة الفرعية --</option>').prop('disabled', true);

                if (hallId) {
                    $.getJSON('@Url.Action("GetHallDetails")', { hallId: hallId }, function (data) {
                        rowSelect.prop('disabled', false);
                        $.each(data.rows, function (i, r) {
                            rowSelect.append($('<option>', { value: r.id, text: r.name }));
                        });
                        updateFieldsAvailability();
                    });
                }
            });

            // السحب الديناميكي للمقرات المندرجة برمجياً تحت الكيان المختار
            rowSelect.change(function () {
                const rowId = $(this).val();
                blockSelect.empty().append('<option value="">-- اختر الصالة الفرعية --</option>').prop('disabled', true);
                committeeSelect.empty().append('<option value="">-- اختر اللجنة الفرعية --</option>').prop('disabled', true);

                if (rowId) {
                    // جلب الصالات التابعة للصف
                    $.getJSON('/ExamLocations/GetSubLocations', { parentId: rowId }, function (blocks) {
                        blockSelect.prop('disabled', false);
                        $.each(blocks, function (i, b) {
                            blockSelect.append($('<option>', { value: b.locationId, text: b.locationName }));
                        });
                        updateFieldsAvailability();
                    });
                }
            });

            blockSelect.change(function () {
                const blockId = $(this).val();
                committeeSelect.empty().append('<option value="">-- اختر اللجنة الفرعية --</option>').prop('disabled', true);

                if (blockId) {
                    // جلب اللجان التابعة للصالة
                    $.getJSON('/ExamLocations/GetSubLocations', { parentId: blockId }, function (committees) {
                        committeeSelect.prop('disabled', false);
                        $.each(committees, function (i, c) {
                            committeeSelect.append($('<option>', { value: c.locationId, text: c.locationName }));
                        });
                        updateFieldsAvailability();
                    });
                }
            });

            committeeSelect.change(updateFieldsAvailability);
            personSelect.change(updateFieldsAvailability);

            // تجميع وتحديد القيمة المكتسبة النهائية لإسنادها لـ LocationId قبل الـ Submit
            $('form').submit(function () {
                let finalVal = hallSelect.val();

                if (committeeSelect.val() && !committeeSelect.prop('disabled')) {
                    finalVal = committeeSelect.val();
                } else if (blockSelect.val() && !blockSelect.prop('disabled')) {
                    finalVal = blockSelect.val();
                } else if (rowSelect.val() && !rowSelect.prop('disabled')) {
                    finalVal = rowSelect.val();
                }

                // إلغاء تسمية الـ select لكي لا يتعارض مع الحقل المخفي الممرر للموديل
                hallSelect.removeAttr('name');

                $('<input>').attr({
                    type: 'hidden',
                    name: 'LocationId',
                    value: finalVal
                }).appendTo('form');
            });

            // منطق سحب الهيكل بالكامل خلفياً وعرضه مسكناً تلقائياً عند فتح شاشة التعديل للتكليفات الحالية
            if (initialLocationId) {
                // استعلام خلفي سريع لـ معرف الأب والجد لتثبيت قيم المنسدلات للمستخدم
                $.getJSON('/ExamLocations/GetLocationHierarchy', { locationId: initialLocationId }, function (h) {
                    if (h) {
                        if (h.hallId) hallSelect.val(h.hallId).trigger('change');

                        // استخدام تكتيك التأخير الزمني لضمان اكتمال استعلامات الـ AJAX التتابعية وتأمين الاختيارات
                        setTimeout(function () {
                            if (h.rowId) rowSelect.val(h.rowId).trigger('change');
                            setTimeout(function () {
                                if (h.blockId) blockSelect.val(h.blockId).trigger('change');
                                setTimeout(function () {
                                    if (h.committeeId) committeeSelect.val(h.committeeId);
                                    updateFieldsAvailability();
                                }, 300);
                            }, 300);
                        }, 300);
                    }
                });
            } else {
                updateFieldsAvailability();
            }
        });
    </script>
}