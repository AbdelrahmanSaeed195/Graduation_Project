@model projectweb.Models.CommitteesAssignment

<div class="container mt-5 text-end" dir="rtl">
    <div class="card mx-auto shadow border-0" style="max-width: 700px; border-radius: 15px;">
        <div class="card-header bg-secondary text-white text-center py-3" style="border-radius: 15px 15px 0 0;">
            <h4 class="mb-0">تعديل بيانات التكليف</h4>
        </div>
        <div class="card-body p-4 text-end">
            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4 py-2"></div>

                <input type="hidden" asp-for="AssignmentID" />
                <input type="hidden" asp-for="AssignmentType" />
                <input type="hidden" asp-for="ExamScheduleId" />
                <input type="hidden" asp-for="RoleID" /> @* لو مش محتاج تغير الدور يفضل تخليه Hidden *@

                <div class="mb-3">
                    <label class="form-label fw-bold">الموظف</label>
                    <select asp-for="PersonID" class="form-select shadow-sm" asp-items="ViewBag.PersonID"></select>
                    <span asp-validation-for="PersonID" class="text-danger small"></span>
                </div>

                <div class="row bg-light p-3 rounded border mb-3 mx-0">
                    <h6 class="fw-bold border-bottom pb-2 mb-3">تعديل نطاق المسئولية (اختر النطاق الصحيح)</h6>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold small text-muted">تغيير الصالة</label>
                        <select asp-for="HallId" class="form-select shadow-sm" asp-items="ViewBag.HallId">
                            <option value="">-- بلا --</option>
                        </select>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold small text-muted">تغيير البلوك</label>
                        <select asp-for="BlockId" class="form-select shadow-sm" asp-items="ViewBag.BlockId">
                            <option value="">-- بلا --</option>
                        </select>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold small text-muted">تغيير اللجنة</label>
                        <select asp-for="CommitteeID" class="form-select shadow-sm" asp-items="ViewBag.CommitteeID">
                            <option value="">-- بلا --</option>
                        </select>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-primary btn-lg shadow">تحديث البيانات</button>
                    <a asp-action="Index" asp-route-scheduleId="@Model.ExamScheduleId" class="btn btn-light btn-lg border">إلغاء</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}