@model projectweb.Models.CommitteesAssignment

<div class="container mt-5 text-end" dir="rtl">
    <div class="card mx-auto shadow border-0" style="max-width: 700px; border-radius: 15px;">
        <div class="card-header text-white text-center py-3" style="background-color: #1a3a5a;">
            <h4 class="mb-0">إنشاء تكليف يدوي جديد</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4 py-2"></div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label asp-for="PersonID" class="form-label fw-bold"></label>
                        <select asp-for="PersonID" class="form-select" asp-items="ViewBag.PersonID"></select>
                        <span asp-validation-for="PersonID" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="RoleID" class="form-label fw-bold"></label>
                        <select asp-for="RoleID" class="form-select" asp-items="ViewBag.RoleID"></select>
                        <span asp-validation-for="RoleID" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="ExamScheduleId" class="form-label fw-bold"></label>
                        <select asp-for="ExamScheduleId" class="form-select" asp-items="ViewBag.ExamScheduleId"></select>
                        <span asp-validation-for="ExamScheduleId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12 my-3 p-3 bg-light rounded border">
                        <h6 class="fw-bold border-bottom pb-2">نطاق المسئولية (اختر النطاق المناسب للدور فقط)</h6>
                        <div class="row">
                            <div class="col-md-4">
                                <label class="small text-muted">صالة (رئيس صالة/طبي)</label>
                                <select asp-for="HallId" class="form-select mt-1" asp-items="ViewBag.HallId"><option value="">-- بلا --</option></select>
                            </div>
                            <div class="col-md-4">
                                <label class="small text-muted">بلوك (مراقب)</label>
                                <select asp-for="BlockId" class="form-select mt-1" asp-items="ViewBag.BlockId"><option value="">-- بلا --</option></select>
                            </div>
                            <div class="col-md-4">
                                <label class="small text-muted">لجنة (ملاحظ)</label>
                                <select asp-for="CommitteeID" class="form-select mt-1" asp-items="ViewBag.CommitteeID"><option value="">-- بلا --</option></select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-dark btn-lg shadow">حفظ التكليف</button>
                    <a asp-action="Index" class="btn btn-light">إلغاء</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}