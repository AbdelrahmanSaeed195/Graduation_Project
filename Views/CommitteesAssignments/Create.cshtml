@model projectweb.Models.CommitteesAssignment

@{
    ViewData["Title"] = "تكليف يدوي جديد";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5" dir="rtl" style="text-align: right;">
    <div class="card mx-auto shadow border-0" style="max-width: 800px; border-radius: 15px;">
        <div class="card-header text-white text-center py-3" style="background: linear-gradient(135deg, #1a3a5a 0%, #2e5a88 100%); border-radius: 15px 15px 0 0;">
            <h4 class="mb-0 fw-bold text-white"><i class="bi bi-person-plus-fill me-2"></i> إنشاء تكليف يدوي جديد</h4>
        </div>
        <div class="card-body p-4 p-md-5 bg-white">
            <form asp-action="Create" method="post" id="createForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4 py-2 small" style="border-radius: 8px;"></div>

                <div class="row g-3">
                    <div class="col-md-12 mb-2">
                        <label class="form-label fw-bold text-dark mb-2"><i class="bi bi-person-circle me-1 text-primary"></i> اختيار الموظف / عضو هيئة التدريس</label>
                        <select asp-for="PersonId" id="personSelect" class="form-select shadow-sm border-light-subtle"
                                asp-items="@(ViewBag.PersonId as SelectList ?? new SelectList(Enumerable.Empty<SelectListItem>()))" style="border-radius: 8px;">
                            <option value="">-- اختر الموظف (الاسم والوظيفة) --</option>
                        </select>
                        <span asp-validation-for="PersonId" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-bold text-dark mb-2"><i class="bi bi-calendar-check me-1 text-success"></i> جلسة الامتحان المعنية</label>
                        <select asp-for="ExamScheduleId" class="form-select shadow-sm border-light-subtle"
                                asp-items="@(ViewBag.ExamScheduleId as SelectList ?? new SelectList(Enumerable.Empty<SelectListItem>()))" style="border-radius: 8px; font-size: 0.9rem;">
                            <option value="">-- اختر الجلسة (المادة - التاريخ) --</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-2">
                        <label class="form-label fw-bold text-dark mb-2"><i class="bi bi-briefcase me-1 text-info"></i> الدور في اللجنة</label>
                        <select asp-for="RoleId" id="roleSelect" class="form-select shadow-sm border-light-subtle"
                                asp-items="@(ViewBag.RoleId as SelectList ?? new SelectList(Enumerable.Empty<SelectListItem>()))" style="border-radius: 8px;">
                            <option value="">-- اختر الدور المكلف به --</option>
                        </select>
                    </div>

                    <div class="col-md-12 my-3 p-4 rounded-3 border shadow-sm" style="background-color: #f8faff; border-radius: 12px !important;">
                        <h6 class="fw-bold border-bottom pb-2 mb-3 text-primary"><i class="bi bi-geo-alt-fill me-1 text-danger"></i> تحديد نطاق المسئولية (المكان)</h6>
                        <div class="row g-3">
                            <div class="col-md-6 mb-2">
                                <label class="small text-muted fw-bold d-block mb-2">1. الجراش الرئيسي الأب</label>
                                <select id="hallSelect" class="form-select form-select-sm shadow-sm" style="border-radius: 6px;" asp-items="ViewBag.LocationId">
                                    <option value="">-- اختر الجراش الرئيسي --</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-2">
                                <label class="small text-muted fw-bold d-block mb-2">2. القطاع / الصف الفرعي</label>
                                <select id="rowSelect" class="form-select form-select-sm shadow-sm" style="border-radius: 6px;" disabled>
                                    <option value="">-- اختر الصف التنظيمي --</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-2">
                                <label class="small text-muted fw-bold d-block mb-2">3. الصالة الفرعية</label>
                                <select id="blockSelect" class="form-select form-select-sm shadow-sm" style="border-radius: 6px;" disabled>
                                    <option value="">-- اختر الصالة --</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-2">
                                <label class="small text-muted fw-bold d-block mb-2">4. اللجنة الدقيقة</label>
                                <select id="committeeSelect" class="form-select form-select-sm shadow-sm" style="border-radius: 6px;" disabled>
                                    <option value="">-- اختر اللجنة --</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-lg shadow text-white fw-bold py-2" style="background-color: #1a3a5a; border-radius: 8px;">
                        <i class="bi bi-check-all me-1"></i> إتمام وحفظ التكليف
                    </button>
                    <a asp-action="Index" class="btn btn-light border py-2 fw-bold" style="border-radius: 8px;">إلغاء</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            const roleSelect = $('#roleSelect');
            const hallSelect = $('#hallSelect');
            const rowSelect = $('#rowSelect');
            const blockSelect = $('#blockSelect');
            const committeeSelect = $('#committeeSelect');
            const personSelect = $('#personSelect');

            function updateFieldsAvailability() {
                const roleText = roleSelect.find("option:selected").text() || "";

                // تفعيل ديناميكي تتابعي
                hallSelect.prop('disabled', false);
                rowSelect.prop('disabled', !hallSelect.val());
                blockSelect.prop('disabled', !rowSelect.val());
                committeeSelect.prop('disabled', !blockSelect.val());

                // فحص القادة (رؤساء الجراشات والطاقم الطبي) -> يكتفون بالجراش الأب
                if (roleText.includes("رئيس جراش") || roleText.includes("دكتور") || roleText.includes("مساعد دكتور")) {
                    rowSelect.prop('disabled', true).val("");
                    blockSelect.prop('disabled', true).val("");
                    committeeSelect.prop('disabled', true).val("");
                }
                // المراقب -> يكتفي بالصالة الفرعية
                else if (roleText.includes("مراقب")) {
                    committeeSelect.prop('disabled', true).val("");
                }
            }

            // ربط تلقائي ذكي للـ RoleId بناءً على المسمى العلمي للشخص المختار
            personSelect.change(function () {
                const text = $(this).find("option:selected").text();
                if (text.includes("أستاذ متفرغ")) roleSelect.val("3");
                else if (text.includes("أستاذ مساعد")) roleSelect.val("2");
                else if (text.includes("أستاذ")) roleSelect.val("1");
                else if (text.includes("مدرس")) roleSelect.val("4");
                else if (text.includes("معيد")) roleSelect.val("5");
                else if (text.includes("مدرس مساعد")) roleSelect.val("6");
                else if (text.includes("موظف")) roleSelect.val("7");
                updateFieldsAvailability();
            });

            roleSelect.change(updateFieldsAvailability);

            // تتابع الـ AJAX الشجري المتوافق مع الكنترولر المطور
            hallSelect.change(function () {
                const hallId = $(this).val();
                rowSelect.empty().append('<option value="">-- اختر الصف التنظيمي --</option>').prop('disabled', true);
                blockSelect.empty().append('<option value="">-- اختر الصالة --</option>').prop('disabled', true);
                committeeSelect.empty().append('<option value="">-- اختر اللجنة --</option>').prop('disabled', true);

                if (!hallId) return;

                $.getJSON('@Url.Action("GetHallDetails")', { hallId: hallId }, function (data) {
                    rowSelect.prop('disabled', false);
                    $.each(data.rows, (i, r) => rowSelect.append($('<option>', { value: r.id, text: r.name })));
                    updateFieldsAvailability();
                });
            });

            rowSelect.change(function () {
                const rowId = $(this).val();
                blockSelect.empty().append('<option value="">-- اختر الصالة --</option>').prop('disabled', true);
                committeeSelect.empty().append('<option value="">-- اختر اللجنة --</option>').prop('disabled', true);

                if (!rowId) return;

                $.getJSON('/ExamLocations/GetSubLocations', { parentId: rowId }, function (blocks) {
                    blockSelect.prop('disabled', false);
                    $.each(blocks, (i, b) => blockSelect.append($('<option>', { value: b.locationId, text: b.locationName })));
                    updateFieldsAvailability();
                });
            });

            blockSelect.change(function () {
                const blockId = $(this).val();
                committeeSelect.empty().append('<option value="">-- اختر اللجنة --</option>').prop('disabled', true);

                if (!blockId) return;

                $.getJSON('/ExamLocations/GetSubLocations', { parentId: blockId }, function (committees) {
                    committeeSelect.prop('disabled', false);
                    $.each(committees, (i, c) => committeeSelect.append($('<option>', { value: c.locationId, text: c.locationName })));
                    updateFieldsAvailability();
                });
            });

            committeeSelect.change(updateFieldsAvailability);

            // تجميع وتمرير معرف التكليف النهائي المطلوب لقاعدة البيانات قبل الإرسال
            $('#createForm').submit(function() {
                let finalLoc = committeeSelect.val() || blockSelect.val() || rowSelect.val() || hallSelect.val();
                hallSelect.removeAttr('name'); // إزالة مسمى الحقل لضمان عدم حدوث تداخل
                $('<input>').attr({type: 'hidden', name: 'LocationId', value: finalLoc}).appendTo(this);
            });
        });
    </script>
}