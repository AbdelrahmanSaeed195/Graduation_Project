@model projectweb.Models.CommitteesAssignment

<div class="container mt-5 text-end" dir="rtl">
    <div class="card mx-auto shadow border-0" style="max-width: 750px; border-radius: 15px;">
        <div class="card-header text-white text-center py-3" style="background-color: #1a3a5a;">
            <h4 class="mb-0"><i class="bi bi-person-plus me-2"></i> إنشاء تكليف يدوي جديد</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 mb-4 py-2"></div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold">الموظف</label>
                        <select asp-for="PersonID" class="form-select shadow-sm" asp-items="ViewBag.PersonID">
                            <option value="">-- اختر الموظف --</option>
                        </select>
                        <span asp-validation-for="PersonID" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">الدور في اللجنة</label>
                        <select asp-for="RoleID" class="form-select shadow-sm" asp-items="ViewBag.RoleID"></select>
                        <span asp-validation-for="RoleID" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">جلسة الامتحان</label>
                        <select asp-for="ExamScheduleId" class="form-select shadow-sm" asp-items="ViewBag.ExamScheduleId"></select>
                        <span asp-validation-for="ExamScheduleId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12 my-3 p-3 bg-light rounded border">
                        <h6 class="fw-bold border-bottom pb-2 mb-3"><i class="bi bi-geo-alt me-1"></i> نطاق المسئولية (اختر النطاق المناسب للدور)</h6>
                        <div class="row">
                            <div class="col-md-4">
                                <label class="small text-muted fw-bold">صالة (رئيس صالة/طبي)</label>
                                <select asp-for="HallId" class="form-select mt-1 shadow-sm" asp-items="ViewBag.HallId">
                                    <option value="">-- بلا --</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="small text-muted fw-bold">بلوك (مراقب)</label>
                                <select asp-for="BlockId" class="form-select mt-1 shadow-sm" asp-items="ViewBag.BlockId">
                                    <option value="">-- بلا --</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="small text-muted fw-bold">لجنة (ملاحظ)</label>
                                <select asp-for="CommitteeID" class="form-select mt-1 shadow-sm" asp-items="ViewBag.CommitteeID">
                                    <option value="">-- بلا --</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-dark btn-lg shadow"><i class="bi bi-save me-1"></i> حفظ التكليف</button>
                    <a asp-action="Index" class="btn btn-light border">إلغاء</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}